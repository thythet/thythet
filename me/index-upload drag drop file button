    async function publishPost(e){
      e.preventDefault();
      const statusEl = document.getElementById('composerStatus');
      const publishBtn = e.target.querySelector('button[type="submit"]');
      const setComposerStatus = (message, type="") => {
        if(!statusEl) return;
        statusEl.textContent = message;
        statusEl.className = "composer-status" + (type ? " " + type : "");
      };

      const titleInput = document.getElementById('titleInput');
      const title = titleInput?.value.trim() || "";
      const captionInput = document.getElementById('captionInput');
      let caption = captionInput.value.trim();
      if(captionHasUrl(caption)){
        caption = stripCaptionUrls(caption);
        captionInput.value = caption;
        setComposerStatus("Links are not allowed in caption.", "error");
        saveComposerDraft();
        return;
      }
      const audioUrlInput = safeAudioURL(document.getElementById('audioUrlInput').value);

      const imagePayload = getImagePayload();
      let images = imagePayload.images;
      let hdImages = imagePayload.hdImages;
      let audioUrls = getAudioLinks();
      let audioPublic = getAudioPublicValues();
      let audioUrl = audioUrls[0] || audioUrlInput;

      if(USE_FIREBASE){
        try{
        setComposerStatus("Publishing...");
        if(publishBtn) publishBtn.disabled = true;
        const signedInUser = auth && auth.currentUser ? auth.currentUser : currentUser;
        currentUser = signedInUser;
        updateAuthUI();

        if(!signedInUser){
          alert("Please login first.");
          setComposerStatus("Please login first.", "error");
          return;
        }

        if(!canUpload()){
          setComposerStatus("Request upload access before publishing.", "error");
          alert("Please request upload access first. An admin must approve your account before you can publish.");
          renderRoleUI();
          return;
        }

        const wasEditing = !!editingPostId;
        const editingPost = editingPostId ? firebasePosts.find(post => post.id === editingPostId) : null;
        if(!wasEditing && !clientActionAllowed(`publish:${signedInUser.uid}`, 4, 10 * 60000)){
          setComposerStatus("Please wait before publishing another post.", "error");
          return;
        }
        if(editingPostId && !editingPost){
          setComposerStatus("Could not find the post to edit. Refresh and try again.", "error");
          return;
        }
        if(editingPost && signedInUser.uid !== editingPost.authorUid && !isAdmin()){
          setComposerStatus("You can only edit your own posts.", "error");
          alert("You can only edit your own posts.");
          return;
        }

        if(!isAdmin() && !wasEditing){
          const ownedCount = firebasePosts.filter(post => post.authorUid === signedInUser.uid).length;
          if(ownedCount >= 100){
            setComposerStatus("You reached the 100 post limit. Pro upgrade will be available later.", "error");
            alert("You reached the 100 post limit. Pro upgrade will be available later.");
            return;
          }
        }

        const imageCheck = sanitizeImageLinkInputs({excludePostId:editingPostId, showStatus:true});
        const cleanImagePayload = getImagePayload();
        images = cleanImagePayload.images;
        hdImages = cleanImagePayload.hdImages;
        if(!imageCheck.ok){
          setComposerStatus(imageCheck.removedPlatform ? "Image already posted." : "Duplicate image removed.", "error");
          return;
        }

        if(!audioUrls.length && audioFileNameInput?.value.trim()){
          audioUrl = safeAudioURL(await detectAudioFromStorage(false));
          if(!audioUrl){
            setComposerStatus("Could not find that audio file in your storage links.", "error");
            alert("Could not find that audio file in your saved storage links.");
            return;
          }
          audioUrls = [audioUrl];
          setAudioLinks(audioUrls);
        }

        if(!images.length){
          alert("Please add at least one image.");
          setComposerStatus("Please add at least one image.", "error");
          return;
        }
        const audienceSettings = getAudienceSettings();
        if(audienceSettings.audience === "selected" && !audienceSettings.audienceUsers.length){
          setComposerTab("audience");
          setComposerStatus("Add at least one email or user ID for selected audience.", "error");
          return;
        }

        const postRef = editingPostId
          ? fb.dbRef(db, `sermonPosts/${editingPostId}`)
          : fb.push(fb.dbRef(db, 'sermonPosts'));
        const savedPostId = editingPostId || postRef.key;
        const createdAt = editingPost?.createdAt || Date.now();
        const publishesDirectly = isAdmin() || isProUser();
        let payload = {
          authorUid:signedInUser.uid,
          authorName:signedInUser.displayName || "Church Member",
          authorEmail:signedInUser.email || "",
          authorPhoto:signedInUser.photoURL || "",
          images,
          hdImages,
          hdUpload:hdImages.some(Boolean),
          audioUrl:audioUrls[0] || "",
          audioUrls,
          audioPublic,
          title,
          caption,
          audience:audienceSettings.audience,
          audienceUsers:audienceSettings.audienceUsers,
          likes:Number(editingPost?.likes || 0),
          shares:Number(editingPost?.shares || 0),
          views:Number(editingPost?.views || 0),
          createdAt,
          updatedAt:Date.now(),
          status:publishesDirectly ? "published" : "pending"
        };
        payload = securePostPayload(payload);
        if(!payload.images.length){
          setComposerStatus("Please add a safe image URL.", "error");
          alert("Please add a safe image URL.");
          return;
        }
        const tokenPost = {...payload, id:savedPostId};
        payload.shareToken = editingPost?.shareToken || postShareToken(tokenPost, [...firebasePosts.filter(post => post.id !== savedPostId), tokenPost]);
        if(editingPost && signedInUser.uid !== editingPost.authorUid && isAdmin()){
          payload.authorUid = clampText(editingPost.authorUid, 128);
          payload.authorName = clampText(editingPost.authorName || "Church Member", 80);
          payload.authorEmail = clampText(editingPost.authorEmail || "", 160);
          payload.authorPhoto = safeImageURL(editingPost.authorPhoto || "");
        }
        await fb.set(postRef, payload);
        if(!wasEditing && payload.status === "published"){
          await notifyFollowersOfPost(savedPostId, payload);
        }

        e.target.reset();
        setAudioLinks([]);
        clearComposerDraft();
        setHdUploadEnabled(false);
        setComposerMode(null);
        closeComposer(false);
        setComposerStatus(
          publishesDirectly
            ? (wasEditing ? "Updated successfully." : "Published successfully.")
            : "Submitted for admin approval.",
          "success"
        );
        loadFirebasePosts();
        }catch(error){
          console.error("Publish failed:", error);
          const message = error && (error.code || error.message)
            ? `${error.code || "Error"}: ${error.message || ""}`.trim()
            : "Unknown Firebase error.";
          setComposerStatus("Publish failed. " + message, "error");
          alert("Publish failed.\n\n" + message + "\n\nIf this says permission_denied, update Realtime Database rules.");
        }finally{
          if(publishBtn) publishBtn.disabled = false;
        }
      }else{
        const post = {
          id:"local_" + Date.now(),
          authorName:"Thy Thet",
          authorEmail:"thythet@gmail.com",
          authorPhoto:"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=200&q=80",
          images: images.length ? images : demoPosts[0].images,
          hdImages: images.length ? hdImages : [],
          audioUrl:audioUrls[0] || "",
          audioUrls,
          audioPublic,
          title,
          caption: caption || "New sermon post caption...",
          likes:0, shares:0, views:0,
          createdAt:Date.now()
        };
        demoPosts.unshift(post);
        e.target.reset();
        setHdUploadEnabled(false);
        closeComposer();
        renderPosts(demoPosts);
      }
    }

