    async function pruneDuplicateLikeNotifications(){
      if(!USE_FIREBASE || !currentUser) return;
      const groups = {};
      Object.entries(userNotifications || {}).forEach(([id, item]) => {
        if(item?.type !== "like" || !item.actorUid || !item.postId) return;
        const key = `${item.actorUid}_${item.postId}`;
        if(!groups[key]) groups[key] = [];
        groups[key].push([id, item]);
      });
      const updates = {};
      Object.values(groups).forEach(items => {
        if(items.length < 2) return;
        items.sort((a, b) => (b[1]?.createdAt || 0) - (a[1]?.createdAt || 0));
        const stableId = items.find(([id, item]) => id === likeNotificationId(item.postId, item.actorUid));
        const keepId = stableId?.[0] || items[0][0];
        items.forEach(([id]) => {
          if(id === keepId) return;
          updates[`sermonNotifications/${currentUser.uid}/${id}`] = null;
          delete userNotifications[id];
        });
      });
      if(!Object.keys(updates).length) return;
      renderNotificationList();
      refreshNotificationBadge();
      try{
        await fb.update(fb.dbRef(db), updates);
      }catch(error){
        console.warn("Could not prune duplicate like notifications:", error);
      }
    }

