    function stripCaptionUrls(text=""){
      return String(text || "")
        .replace(/https?:\/\/\S+/gi, "")
        .replace(/\bwww\.\S+/gi, "")
        .replace(/\b[\w-]+\.(?:com|net|org|io|co|app|info|me|tv|kh)\S*/gi, "")
        .replace(/[ \t]{2,}/g, " ")
        .trimStart();
    }

