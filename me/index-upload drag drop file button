    function currentSeenUser(){
      return {
        uid:currentUser?.uid || "",
        email:currentUser?.email || "",
        name:currentUser?.displayName || currentProfile?.name || "Church Member",
        photo:currentUser?.photoURL || currentProfile?.photo || "",
        at:Date.now()
      };
    }

    function currentActor(){
      return currentSeenUser();
    }

    function shareCountKey(postId){
      return "sermonPost_" + String(postId || "").replace(/[.#$\[\]\/]/g, "_");
    }

    function shareCountForPost(post){
      const liveCount = postShareCounts[shareCountKey(post?.id)];
      return Number(liveCount ?? post?.shares ?? 0);
    }

    function isFollowing(uid){
      return !!currentFollowing[uid];
    }

    function isSavedPost(postId){
      return savedPostIds.has(postId);
    }

    function isFavoriteUser(uid){
      return favoriteUserIds.has(uid);
    }

    function normalizeAudience(value="followers"){
      return ["public","following","followers","followers_following","only_me","selected"].includes(value) ? value : "followers";
    }

    function audienceLabel(value="public"){
      const audience = normalizeAudience(value || "public");
      return ({
        public:"Public",
        following:"Following only",
        followers:"Followers only",
        followers_following:"Followers & following",
        only_me:"Only me",
        selected:"Selected users"
      })[audience] || "Public";
    }

    function parseAudienceUsers(value=""){
      return String(value || "")
        .split(/[\n,]+/)
        .map(item => item.trim().toLowerCase())
        .filter(Boolean);
    }

    function canViewPostAudience(post){
      const audience = normalizeAudience(post?.audience || "public");
      if(isAdmin() || post?.authorUid === currentUser?.uid) return true;
      if(audience === "public") return true;
      if(!currentUser) return false;
      const viewerUid = currentUser.uid;
      const authorUid = post?.authorUid || "";
      if(audience === "only_me") return false;
      const isFollower = !!allFollows?.[authorUid]?.[viewerUid];
      const isAuthorFollowingViewer = !!allFollows?.[viewerUid]?.[authorUid];
      if(audience === "followers") return isFollower;
      if(audience === "following") return isAuthorFollowingViewer;
      if(audience === "followers_following") return isFollower || isAuthorFollowingViewer;
      if(audience === "selected"){
        const allowed = (Array.isArray(post.audienceUsers) ? post.audienceUsers : []).map(item => String(item || "").toLowerCase());
        const email = String(currentUser.email || "").toLowerCase();
        return allowed.includes(viewerUid.toLowerCase()) || (!!email && allowed.includes(email));
      }
      return true;
    }

    function hasPostImages(post){
      return Array.isArray(post?.images) && post.images.some(src => String(src || "").trim());
    }

    function isValidPost(post){
      return !!post?.id && !!post?.authorUid && hasPostImages(post);
    }

    function isDeletedPost(post){
      return post?.deletedAt || post?.deleted === true;
    }

    function visiblePostsFrom(posts){
      const base = posts.filter(post => isValidPost(post)
        && !isDeletedPost(post)
        && (isAdmin() || post.blockedByAdmin !== true)
        && canViewPostAudience(post)
        && (post.status !== "pending" || isAdmin() || post.authorUid === currentUser?.uid));
      if(!currentUser) return base;
      if(activeFeedFilter === "mine") return base.filter(post => post.authorUid === currentUser.uid);
      if(activeFeedFilter === "following") return base.filter(post => post.authorUid === currentUser.uid || isFollowing(post.authorUid));
      if(activeFeedFilter === "favorite") return base.filter(post => isFavoriteUser(post.authorUid));
      if(activeFeedFilter === "saved") return base.filter(post => isSavedPost(post.id));
      return base;
    }

    function visiblePosts(){
      return visiblePostsFrom(firebasePosts);
    }

    function refreshFollowUI(uid){
      if(!uid) return;
      const following = isFollowing(uid);
      document.querySelectorAll(`[data-follow-uid="${uid}"]`).forEach(btn => {
        btn.classList.toggle('following', following);
        btn.setAttribute('aria-label', following ? "Following" : "Follow");
        if(btn.classList.contains('follow-btn')){
          btn.textContent = following ? "Following" : "Follow";
        }
      });
      document.querySelectorAll(`[data-profile-uid="${uid}"] .email`).forEach(el => {
        el.innerHTML = followerStatusHTML(uid);
      });
      document.querySelectorAll(`[data-user-uid="${uid}"] .request-subline`).forEach(el => {
        el.innerHTML = followerStatusHTML(uid);
      });
      if(currentUser && uid === currentUser.uid) updateAuthUI();
      refreshSeenBoardIfOpen();
      if(userProfileBoard.classList.contains('open') && userProfileBoard.dataset.profileUid === uid){
        openUserProfile(uid);
      }
      if(notificationBoard.classList.contains('open')) renderNotificationList();
    }

