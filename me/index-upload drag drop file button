        try{
          await clearActivityLog();
        }catch(error){
          console.error("Could not clear activity log:", error);
          clearActivityBtn.disabled = false;
          alert("Could not clear Activity Log. Please check Firebase rules.");
        }
        return;
      }

      if(activityProfileBtn){
        openUserProfile(activityProfileBtn.dataset.profileOpen);
        return;
      }

      if(activityPostBtn){
        closeProfileBoard();
        goToPost(activityPostBtn.dataset.goPostId);
        return;
      }

      if(restoreBtn){
        restoreBtn.disabled = true;
        try{
          await restorePostFromTrash(restoreBtn.dataset.restorePostId);
          await loadFirebasePosts();
          renderAdminActivity();
        }catch(error){
          console.error("Could not restore post:", error);
          restoreBtn.disabled = false;
          alert("Could not restore this post. Please check Firebase rules.");
        }
        return;
      }

      if(permanentDeleteBtn){
        const confirmed = window.confirm("Permanently delete this post? This cannot be undone.");
        if(!confirmed) return;
        permanentDeleteBtn.disabled = true;
        try{
          await permanentlyDeletePost(permanentDeleteBtn.dataset.permanentDeletePostId);
          await loadFirebasePosts();
          renderAdminActivity();
        }catch(error){
          console.error("Could not permanently delete post:", error);
          permanentDeleteBtn.disabled = false;
          alert("Could not permanently delete this post. Please check Firebase rules.");
        }
        return;
      }

      if(imageOverlayToggle){
        imageOverlayToggle.disabled = true;
        try{
          await setImageOverlayHidden(!appSettings.hideImageOverlay);
        }finally{
          imageOverlayToggle.disabled = false;
        }
        return;
      }

      if(saveLoginTitleBtn){
        saveLoginTitleBtn.disabled = true;
        try{
          await saveLoginTitleSetting();
        }finally{
          saveLoginTitleBtn.disabled = false;
        }
        return;
      }

      if(userRow){
        const uid = userRow.dataset.requestUid;
        const approve = e.target.closest('.approve-user-btn');
        const reject = e.target.closest('.reject-user-btn');
        if(!approve && !reject) return;

        await fb.update(fb.dbRef(db, `sermonUsers/${uid}`), approve ? {
          role:"content_creator",
          status:"approved",
          approvedAt:Date.now(),
          approvedBy:currentUser.email,
          updatedAt:Date.now()
        } : {
          role:"viewer",
          status:"rejected",
          rejectedAt:Date.now(),
          rejectedBy:currentUser.email,
          updatedAt:Date.now()
        });
        await loadAdminRequests();
        return;
      }

      if(restoreReviewRow){
        const postId = restoreReviewRow.dataset.restoreReviewPostId;
        const approveRestore = e.target.closest('.approve-restore-btn');
        const rejectRestore = e.target.closest('.reject-restore-btn');
        if(!approveRestore && !rejectRestore) return;
        restoreReviewRow.querySelectorAll('button').forEach(btn => btn.disabled = true);
        try{
          if(approveRestore) await restorePostFromTrash(postId);
          else await rejectPostRestoreRequest(postId);
          await loadFirebasePosts();
          await loadAdminRequests();
        }catch(error){
          console.error("Could not update restore request:", error);
          restoreReviewRow.querySelectorAll('button').forEach(btn => btn.disabled = false);
          alert("Could not update restore request. Please check Firebase rules.");
        }
        return;
      }

      if(manageUserRow){
        const uid = manageUserRow.dataset.userUid;
        if(uid === currentUser.uid) return;
        const proToggle = e.target.closest('.user-pro-toggle');
        if(proToggle){
          proToggle.disabled = true;
          const targetUser = (await fb.get(fb.dbRef(db, `sermonUsers/${uid}`))).val() || {};
          const nextPro = targetUser.isPro !== true;
          await fb.update(fb.dbRef(db, `sermonUsers/${uid}`), {
            isPro:nextPro,
            proUpdatedAt:Date.now(),
            proUpdatedBy:currentUser.email,
            updatedAt:Date.now()
          });
          await loadAdminRequests();
          return;
        }
        const userToggle = e.target.closest('.user-admin-toggle');
        if(userToggle){
          const shouldOpen = !manageUserRow.classList.contains('actions-open');
          if(shouldOpen) openAdminUserActionUids.add(uid);
          else openAdminUserActionUids.delete(uid);
          manageUserRow.classList.toggle('actions-open', shouldOpen);
          return;
        }
        const deleteData = e.target.closest('.delete-user-data-btn');
        if(deleteData){
          deleteData.disabled = true;
          try{
            await permanentlyDeleteUserData(uid);
          }catch(error){
            console.error("Permanent user delete failed:", error);
            deleteData.disabled = false;
            alert("Could not permanently delete this user data. Please check Firebase rules and try again.");
          }
          return;
        }
        const blockBtn = e.target.closest('.block-user-btn');
        if(blockBtn){
          blockBtn.disabled = true;
          try{
            const [targetSnap, postsSnap] = await Promise.all([
              fb.get(fb.dbRef(db, `sermonUsers/${uid}`)),
              fb.get(fb.dbRef(db, 'sermonPosts'))
            ]);
            const targetUser = targetSnap.val() || {};
            const posts = postsSnap.val() || {};
            const nextBlocked = targetUser.blocked !== true;
            const now = Date.now();
            const updates = {};
            Object.entries(posts).forEach(([postId, post]) => {
              if(post?.authorUid === uid){
                updates[`sermonPosts/${postId}/blockedByAdmin`] = nextBlocked ? true : null;
                updates[`sermonPosts/${postId}/blockedUpdatedAt`] = now;
              }
            });
            Object.assign(updates, nextBlocked ? {
              [`sermonUsers/${uid}/blocked`]:true,
              [`sermonUsers/${uid}/blockedAt`]:now,
              [`sermonUsers/${uid}/blockedBy`]:currentUser.email,
              [`sermonUsers/${uid}/updatedAt`]:now
            } : {
              [`sermonUsers/${uid}/blocked`]:false,
              [`sermonUsers/${uid}/unblockedAt`]:now,
              [`sermonUsers/${uid}/unblockedBy`]:currentUser.email,
              [`sermonUsers/${uid}/updatedAt`]:now
            });
            await fb.update(fb.dbRef(db), updates);
            await loadAdminRequests();
          }catch(error){
            console.error("Block user failed:", error);
            blockBtn.disabled = false;
            alert("Could not update block status. Please check Firebase rules and try again.");
          }
          return;
        }
        const grant = e.target.closest('.grant-user-btn');
        const pending = e.target.closest('.pending-user-btn');
        const remove = e.target.closest('.remove-user-btn');
        if(!grant && !pending && !remove) return;

        const update = grant ? {
          role:"content_creator",
          status:"approved",
          approvedAt:Date.now(),
          approvedBy:currentUser.email,
          updatedAt:Date.now()
        } : pending ? {
          role:"viewer",
          status:"requested",
          requestedRole:"content_creator",
          requestedAt:Date.now(),
          updatedAt:Date.now()
        } : {
          role:"viewer",
          status:"rejected",
          rejectedAt:Date.now(),
          rejectedBy:currentUser.email,
          updatedAt:Date.now()
        };
        await fb.update(fb.dbRef(db, `sermonUsers/${uid}`), update);
        await loadAdminRequests();
        return;
      }

      if(postRow){
        const postId = postRow.dataset.pendingPostId;
        const approve = e.target.closest('.approve-post-btn');
        const reject = e.target.closest('.reject-post-btn');
        if(!approve && !reject) return;

        if(approve){
          await fb.update(fb.dbRef(db, `sermonPosts/${postId}`), {
            status:"published",
            approvedAt:Date.now(),
            approvedBy:currentUser.email,
            updatedAt:Date.now()
          });
          const approvedPost = firebasePosts.find(post => post.id === postId);
          if(approvedPost) await notifyFollowersOfPost(postId, {...approvedPost, status:"published"});
        }else{
          const confirmed = window.confirm("Reject and delete this pending post?");
          if(!confirmed) return;
          await fb.remove(fb.dbRef(db, `sermonPosts/${postId}`));
        }
        await loadFirebasePosts();
      }
    });

    let lastMediaTap = null;
    feed.addEventListener('pointerup', async e => {
      const media = e.target.closest('.media');
      const postEl = e.target.closest('.post');
      if(!media || !postEl || e.target.closest('button')) return;
      const now = Date.now();
      const last = lastMediaTap;
      const dx = last ? Math.abs(e.clientX - last.x) : Infinity;
      const dy = last ? Math.abs(e.clientY - last.y) : Infinity;
      const isDoubleTap = last && last.postId === postEl.dataset.postId && now - last.time < 340 && dx < 42 && dy < 42;
      lastMediaTap = {postId:postEl.dataset.postId, time:now, x:e.clientX, y:e.clientY};
      if(isDoubleTap){
        e.preventDefault();
        showTouchRipple(e.clientX, e.clientY, 4.2);
        showLikeBurst(media);
        await updatePostLike(postEl.dataset.postId, postEl, true);
      }
    });

    feed.addEventListener('click', async e => {
      const loadMoreBtn = e.target.closest('[data-load-more-posts]');
      if(loadMoreBtn){
        e.preventDefault();
        appendMoreFeedPosts();
        return;
      }
      const postEl = e.target.closest('.post');
      if(!postEl) return;
      if(!e.target.closest('[data-audio-tools]') && !e.target.closest('.time') && !e.target.closest('.track')){
        closeAudioToolboxes();
      }
      const id = postEl.dataset.postId;
      const post = firebasePosts.find(entry => entry.id === id);
      if(!currentUser && document.body.classList.contains('shared-preview')){
        const audioTarget = e.target.closest('.audio, [data-audio-tools], .speaker, .track');
        if(!audioTarget){
          await signInOrOut();
          return;
        }
      }
      const followIcon = e.target.closest('.profile-follow-icon');
      if(followIcon){
        await toggleFollow(followIcon.dataset.followUid);
        return;
      }

      const favoriteIcon = e.target.closest('[data-favorite-uid]');
      if(favoriteIcon){
        await toggleFavoriteUser(favoriteIcon.dataset.favoriteUid);
        return;
      }

      const profileTarget = e.target.closest('[data-profile-uid]');
      if(profileTarget && !e.target.closest('button')){
        openUserProfile(profileTarget.dataset.profileUid);
        return;
      }

      const mediaTap = e.target.closest('.media');
      if(mediaTap && !e.target.closest('button')){
        showMediaControls(mediaTap);
        return;
      }

      const seenBtn = e.target.closest('.seen-strip');
      if(seenBtn){
        openSeenBoard(seenBtn.dataset.seenPostId || id);
        return;
      }

      const exitFullscreenBtn = e.target.closest('.exit-fullscreen-btn');
      if(exitFullscreenBtn){
        if(exitAppMediaFullscreen()) return;
        if(document.fullscreenElement && document.exitFullscreen) await document.exitFullscreen().catch(()=>{});
        else if(document.webkitFullscreenElement && document.webkitExitFullscreen) document.webkitExitFullscreen();
        return;
      }

      const fullscreenBtn = e.target.closest('.fullscreen-post-btn');
      if(fullscreenBtn){
        const media = postEl.querySelector('.media');
        showMediaControls(media);
        if(isAndroidWebViewApp()){
          enterAppMediaFullscreen(media);
          return;
        }
        if(media?.requestFullscreen) await media.requestFullscreen().catch(()=>{});
        else if(media?.webkitRequestFullscreen) media.webkitRequestFullscreen();
        return;
      }

      const statusToggle = e.target.closest('[data-post-status-toggle]');
      if(statusToggle){
        if(!post || !isAdmin()) return;
        const nextStatus = post.status === "pending" ? "published" : "pending";
        statusToggle.disabled = true;
        statusToggle.classList.toggle('published', nextStatus === "published");
        try{
          await fb.update(fb.dbRef(db, `sermonPosts/${id}`), {
            status:nextStatus,
            approvedAt:nextStatus === "published" ? Date.now() : null,
            approvedBy:nextStatus === "published" ? currentUser.email : null,
            updatedAt:Date.now()
          });
          await loadFirebasePosts();
        }catch(error){
          statusToggle.disabled = false;
          statusToggle.classList.toggle('published', post.status !== "pending");
          alert("Could not update post approval status. Please check Firebase rules and try again.");
        }
        return;
      }

      const mediaProfileToggle = e.target.closest('[data-media-profile-toggle]');
      if(mediaProfileToggle){
        setCleanImageView(!cleanImageViewEnabled);
        showMediaControls(mediaProfileToggle.closest('.media'));
        return;
      }

      const menuToggle = e.target.closest('.owner-menu-toggle');
      if(menuToggle){
        const tools = menuToggle.parentElement?.querySelector('.owner-tools');
        const open = !tools?.classList.contains('open');
        document.querySelectorAll('.owner-tools.open').forEach(el => el.classList.remove('open'));
        document.querySelectorAll('.owner-menu-toggle.open').forEach(el => el.classList.remove('open'));
        if(tools && open){
          tools.classList.add('open');
          menuToggle.classList.add('open');
          showMediaControls(menuToggle.closest('.media'));
        }else{
          hideMediaControls(menuToggle.closest('.media'));
        }
        return;
      }

      const editBtn = e.target.closest('.edit-post-btn');
      if(editBtn){
        if(!post) return alert("Could not find this post. Please refresh and try again.");
        if(!currentUser || (currentUser.uid !== post.authorUid && !isAdmin())){
          return alert("You can only edit your own posts.");
        }
        editBtn.closest('.owner-tools')?.classList.remove('open');
        editBtn.closest('.media-tools')?.querySelector('.owner-menu-toggle')?.classList.remove('open');
        setComposerMode(post);
        return;
      }

      const deleteBtn = e.target.closest('.delete-post-btn');
      if(deleteBtn){
        if(!post) return alert("Could not find this post. Please refresh and try again.");
        if(!currentUser || (currentUser.uid !== post.authorUid && !isAdmin())){
          return alert("You can only delete your own posts.");
        }
        const confirmed = window.confirm("Move this sermon post to Recovery trash?");
        if(!confirmed) return;

        deleteBtn.disabled = true;
        try{
          await movePostToTrash(id);
          await loadFirebasePosts();
        }catch(error){
          deleteBtn.disabled = false;
          alert("Could not move this post to trash. Please check Firebase rules and try again.");
        }
        return;
      }

      const like = e.target.closest('.like-btn');
      if(like){
        await updatePostLike(id, postEl);
        return;
      }

      const share = e.target.closest('.share-btn');
      if(share){
        const shareData = createShareData(id);
        if(navigator.share) await navigator.share(shareData).catch(()=>{});
        else{
          await navigator.clipboard.writeText(shareData.url);
          alert("Share link copied.");
        }
        return;
      }

      const save = e.target.closest('.save-post-btn');
      if(save){
        await toggleSavePost(id);
        return;
      }
    });

    document.addEventListener('click', e => {
      if(appFullscreenMedia && e.target.closest('.exit-fullscreen-btn')){
        exitAppMediaFullscreen();
        return;
      }
      if(appFullscreenMedia && e.target === appFullscreenMedia){
        exitAppMediaFullscreen();
        return;
      }
      if(e.target.closest('.post') || e.target.closest('[data-audio-tools]') || e.target.closest('.time') || e.target.closest('.track')) return;
      closeAudioToolboxes();
    });

    renderImageLinkFields();
    renderAudioLinkFields();
    setDarkMode(darkModeEnabled);
    setCleanImageView(cleanImageViewEnabled);
    window.addEventListener('offline', () => updateConnectionState(false, true));
    window.addEventListener('online', () => updateConnectionState(true, true));
    document.addEventListener('keydown', event => {
      if(event.key === "Escape") exitAppMediaFullscreen();
    });
    updateConnectionState(navigator.onLine !== false, false);
    renderAuthGate("checking");
  </script>
</body>
</html>
