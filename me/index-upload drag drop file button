          applyBlockedUserUI();
          return;
        }
        document.body.classList.remove('blocked-user');
        setSharedPreviewMode(false);
        document.body.classList.remove('auth-locked');
        authGate.classList.add('hidden');
        authGate.classList.remove('checking', 'logged-in-preload');
        copy.textContent = "";
        return;
      }

      if(hasSharedPostLink() && firebasePosts.length){
        setSharedPreviewMode(true);
        copy.textContent = "";
        return;
      }

      setSharedPreviewMode(false);
      document.body.classList.remove('blocked-user');
      document.body.classList.add('auth-locked');
      authGate.classList.remove('hidden');
      authGate.classList.toggle('checking', checking);
      authGate.classList.remove('logged-in-preload');
