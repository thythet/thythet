      if(!isAdmin()) return [];
      const requestItems = adminPendingUsers.map(user => ({
        id:`admin_request_${user.uid}`,
        adminNotice:true,
        type:"admin_request",
        actorUid:user.uid,
        actorName:user.name || user.email || "Church Member",
        actorPhoto:user.photo || "",
        createdAt:user.requestedAt || user.updatedAt || Date.now(),
        read:false
      }));
      const postItems = adminPendingPosts.map(post => ({
        id:`admin_post_${post.id}`,
        adminNotice:true,
        type:"admin_pending_post",
        actorUid:post.authorUid || "",
        actorName:post.authorName || "Church Member",
        actorPhoto:post.authorPhoto || "",
        postId:post.id,
        createdAt:post.createdAt || post.updatedAt || Date.now(),
        read:false
      }));
