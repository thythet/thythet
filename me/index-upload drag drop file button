    function stopFeedLoadObserver(){
      if(feedLoadObserver){
        feedLoadObserver.disconnect();
        feedLoadObserver = null;
      }
    }

    function feedLoadSentinelHTML(){
      return `<div class="feed-load-sentinel" data-feed-load-sentinel>Loading more posts</div>`;
    }

    function setupRenderedPostFeatures(){
      setupLazyImages();
      setupSliders();
      setupCaptions();
      setupAudio();
      setupPostViews();
      refreshSavedFavoriteUI();
    }

    function setupFeedLoadObserver(){
      stopFeedLoadObserver();
      const sentinel = feed.querySelector('[data-feed-load-sentinel]');
      if(!sentinel || (feedRenderedCount >= feedRenderPosts.length && !firebaseHasOlderPosts)) return;
      if(!('IntersectionObserver' in window)){
        sentinel.innerHTML = `<button class="feed-search-follow" type="button" data-load-more-posts>Load more</button>`;
        return;
      }
      feedLoadObserver = new IntersectionObserver(entries => {
        if(entries.some(entry => entry.isIntersecting)) appendMoreFeedPosts();
      }, {rootMargin:"1200px 0px", threshold:0.01});
      feedLoadObserver.observe(sentinel);
    }

    async function appendMoreFeedPosts(){
      if(feedRenderPosts.length - feedRenderedCount <= FEED_BATCH_RENDER_COUNT && firebaseHasOlderPosts){
        await loadOlderFirebasePosts();
      }
      if(feedRenderedCount >= feedRenderPosts.length){
        if(!firebaseHasOlderPosts) feed.querySelector('[data-feed-load-sentinel]')?.remove();
        return;
      }
      const sentinel = feed.querySelector('[data-feed-load-sentinel]');
      if(sentinel) sentinel.remove();
      const start = feedRenderedCount;
      const end = Math.min(feedRenderPosts.length, start + FEED_BATCH_RENDER_COUNT);
      feed.insertAdjacentHTML('beforeend', feedRenderPosts.slice(start, end).map((post,index)=>postHTML(post,start + index)).join(""));
      feedRenderedCount = end;
      if(feedRenderedCount < feedRenderPosts.length || firebaseHasOlderPosts) feed.insertAdjacentHTML('beforeend', feedLoadSentinelHTML());
      setupRenderedPostFeatures();
      setupFeedLoadObserver();
    }

    function renderPosts(posts, initialCount=FEED_INITIAL_RENDER_COUNT){
      exitAppMediaFullscreen();
      stopFeedLoadObserver();
      feedRenderPosts = posts;
      feedRenderedCount = 0;
      if(!posts.length){
        feed.innerHTML = `<div class="empty">${canUpload() ? "No posts yet. Tap + to create the first sermon post." : "No sermon posts yet."}</div>`;
        return;
      }
      feedRenderedCount = Math.min(posts.length, Math.max(FEED_INITIAL_RENDER_COUNT, Number(initialCount) || 0));
      feed.innerHTML = posts.slice(0, feedRenderedCount).map((post,index)=>postHTML(post,index)).join("")
        + (feedRenderedCount < posts.length || firebaseHasOlderPosts ? feedLoadSentinelHTML() : "");
      setupRenderedPostFeatures();
      setupFeedLoadObserver();
    }

    function captureActiveAudioState(){
      const audio = [...document.querySelectorAll('[data-audio-ui] audio')]
        .find(player => !player.paused && !player.ended);
      if(!audio) return null;
      const postEl = audio.closest('.post');
      return {
        postId: postEl?.dataset.postId || "",
        src: audio.currentSrc || audio.src || "",
        time: Number.isFinite(audio.currentTime) ? audio.currentTime : 0,
        volume: audio.volume,
        muted: audio.muted
      };
    }

    function restoreActiveAudioState(state){
      if(!state?.postId) return;
      const postEl = [...document.querySelectorAll('.post')]
        .find(el => el.dataset.postId === state.postId);
      const audio = postEl?.querySelector('[data-audio-ui] audio');
      if(!audio) return;
      const currentSrc = audio.currentSrc || audio.src || "";
      if(state.src && currentSrc && currentSrc !== state.src) return;
      const syncPlayback = () => {
        try{
          audio.volume = state.volume;
          audio.muted = state.muted;
          if(Number.isFinite(state.time)) audio.currentTime = Math.min(state.time, audio.duration || state.time);
          audio.play().catch(() => {});
        }catch(error){
          console.warn("Could not restore audio playback:", error);
        }
      };
      if(audio.readyState >= 1) syncPlayback();
      else audio.addEventListener('loadedmetadata', syncPlayback, {once:true});
    }

    function renderPostsPreservingAudio(posts, initialCount=FEED_INITIAL_RENDER_COUNT){
      const activeAudio = captureActiveAudioState();
      renderPosts(posts, initialCount);
      if(activeAudio) setTimeout(() => restoreActiveAudioState(activeAudio), 0);
    }

    async function recordPostSeen(postId, postEl){
      if(!postId || !currentUser) return;
      if(postSeenUsers[postId]?.[currentUser.uid]) return;
      if(!clientActionAllowed(`seen:${currentUser.uid}`, 60, 60000)) return;
      const seenUser = currentSeenUser();
      postSeenUsers[postId] = {
        ...(postSeenUsers[postId] || {}),
        [currentUser.uid]:seenUser
      };
      updateSeenStack(postId, postEl);
      if(!USE_FIREBASE) return;
      try{
        await fb.set(fb.dbRef(db, `sermonPostSeen/${postId}/${currentUser.uid}`), seenUser);
      }catch(error){
        delete postSeenUsers[postId]?.[currentUser.uid];
        updateSeenStack(postId, postEl);
        console.warn("Could not update seen user:", error);
      }
    }

    async function registerPostView(postId, postEl){
      if(!postId) return;
      if(currentUser && !clientActionAllowed(`view:${currentUser.uid}`, 80, 60000)) return;
      await recordPostSeen(postId, postEl);
      const sessionKey = `sermonPostViewed:${postId}`;
      if(sessionStorage.getItem(sessionKey)) return;
      sessionStorage.setItem(sessionKey, "1");

      const post = firebasePosts.find(entry => entry.id === postId);
      if(post) post.views = Number(post.views || 0) + 1;

      if(!USE_FIREBASE) return;
      try{
        const countRef = fb.dbRef(db, `sermonPosts/${postId}/views`);
        await fb.runTransaction(countRef, count => Number(count || 0) + 1);
      }catch(error){
        sessionStorage.removeItem(sessionKey);
        if(viewBtn) viewBtn.textContent = currentCount;
        if(post) post.views = Math.max(0, Number(post.views || 0) - 1);
        console.warn("Could not update view count:", error);
      }
    }

    function setupPostViews(){
      if(activeViewObserver) activeViewObserver.disconnect();
      const posts = [...document.querySelectorAll('.post[data-post-id]')];
      if(!posts.length) return;

      if(!('IntersectionObserver' in window)){
        posts.forEach(postEl => registerPostView(postEl.dataset.postId, postEl));
        return;
      }

      activeViewObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if(!entry.isIntersecting || entry.intersectionRatio < 0.55) return;
          const postEl = entry.target;
          activeViewObserver.unobserve(postEl);
          registerPostView(postEl.dataset.postId, postEl);
        });
      }, {threshold:[0.55]});

      posts.forEach(postEl => activeViewObserver.observe(postEl));
    }

    function rememberImageLoaded(src){
      const key = String(src || "").trim();
      if(!key) return;
      loadedImageURLs.add(key);
      preloadedImageURLs.add(key);
    }

    function trimImagePreloadCache(){
      while(preloadedImageURLs.size > IMAGE_PRELOAD_CACHE_LIMIT){
        preloadedImageURLs.delete(preloadedImageURLs.values().next().value);
      }
    }

    function pumpImagePreloadQueue(){
      while(activeImagePreloads < IMAGE_PRELOAD_CONCURRENCY && queuedImageURLs.length){
        const src = queuedImageURLs.shift();
        if(!src || loadedImageURLs.has(src)) continue;
        activeImagePreloads++;
        const preloader = new Image();
        const finish = () => {
          activeImagePreloads = Math.max(0, activeImagePreloads - 1);
          rememberImageLoaded(src);
          trimImagePreloadCache();
          pumpImagePreloadQueue();
        };
        preloader.decoding = "async";
        preloader.onload = finish;
        preloader.onerror = finish;
        preloader.src = src;
      }
    }

    function preloadImageURL(src){
      const safeSrc = String(src || "").trim();
      if(!safeSrc || preloadedImageURLs.has(safeSrc) || queuedImageURLs.includes(safeSrc)) return;
      preloadedImageURLs.add(safeSrc);
      queuedImageURLs.push(safeSrc);
      trimImagePreloadCache();
      pumpImagePreloadQueue();
    }

    function markSlideImageLoaded(img){
      if(!img) return;
      const done = () => {
        img.classList.add('loaded');
        rememberImageLoaded(img.currentSrc || img.src || img.dataset.src);
      };
      if(img.complete && img.naturalWidth){
        done();
        return;
      }
      img.addEventListener('load', done, {once:true});
      img.addEventListener('error', () => img.classList.add('loaded'), {once:true});
    }

    function activateDeferredImage(img){
      if(!img?.dataset.src) return;
      img.src = img.dataset.src;
      img.removeAttribute('data-src');
      img.classList.remove('lazy-image');
      img.classList.add('loading-now');
      markSlideImageLoaded(img);
    }

    function preloadNearbySlideImages(slides, activeIndex=0){
      if(!slides) return;
      const images = [...slides.querySelectorAll('.slide img')];
      const start = Math.max(0, activeIndex - 1);
      const end = Math.min(images.length, activeIndex + IMAGE_PRELOAD_SLIDES_PER_POST);
      for(let index = start; index < end; index++){
        const img = images[index];
        if(index <= activeIndex + 1) activateDeferredImage(img);
        preloadImageURL(img?.dataset.src || img?.currentSrc || img?.src);
      }
    }

    function setupLazyImages(){
      document.querySelectorAll('.slide img[src]').forEach(markSlideImageLoaded);

      const imgs = [...document.querySelectorAll('img[data-src]')];
      const loadImage = img => {
        if(!img?.dataset.src) return;
        activateDeferredImage(img);
      };
      const loadMediaImages = media => {
        media?.querySelectorAll('img[data-src]').forEach(loadImage);
      };
      const warmFirstRenderedSlides = () => {
        [...document.querySelectorAll('.post')].slice(0, IMAGE_PRELOAD_AHEAD_POSTS).forEach(post => {
          const slideImages = [...post.querySelectorAll('.slide img')].slice(0, IMAGE_PRELOAD_SLIDES_PER_POST);
          slideImages.forEach((img, index) => {
            if(index === 0) loadImage(img);
            preloadImageURL(img.dataset.src || img.currentSrc || img.src);
          });
        });
      };

      warmFirstRenderedSlides();
      if(!imgs.length) return;
      const medias = [...document.querySelectorAll('.media')]
        .filter(media => media.querySelector('img[data-src]'));
      if(!('IntersectionObserver' in window)){
        medias.forEach(loadMediaImages);
        imgs.forEach(loadImage);
        return;
      }
      const mediaObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if(!entry.isIntersecting) return;
          loadMediaImages(entry.target);
          mediaObserver.unobserve(entry.target);
        });
      }, {rootMargin:"4200px 0px", threshold:0.01});
      medias.forEach(media => mediaObserver.observe(media));
    }

    function setupSliders(){
      document.querySelectorAll('.media').forEach(media => {
        const slides = media.querySelector('.slides');
        const dots = [...media.querySelectorAll('.dot')];
        const count = media.querySelector('.media-count');
        if(!slides) return;
        if(slides.dataset.sliderReady) return;
        slides.dataset.sliderReady = "true";
        preloadNearbySlideImages(slides, 0);
        let preloadTimer = null;

        slides.addEventListener('scroll', () => {
          const active = Math.round(slides.scrollLeft / slides.clientWidth);
          dots.forEach((dot,i)=>dot.classList.toggle('active', i === active));
          if(count) count.textContent = `${active + 1}/${Math.max(dots.length,1)}`;
          clearTimeout(preloadTimer);
          preloadTimer = setTimeout(() => preloadNearbySlideImages(slides, active), 80);
        }, {passive:true});
      });
    }

    function setupCaptions(){
      const lessIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" /></svg>`;
      document.querySelectorAll('.post-content').forEach(content => {
        if(content.dataset.captionReady) return;
        content.dataset.captionReady = "true";
        const line = content.querySelector('.caption-line');
        const text = content.querySelector('.caption-text');
        const btn = content.querySelector('.more-link');
        if(!text || !btn) return;

        requestAnimationFrame(() => {
          const needsMore = text.scrollWidth > text.clientWidth + 2;
          line.classList.toggle('needs-more', needsMore);
          if(!needsMore){
            btn.innerHTML = lessIcon;
            btn.setAttribute("aria-label", "Show post date");
          }else{
            btn.innerHTML = "more";
            btn.setAttribute("aria-label", "Show full caption");
          }
          content?.classList.toggle('caption-below', line.classList.contains('expanded'));
          content?.classList.toggle('caption-expanded', line.classList.contains('expanded'));
        });

        btn.addEventListener('click', () => {
          const expanded = line.classList.toggle('expanded');
          const needsMore = line.classList.contains('needs-more');
          btn.innerHTML = expanded && needsMore ? "less" : (needsMore ? "more" : lessIcon);
          btn.setAttribute("aria-label", expanded ? "Hide post date" : (needsMore ? "Show full caption" : "Show post date"));
          content?.classList.toggle('caption-below', expanded);
          content?.classList.toggle('caption-expanded', expanded);
        });
      });
    }

    function setupAudio(){
      document.querySelectorAll('.audio-scroll').forEach(scroller => {
        if(scroller.dataset.audioScrollReady) return;
        scroller.dataset.audioScrollReady = "true";
        const postEl = scroller.closest('.post');
        const dots = [...(postEl?.querySelectorAll('[data-audio-dot-index]') || [])];
        if(!dots.length) return;
        const setActiveDot = index => {
          dots.forEach(dot => dot.classList.toggle('active', Number(dot.dataset.audioDotIndex || 0) === index));
          if(postEl) postEl.dataset.activeAudioIndex = String(index);
        };
        scroller.addEventListener('scroll', () => {
          const width = scroller.clientWidth || 1;
          setActiveDot(Math.max(0, Math.min(dots.length - 1, Math.round(scroller.scrollLeft / width))));
        }, {passive:true});
        dots.forEach(dot => {
          dot.addEventListener('click', e => {
            e.preventDefault();
            e.stopPropagation();
            const index = Number(dot.dataset.audioDotIndex || 0);
            const target = scroller.querySelector(`[data-audio-ui][data-audio-index="${index}"]`);
            target?.scrollIntoView({behavior:"smooth", block:"nearest", inline:"start"});
            setActiveDot(index);
          });
        });
      });

      document.querySelectorAll('[data-audio-ui]').forEach(ui => {
        if(ui.dataset.audioReady) return;
        ui.dataset.audioReady = "true";
        const btn = ui.querySelector('.speaker');
        const audio = ui.querySelector('audio');
        const current = ui.querySelector('.current');
        const duration = ui.querySelector('.duration');
        const progress = ui.querySelector('.progress');
        const track = ui.querySelector('.track');
        const postEl = ui.closest('.post');
        const tools = postEl?.querySelector('[data-audio-tools]');
        const audioIndex = ui.dataset.audioIndex || "0";

        if(!audio){
          btn.addEventListener('click',()=>alert('No audio added yet.'));
          return;
        }

        const syncSpeakerIcon = () => {
          btn.innerHTML = audio.paused ? icons.speakerStopped : icons.speakerPlaying;
          const stoppedIcon = btn.querySelector('[data-speaker-stopped-icon]');
          wireAudioIconFallback(stoppedIcon);
          btn.setAttribute("aria-label", audio.paused ? "Play" : "Pause");
        };
        const syncToolStates = () => {
          if(postEl?.dataset.activeAudioIndex !== audioIndex) return;
          const toggle = tools?.querySelector('[data-audio-action="toggleplay"]');
          if(toggle) toggle.innerHTML = audio.paused ? icons.play : icons.pause;
          tools?.querySelector('[data-audio-action="mute"]')?.classList.toggle('active', audio.muted);
          const loopTool = tools?.querySelector('[data-audio-action="loop"]');
          const repeatMode = postEl?.dataset.repeatMode || "off";
          loopTool?.classList.toggle('active', repeatMode !== "off");
          loopTool?.classList.toggle('repeat-once', repeatMode === "once");
          loopTool?.classList.toggle('repeat-all', repeatMode === "all");
          loopTool?.setAttribute("title", repeatMode === "once" ? "Repeat once" : (repeatMode === "all" ? "Repeat all" : "Repeat off"));
          loopTool?.setAttribute("aria-label", loopTool?.title || "Repeat off");
        };
        syncSpeakerIcon();
        syncToolStates();

        const requireAudioLogin = () => {
          if(currentUser) return false;
          if(ui.dataset.audioPublic === "true") return false;
          alert("Please log in to listen audio.");
          signInOrOut();
          return true;
        };

        audio.addEventListener('loadedmetadata',()=>{
          duration.textContent = formatTime(audio.duration);
        });
        audio.addEventListener('play', () => {
          postEl.dataset.activeAudioIndex = audioIndex;
        });
        audio.addEventListener('play', syncSpeakerIcon);
        audio.addEventListener('pause', syncSpeakerIcon);
        audio.addEventListener('ended', syncSpeakerIcon);
        audio.addEventListener('play', syncToolStates);
        audio.addEventListener('pause', syncToolStates);
        audio.addEventListener('ended', syncToolStates);
        audio.addEventListener('play', updateFeedNowPlaying);
        audio.addEventListener('pause', updateFeedNowPlaying);
        audio.addEventListener('ended', updateFeedNowPlaying);
        audio.addEventListener('ended', () => {
          const repeatMode = postEl?.dataset.repeatMode || "off";
          const rows = [...(postEl?.querySelectorAll('[data-audio-ui]') || [])];
          const index = rows.indexOf(ui);
          if(repeatMode === "once"){
            audio.currentTime = 0;
            audio.play().catch(()=>{});
            return;
          }
          const nextRow = rows[index + 1] || (repeatMode === "all" ? rows[0] : null);
          if(!nextRow || nextRow === ui) return;
          const nextAudio = nextRow.querySelector('audio');
          const nextIndex = nextRow.dataset.audioIndex || "0";
          postEl.dataset.activeAudioIndex = nextIndex;
          nextRow.scrollIntoView({behavior:"smooth", block:"nearest", inline:"start"});
          postEl.querySelectorAll('[data-audio-dot-index]').forEach(dot => {
            dot.classList.toggle('active', Number(dot.dataset.audioDotIndex || 0) === Number(nextIndex));
          });
          nextAudio?.play().catch(()=>{});
        });
        audio.addEventListener('volumechange', syncToolStates);

        audio.addEventListener('timeupdate',()=>{
          current.textContent = formatTime(audio.currentTime);
          const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
          progress.style.width = pct + "%";
        });

        btn.addEventListener('click', async ()=>{
          if(requireAudioLogin()) return;
          document.querySelectorAll('audio').forEach(a => { if(a !== audio) a.pause(); });
          if(audio.paused) await audio.play();
          else audio.pause();
        });

        track.addEventListener('click', e => {
          if(requireAudioLogin()) return;
          const rect = track.getBoundingClientRect();
          const pct = (e.clientX - rect.left) / rect.width;
          audio.currentTime = pct * audio.duration;
        });

        const openTools = () => {
          document.querySelectorAll('.post.audio-tools-open').forEach(post => {
            if(post !== postEl) post.classList.remove('audio-tools-open');
          });
          postEl.dataset.activeAudioIndex = audioIndex;
          postEl?.classList.add('audio-tools-open');
          syncToolStates();
        };
        const toggleTools = e => {
          e.preventDefault();
          e.stopPropagation();
          if(postEl?.classList.contains('audio-tools-open') && postEl.dataset.activeAudioIndex === audioIndex) postEl.classList.remove('audio-tools-open');
          else openTools();
        };
        [current, duration].forEach(label => {
          label.addEventListener('click', toggleTools);
        });
        track.addEventListener('mouseenter', openTools);
        track.addEventListener('touchstart', openTools, {passive:true});

        if(tools && !tools.dataset.audioToolsBound){
          tools.dataset.audioToolsBound = "true";
          tools.addEventListener('click', e => {
          const tool = e.target.closest('[data-audio-action]');
          if(!tool) return;
          e.stopPropagation();
          const activeIndex = postEl?.dataset.activeAudioIndex || "0";
          const activeUi = postEl?.querySelector(`[data-audio-ui][data-audio-index="${activeIndex}"]`) || postEl?.querySelector('[data-audio-ui]');
          const activeAudio = activeUi?.querySelector('audio');
          const activeCurrent = activeUi?.querySelector('.current');
          const activeProgress = activeUi?.querySelector('.progress');
          if(!activeAudio) return;
          if(!currentUser && activeUi.dataset.audioPublic !== "true"){
            alert("Please log in to listen audio.");
            signInOrOut();
            return;
          }
          const action = tool.dataset.audioAction;
          if(action === "toggleplay"){
            if(activeAudio.paused){
              document.querySelectorAll('audio').forEach(a => { if(a !== activeAudio) a.pause(); });
              activeAudio.play().catch(()=>{});
            }else{
              activeAudio.pause();
            }
          }
          if(action === "stop"){
            activeAudio.pause();
            activeAudio.currentTime = 0;
            if(activeProgress) activeProgress.style.width = "0%";
            if(activeCurrent) activeCurrent.textContent = "00:00";
          }
          if(action === "mute") activeAudio.muted = !activeAudio.muted;
          if(action === "loop"){
            const currentMode = postEl?.dataset.repeatMode || "off";
            postEl.dataset.repeatMode = currentMode === "off" ? "once" : (currentMode === "once" ? "all" : "off");
            activeAudio.loop = false;
          }
          if(action === "back10") activeAudio.currentTime = Math.max(0, activeAudio.currentTime - 10);
          if(action === "forward10") activeAudio.currentTime = Math.min(activeAudio.duration || activeAudio.currentTime + 10, activeAudio.currentTime + 10);
          const activeIdx = activeUi?.dataset.audioIndex || "0";
          postEl.dataset.activeAudioIndex = activeIdx;
          activeAudio.dispatchEvent(new Event('volumechange'));
        });
        }
      });
    }

