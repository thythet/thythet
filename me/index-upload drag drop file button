    async function updatePostLike(postId, postEl, forceLike=false){
      if(!currentUser) return renderAuthGate();
      if(!clientActionAllowed(`like:${currentUser.uid}:${postId}`, 10, 60000)) return;
      const like = postEl?.querySelector('.like-btn');
      const span = like?.querySelector('span');
      const post = firebasePosts.find(entry => entry.id === postId);
      const wasLiked = userLikedPostIds.has(postId);
      const shouldLike = forceLike ? true : !wasLiked;
      if(shouldLike === wasLiked) return;

      like?.classList.toggle('liked', shouldLike);
      if(span) span.textContent = Math.max(0, Number(span.textContent) + (shouldLike ? 1 : -1));
      const likeRef = fb.dbRef(db, `sermonPostLikes/${postId}/${currentUser.uid}`);
      const countRef = fb.dbRef(db, `sermonPosts/${postId}/likes`);
      try{
        if(shouldLike){
          await fb.set(likeRef, {
            email:currentUser.email || "",
            name:currentUser.displayName || "",
            at:Date.now()
          });
          await fb.runTransaction(countRef, count => Number(count || 0) + 1);
          if(post?.authorUid && post.authorUid !== currentUser.uid){
            await removeLikeNotifications(post.authorUid, currentUser.uid, postId);
            await fb.set(fb.dbRef(db, `sermonNotifications/${post.authorUid}/${likeNotificationId(postId, currentUser.uid)}`), {
              type:"like",
              postId,
              postCaption:postTextPreview(post).slice(0, 80),
              ...actorPayload(),
              createdAt:Date.now(),
              read:false
            }).catch(error => {
              console.warn("Could not send like notification:", error);
            });
          }
          userLikedPostIds.add(postId);
        }else{
          await fb.remove(likeRef);
          await fb.runTransaction(countRef, count => Math.max(0, Number(count || 0) - 1));
          if(post?.authorUid && post.authorUid !== currentUser.uid){
            await removeLikeNotifications(post.authorUid, currentUser.uid, postId);
          }
          userLikedPostIds.delete(postId);
        }
      }catch(error){
        like?.classList.toggle('liked', wasLiked);
        if(span) span.textContent = Math.max(0, Number(span.textContent) + (shouldLike ? -1 : 1));
        alert("Could not update like. Please try again.");
      }
    }

