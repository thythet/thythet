    function appConfirm(message){
      const board = document.getElementById('appConfirmBoard');
      const messageNode = document.getElementById('appConfirmMessage');
      if(!board || !messageNode) return Promise.resolve(window.confirm(message));
      messageNode.textContent = message;
      board.classList.add('open');
      board.setAttribute('aria-hidden', 'false');
      return new Promise(resolve => {
        const okBtn = board.querySelector('[data-confirm-ok]');
        const cancelBtn = board.querySelector('[data-confirm-cancel]');
        const cleanup = result => {
          board.classList.remove('open');
          board.setAttribute('aria-hidden', 'true');
          okBtn?.removeEventListener('click', okHandler);
          cancelBtn?.removeEventListener('click', cancelHandler);
          board.removeEventListener('click', boardHandler);
          document.removeEventListener('keydown', keyHandler);
          resolve(result);
        };
        const okHandler = () => cleanup(true);
        const cancelHandler = () => cleanup(false);
        const boardHandler = event => {
          if(event.target === board) cleanup(false);
        };
        const keyHandler = event => {
          if(event.key === "Escape") cleanup(false);
        };
        okBtn?.addEventListener('click', okHandler);
        cancelBtn?.addEventListener('click', cancelHandler);
        board.addEventListener('click', boardHandler);
        document.addEventListener('keydown', keyHandler);
      });
    }

