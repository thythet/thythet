      document.querySelectorAll(`[data-profile-uid="${uid}"] .email`).forEach(el => {
        el.innerHTML = followerStatusHTML(uid);
      });
      document.querySelectorAll(`[data-user-uid="${uid}"] .request-subline`).forEach(el => {
        el.innerHTML = followerStatusHTML(uid);
      });
      if(currentUser && uid === currentUser.uid) updateAuthUI();
      refreshSeenBoardIfOpen();
      if(userProfileBoard.classList.contains('open') && userProfileBoard.dataset.profileUid === uid){
        openUserProfile(uid);
      }
      if(profileBoard.classList.contains('open')) renderProfileBoard();
      if(isAdmin()) scheduleAdminRealtimeRefresh();
