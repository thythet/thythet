      return !!uid && onlineUsers[uid]?.online === true;
    }

    function onlineDotHTML(uid=""){
      return isUserOnline(uid) ? `<span class="online-dot-wrap" title="Online" aria-label="Online"><span class="online-dot"></span></span>` : "";
    }

    function followerStatusHTML(uid=""){
      return `${escapeHTML(followerLabel(uid))}${onlineDotHTML(uid)}`;
    }

    function followerStatusText(uid=""){
      return followerLabel(uid) + (isUserOnline(uid) ? " · Online" : "");
    }

    function followingLabel(count=0){
      return compactNumber(count) + " following";
    }

    function profileActiveStatusHTML(uid=""){
      const presence = onlineUsers[uid] || {};
      if(presence.online === true){
        return `<span class="profile-active-pill"><span class="online-dot-wrap" aria-hidden="true"><span class="online-dot"></span></span><span>Active now</span></span>`;
      }
      const lastChanged = Number(presence.lastChanged || 0);
      if(!lastChanged) return "";
      return `<span class="profile-active-pill">&middot; ${escapeHTML(activeAgoText(lastChanged))}</span>`;
    }

    function activeAgoText(ms){
      const diff = Math.max(1, Date.now() - Number(ms || Date.now()));
      const minutes = Math.floor(diff / 60000);
      if(minutes < 1) return "just now";
      if(minutes < 60) return `${minutes} min ago`;
      const hours = Math.floor(minutes / 60);
      if(hours < 24) return `${hours} hr ago`;
      const days = Math.floor(hours / 24);
      return `${days} day${days === 1 ? "" : "s"} ago`;
    }

    function adminPresenceStatusHTML(uid=""){
      const presence = onlineUsers[uid] || {};
      if(presence.online === true){
        return `<span class="admin-online-status online">Online · Active now</span>`;
      }
      const lastChanged = Number(presence.lastChanged || 0);
      return `<span class="admin-online-status">Offline${lastChanged ? ` · ${escapeHTML(activeAgoText(lastChanged))}` : ""}</span>`;
    }

    function timeAgo(ms){
      const diff = Math.max(1, Date.now() - Number(ms || Date.now()));
      const m = Math.floor(diff/60000);
      const h = Math.floor(m/60);
      const d = Math.floor(h/24);
      if(d) return d + "d ago";
      if(h) return h + "h ago";
      if(m) return m + "m ago";
      return "just now";
    }

    function postDateKey(ms){
      const date = new Date(Number(ms || Date.now()));
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}${month}${day}`;
    }

    function postPublishDateText(ms){
      const date = new Date(Number(ms || Date.now()));
      return date.toLocaleDateString(undefined, {year:"numeric", month:"short", day:"numeric"});
    }

    function postTextPreview(post={}){
      return [post.title, post.caption]
        .map(value => String(value || "").replace(/\s+/g, " ").trim())
        .filter(Boolean)
        .join(" | ");
    }

    function computedPostShareToken(post, posts=firebasePosts){
      if(!post) return "";
      const dateKey = postDateKey(post.createdAt);
      const sameDay = (posts || [])
        .filter(item => item && postDateKey(item.createdAt) === dateKey)
        .sort((a,b) => (Number(a.createdAt || 0) - Number(b.createdAt || 0)) || String(a.id || "").localeCompare(String(b.id || "")));
      const index = Math.max(0, sameDay.findIndex(item => item.id === post.id)) + 1;
      return `${dateKey}-${String(index || 1).padStart(2, "0")}`;
    }

    function postShareToken(post, posts=firebasePosts){
      return post?.shareToken ? String(post.shareToken) : computedPostShareToken(post, posts);
    }

    function postByShareToken(token){
      const clean = String(token || "").trim();
      if(!clean) return null;
      return firebasePosts.find(post => String(post.shareToken || "") === clean)
        || firebasePosts.find(post => computedPostShareToken(post) === clean)
        || null;
    }

    function sharedLinkParams(){
      return new URLSearchParams(location.search);
    }

    function hasSharedPostLink(){
      const params = sharedLinkParams();
      return !!(params.get("Post") || params.get("t") || params.get("post"));
    }

    function linkedPostFromPosts(posts=firebasePosts){
      const params = sharedLinkParams();
      return (posts || []).find(post => post.id === params.get("post"))
        || postByShareToken(params.get("Post"))
        || postByShareToken(params.get("t"));
    }

    function setSharedPreviewMode(active=false){
      document.body.classList.toggle('shared-preview', !!active);
      if(active){
        document.body.classList.remove('auth-locked');
        authGate.classList.add('hidden');
        authGate.classList.remove('checking', 'logged-in-preload');
      }
    }

    function setSharedMoreButton(show=false){
      const wrap = document.getElementById('sharedMoreWrap');
      if(wrap) wrap.style.display = show ? "flex" : "none";
    }

    async function exitSharedPostView(){
      const cleanUrl = `${location.origin}${location.pathname}`;
      history.replaceState(null, "", cleanUrl);
      setSharedMoreButton(false);
      setSharedPreviewMode(false);
      await loadFirebasePosts();
      window.scrollTo({top:0, behavior:"smooth"});
    }

    function avatarFallback(){
      return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>`;
    }

    function seenUsersForPost(postId){
      return Object.values(postSeenUsers[postId] || {})
        .filter(Boolean)
        .sort((a,b)=>(b.at || 0) - (a.at || 0));
    }

    function seenUserCount(postId){
      return seenUsersForPost(postId).length;
    }

    function renderSeenStack(postId){
      const users = seenUsersForPost(postId);
      if(!users.length) return "";
      const visible = users.slice(0, 5);
      const extra = Math.max(0, users.length - visible.length);
      return `
        <button class="seen-strip" type="button" data-seen-post-id="${escapeHTML(postId)}" aria-label="View seen users">
          ${visible.map(user => `
            <span class="seen-avatar" title="${escapeHTML(user.name || "Seen user")}">
              ${safeImageTag(user.photo) || avatarFallback()}
            </span>
          `).join("")}
          ${extra ? `<span class="seen-more">+${extra}</span>` : ""}
