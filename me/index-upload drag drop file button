    function cssEscape(value){
      return window.CSS?.escape ? CSS.escape(String(value || "")) : String(value || "").replace(/"/g, '\\"');
    }

    function postRenderSignature(post){
      if(!post) return "";
      const {likes, shares, views, ...renderFields} = post;
      return JSON.stringify(renderFields);
    }

    function postsCanPatchCountersOnly(previousPosts, nextPosts){
      if(previousPosts.length !== nextPosts.length) return false;
      return nextPosts.every((post, index) => {
        const previous = previousPosts[index];
        return previous?.id === post.id && postRenderSignature(previous) === postRenderSignature(post);
      });
    }

    function updatePostCounterUI(posts){
      posts.forEach(post => {
        const postEl = document.querySelector(`.post[data-post-id="${cssEscape(post.id)}"]`);
        if(!postEl) return;
        const likeCount = postEl.querySelector('.like-btn span');
        const shareCount = postEl.querySelector('.share-btn span');
        const viewCount = postEl.querySelector('.view-btn span');
        if(likeCount) likeCount.textContent = Number(post.likes || 0);
        if(shareCount) shareCount.textContent = shareCountForPost(post);
        if(viewCount) viewCount.textContent = seenUserCount(post.id);
      });
      if(profileBoard.classList.contains('open')) renderProfileBoard();
    }

    function postListFromSnapshotValue(value){
      return Object.entries(value || {})
        .filter(([id,p]) => id !== APP_SETTINGS_POST_KEY && p?.type !== "appSettings")
        .map(([id,p]) => ({id,...p}))
        .sort((a,b)=>(b.createdAt||0)-(a.createdAt||0));
    }

    function limitedPostsQuery(limit=FIREBASE_POST_PAGE_SIZE, beforeCreatedAt=null){
      const postsRef = fb.dbRef(db, 'sermonPosts');
      if(!fb.query || !fb.orderByChild || !fb.limitToLast) return postsRef;
      const constraints = [fb.orderByChild('createdAt')];
      if(beforeCreatedAt !== null && beforeCreatedAt !== undefined && fb.endBefore){
        constraints.push(fb.endBefore(Number(beforeCreatedAt) || 0));
      }
      constraints.push(fb.limitToLast(limit));
      return fb.query(postsRef, ...constraints);
    }

    function mergeFirebasePosts(nextPosts=[]){
      const merged = new Map(firebasePosts.map(post => [post.id, post]));
      nextPosts.forEach(post => {
        if(post?.id) merged.set(post.id, post);
      });
      firebasePosts = [...merged.values()].sort((a,b)=>(b.createdAt||0)-(a.createdAt||0));
      const oldest = firebasePosts[firebasePosts.length - 1];
      firebaseOldestPostCreatedAt = oldest ? Number(oldest.createdAt || 0) : null;
    }

    async function loadOlderFirebasePosts(){
      if(!USE_FIREBASE || firebaseLoadingOlderPosts || !firebaseHasOlderPosts || firebaseOldestPostCreatedAt === null) return;
      firebaseLoadingOlderPosts = true;
      try{
        const snap = await fb.get(limitedPostsQuery(FIREBASE_POST_PAGE_SIZE, firebaseOldestPostCreatedAt));
        const olderPosts = postListFromSnapshotValue(snap.val() || {});
        firebaseHasOlderPosts = olderPosts.length >= FIREBASE_POST_PAGE_SIZE;
        mergeFirebasePosts(olderPosts);
        feedRenderPosts = visiblePosts();
      }catch(error){
        console.warn("Could not load older posts:", error);
      }finally{
        firebaseLoadingOlderPosts = false;
      }
    }

    function applyPostsSnapshot(value){
      const previousVisiblePosts = visiblePosts();
      if(value && Object.prototype.hasOwnProperty.call(value, APP_SETTINGS_POST_KEY)){
        applyAppSettings(value[APP_SETTINGS_POST_KEY] || {});
      }
      const nextPosts = postListFromSnapshotValue(value);
      cleanupInvalidPostsForAdmin(nextPosts);
      firebaseHasOlderPosts = nextPosts.length >= FIREBASE_POST_PAGE_SIZE;
      const nextVisiblePosts = visiblePostsFrom(nextPosts);
      const canPatchCounters = postsCanPatchCountersOnly(previousVisiblePosts, nextVisiblePosts)
        && document.querySelectorAll('.post[data-post-id]').length > 0;

      firebasePosts = nextPosts;
      const oldest = firebasePosts[firebasePosts.length - 1];
      firebaseOldestPostCreatedAt = oldest ? Number(oldest.createdAt || 0) : null;
      if(canPatchCounters){
        updatePostCounterUI(nextVisiblePosts);
        updatePostMetaUI();
        return;
      }

      renderPostsPreservingAudio(nextVisiblePosts);
    }

