    function cloudinaryDisplayImageUrl(url){
      const clean = String(url || "").trim();
      if(!clean || !/res\.cloudinary\.com\/[^/]+\/image\/upload\//i.test(clean)) return clean;
      if(/\/image\/upload\/[^/]*\b(f_auto|c_|w_|h_|q_)/i.test(clean)) return clean;
      return clean.replace("/image/upload/", "/image/upload/f_auto,q_auto/");
    }

    async function convertImageToWebp(file, options={}){
      if(!file || file.type === "image/webp" || file.type === "image/gif") return file;
      let bitmap = null;
      try{
        bitmap = await createImageBitmap(file);
      }catch(error){
        console.warn("Browser could not decode image for WebP conversion; uploading original file.", error);
        return file;
      }
      const canvas = document.createElement("canvas");
      canvas.width = bitmap.width;
      canvas.height = bitmap.height;
      const ctx = canvas.getContext("2d");
      ctx.drawImage(bitmap, 0, 0);
      bitmap.close?.();
      const qualitySteps = options.hd ? [.92, .88, .84, .80, .76, .72] : [.82];
      let blob = null;
      for(const quality of qualitySteps){
        const nextBlob = await new Promise(resolve => canvas.toBlob(resolve, "image/webp", quality));
        if(!nextBlob) continue;
        blob = nextBlob;
        if(!options.hd || !file.size || nextBlob.size <= file.size) break;
      }
      if(!blob) return file;
      const baseName = String(file.name || "image").replace(/\.[^.]+$/, "");
      return new File([blob], `${baseName}.webp`, {
        type:"image/webp",
        lastModified:Date.now()
      });
    }

