    function updateSeenStack(postId, postEl){
      const target = postEl?.querySelector('.seen-slot');
      if(target) target.innerHTML = renderSeenStack(postId);
      const viewCount = postEl?.querySelector('.view-btn span');
      if(viewCount) viewCount.textContent = seenUserCount(postId);
