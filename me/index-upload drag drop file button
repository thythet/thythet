    function activityLogItems(){
      const items = [];
      Object.values(userDirectory || {}).forEach(user => {
        if(!user?.uid || !user?.createdAt) return;
        items.push({
          type:"user",
          at:Number(user.createdAt || 0),
          title:`New user: ${user.name || "Church Member"}`,
          meta:user.email || user.role || "Signed in",
          thumb:safeImageTag(user.photo) || avatarFallback(),
          uid:user.uid
        });
      });
      firebasePosts.forEach(post => {
        if(!isValidPost(post)) return;
        if(isDeletedPost(post)){
          items.push({
            type:"trash",
            at:Number(post.deletedAt || post.createdAt || 0),
            title:`Moved to trash: ${activityPostTitle(post)}`,
            meta:`${post.deletedByName || post.deletedBy || "Admin"} - ${post.authorName || "Church Member"}`,
            thumb:postThumbHTML(post),
            postId:post.id
          });
          return;
        }
        items.push({
          type:"post",
          at:Number(post.createdAt || 0),
          title:`Post: ${activityPostTitle(post)}`,
          meta:`${post.authorName || "Church Member"} - ${audienceLabel(post.audience)}`,
          thumb:postThumbHTML(post),
          postId:post.id
        });
      });
      Object.entries(allFollows || {}).forEach(([targetUid, followers]) => {
        Object.entries(followers || {}).forEach(([followerUid, actor]) => {
          items.push({
            type:"follow",
            at:Number(actor?.at || actor?.createdAt || 0),
            title:`Follow: ${actor?.name || "Church Member"}`,
            meta:`Followed ${userSummary(targetUid)?.name || "Church Member"}`,
            thumb:safeImageTag(actor?.photo) || avatarFallback(),
            uid:followerUid
          });
        });
      });
      const seenKeys = new Set();
      return items
        .filter(item => item.at && item.at > Number(appSettings.activityLogClearedAt || 0))
        .sort((a,b)=>b.at - a.at)
        .filter(item => {
          const key = `${item.type}:${item.postId || item.uid || ""}:${item.at}`;
          if(seenKeys.has(key)) return false;
          seenKeys.add(key);
          return true;
        })
        .slice(0, 60);
    }

