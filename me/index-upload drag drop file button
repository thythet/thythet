    function userSummary(uid){
      if(!uid) return null;
      const fallbackName = "Church Member";
      const cleanUserName = value => String(value || "").trim();
      const isRealUserRecord = user => {
        const name = cleanUserName(user?.name);
        return !!(user?.photo || (name && name.toLowerCase() !== fallbackName.toLowerCase()));
      };
      if(currentUser && uid === currentUser.uid){
        return {
          uid,
          name:currentUser.displayName || currentProfile?.name || fallbackName,
          photo:currentUser.photoURL || currentProfile?.photo || ""
        };
      }
      const directoryUser = userDirectory?.[uid];
      if(directoryUser) return {uid, name:directoryUser.name || fallbackName, photo:directoryUser.photo || "", role:directoryUser.role || "viewer"};
      const post = firebasePosts.find(item => item.authorUid === uid);
      if(post) return {uid, name:post.authorName || fallbackName, photo:post.authorPhoto || ""};
      const presence = onlineUsers?.[uid];
      if(presence && isRealUserRecord(presence)) return {uid, name:presence.name || fallbackName, photo:presence.photo || ""};
      const seenUser = Object.values(postSeenUsers || {})
        .flatMap(group => Object.values(group || {}))
        .find(user => user && user.uid === uid);
      if(seenUser && isRealUserRecord(seenUser)) return {uid, name:seenUser.name || fallbackName, photo:seenUser.photo || ""};
      const notice = Object.values(userNotifications || {}).find(item => item && item.actorUid === uid);
      if(notice && isRealUserRecord({name:notice.actorName, photo:notice.actorPhoto})) return {uid, name:notice.actorName || fallbackName, photo:notice.actorPhoto || ""};
      return {uid, name:fallbackName, photo:"", missing:true};
    }

    function onlineUsersHTML(){
      const canSeeAllOnlineUsers = isAdmin();
      const users = Object.entries(onlineUsers || {})
        .filter(([uid, presence]) => uid && presence?.online === true)
        .filter(([uid]) => canSeeAllOnlineUsers || !!currentFollowing[uid])
        .map(([uid, presence]) => {
          const summary = userSummary(uid) || {};
          return {
            uid,
            name:presence.name || summary.name || "Church Member",
            photo:presence.photo || summary.photo || ""
          };
        })
        .sort((a,b) => {
          if(a.uid === currentUser?.uid) return -1;
          if(b.uid === currentUser?.uid) return 1;
          return a.name.localeCompare(b.name);
        });
      const emptyText = canSeeAllOnlineUsers ? "No one is online now." : "No followed users online now.";
      if(!users.length) return `<div class="section-copy">${emptyText}</div>`;
      const visibleUsers = showAllOnlineUsers ? users : users.slice(0, 10);
      const hiddenCount = users.length - visibleUsers.length;
      const usersHTML = visibleUsers.map(user => `
        <button class="online-user-pill" type="button" data-profile-open="${escapeHTML(user.uid)}" title="${escapeHTML(user.name)}">
          ${safeImageTag(user.photo) || `<span class="online-user-avatar">${avatarFallback()}</span>`}
          <span class="online-dot-wrap" aria-hidden="true"><span class="online-dot"></span></span>
          <span class="online-user-name">${escapeHTML(user.name)}${user.uid === currentUser?.uid ? " (You)" : ""}</span>
        </button>
      `).join("");
      const moreHTML = hiddenCount > 0
        ? `<button class="online-user-pill more" type="button" data-online-more title="Show ${hiddenCount} more online user${hiddenCount === 1 ? "" : "s"}">+${hiddenCount}</button>`
        : "";
      return usersHTML + moreHTML;
    }

    function postsByUser(uid){
