    function renderFeedSearchResults(query=""){
      const clean = String(query || "").trim().toLowerCase();
      document.querySelectorAll('[data-feed-search-box]').forEach(box => {
        const input = box.querySelector('[data-feed-search-input]');
        const results = box.querySelector('[data-feed-search-results]');
        if(!results) return;
        if(input && input.value !== query) input.value = query;
        const activeTab = box.dataset.searchTab || "all";
        box.classList.toggle('searching', !!clean);
        box.querySelectorAll('[data-search-tab]').forEach(tab => {
          tab.classList.toggle('active', (tab.dataset.searchTab || "all") === activeTab);
        });
        if(!clean){
          results.innerHTML = "";
          return;
        }
        if(activeTab === "people"){
          const users = searchableUsers()
            .filter(user => userSearchText(user).includes(clean))
            .slice(0, 12);
          results.innerHTML = users.length
            ? users.map(user => feedSearchUserHTML(user, query)).join("")
            : `<div class="feed-search-empty">No people found.</div>`;
          return;
        }
        const matcher = activeTab === "title"
          ? postTitleSearchText
          : (activeTab === "content" ? postContentSearchText : postSearchText);
        const matches = searchablePosts()
          .filter(post => matcher(post).includes(clean))
          .slice(0, 12);
        results.innerHTML = matches.length
          ? matches.map(post => feedSearchResultHTML(post, query)).join("")
          : `<div class="feed-search-empty">No post found.</div>`;
      });
    }

