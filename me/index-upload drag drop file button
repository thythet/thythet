      if(!select) return;
      const storages = cloudinaryStorageList().filter(item => item.cloudName && item.uploadPreset);
      const previous = Number(select.value || 0);
      select.innerHTML = storages.length
        ? storages.map((storage, index) => `<option value="${index}">STORAGE ${index + 1} - ${escapeHTML(storage.cloudName)}</option>`).join("")
        : `<option value="">No Cloudinary storage set</option>`;
      select.disabled = !storages.length;
      if(storages.length) select.value = String(Math.min(previous, storages.length - 1));
      renderCloudinaryStorageMenu();
