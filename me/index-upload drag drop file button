    function enterAppMediaFullscreen(media){
      if(!media) return;
      exitAppMediaFullscreen();
      const placeholder = document.createElement('div');
      placeholder.className = 'media-fullscreen-placeholder';
      placeholder.style.cssText = `height:${media.offsetHeight || 0}px;width:100%;`;
      media.parentNode?.insertBefore(placeholder, media);
      appFullscreenPlaceholder = placeholder;
      appFullscreenMedia = media;
      document.body.appendChild(media);
      media.classList.add('app-fullscreen', 'controls-visible');
      document.body.style.overflow = "hidden";
      if(window.AndroidMedia?.setFullscreen){
        try{ window.AndroidMedia.setFullscreen(true); }catch(error){}
      }
    }

    function exitAppMediaFullscreen(){
      if(!appFullscreenMedia) return false;
      appFullscreenMedia.classList.remove('app-fullscreen');
      if(appFullscreenPlaceholder?.parentNode){
        appFullscreenPlaceholder.parentNode.insertBefore(appFullscreenMedia, appFullscreenPlaceholder);
        appFullscreenPlaceholder.remove();
      }
      appFullscreenMedia = null;
      appFullscreenPlaceholder = null;
      document.body.style.overflow = "";
      if(window.AndroidMedia?.setFullscreen){
        try{ window.AndroidMedia.setFullscreen(cleanImageViewEnabled); }catch(error){}
      }
      return true;
    }

