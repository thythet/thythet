  <style>
    @font-face{
      font-family:'Krasar';
      src:url('https://thythet.com/assets/fonts/Krasar.woff') format('woff');
      font-weight:400;
      font-display:swap;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      min-height:100vh;
      background:
        radial-gradient(circle at 15% -10%, rgba(57,121,255,.20), transparent 34%),
        radial-gradient(circle at 100% 8%, rgba(0,211,184,.13), transparent 30%),
        #081522;
      font-family:'Kantumruy Pro', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      color:#fff;
      overflow-x:hidden;
    }
    body.dark-mode{
      background:
        radial-gradient(circle at 15% -10%, rgb(0 0 0 / 20%), transparent 34%),
        radial-gradient(circle at 100% 8%, rgba(0,211,184,.13), #29121200 30%),
        #000000;
    }
    body.auth-locked .app,
    body.auth-locked .bottom-nav,
    body:not(.admin-user) .bottom-nav{display:none}
    body.blocked-user .app,
    body.blocked-user .auth-gate,
    body.blocked-user .bottom-nav,
    body.blocked-user .profile-board,
    body.blocked-user .seen-board,
    body.blocked-user .composer,
    body.blocked-user .audio-storage-board,
    body.blocked-user .user-profile-board{display:none !important}
    body.shared-preview .auth-gate,
    body.shared-preview .topbar,
    body.shared-preview .bottom-nav,
    body.shared-preview #roleCard{display:none !important}
    body.shared-preview .app{padding-top:18px}
    body.shared-preview .post{cursor:pointer}
    body.shared-preview .post .top-info .profile{display:none}
    body.shared-preview .post .top-info{
      top:auto;
      left:auto;
      right:calc(var(--gap) + 4px);
      bottom:calc(var(--gap) + 4px);
      justify-content:flex-end;
    }
    body.shared-preview .post .media-tools{
      gap:6px;
    }
    body.shared-preview .post .fullscreen-post-btn{
      opacity:1 !important;
      pointer-events:auto !important;
      transform:none !important;
    }
    body.clean-image-view .post:not(.auth-card-skeleton) .top-info .profile{
      opacity:0;
      pointer-events:none;
      transform:translateY(-6px);
    }
    .shared-login-wrap{
      display:none;
      justify-content:center;
      padding:28px 0 6px;
    }
    body.shared-preview .shared-login-wrap{display:flex}
    .shared-login-wrap .google-signin-btn{
      min-height:54px;
      width:min(100%, 390px);
      padding:8px 20px;
      gap:14px;
      font-size:clamp(12px, 3.2vw, 14px);
      white-space:nowrap;
    }
    .shared-login-wrap .google-signin-btn svg{
      width:31px;
      height:31px;
      flex:0 0 auto;
    }
    .shared-login-wrap .google-signin-btn span{
      min-width:0;
      overflow:hidden;
      text-overflow:clip;
    }
    .shared-more-wrap{
      display:none;
      justify-content:center;
      padding:24px 0 6px;
    }
    .shared-more-btn{
      min-height:48px;
      min-width:190px;
      border:1px solid rgba(125,203,255,.46);
      border-radius:999px;
      background:linear-gradient(180deg,rgba(50,118,170,.76),rgba(20,70,112,.78));
      color:#f4fbff;
      font-weight:800;
      box-shadow:0 14px 32px rgba(0,0,0,.24), inset 0 1px rgba(255,255,255,.18);
    }
    .shared-more-btn:active{transform:translateY(1px)}

    :root{
      /* EDIT ONLY THESE TWO VALUES TO TUNE UI */
      --avatar-radius:6px;
      --card-width:390px;

      /* AUTO CALCULATED */
      --gap:calc(var(--avatar-radius) * 2);
      --media-radius:calc(var(--avatar-radius) + var(--gap));
      --audio-radius:var(--media-radius);
      --card-radius:calc(var(--media-radius) + var(--gap));

      --avatar-size:38px;
      --text:#fff;
      --muted:rgba(255,255,255,.82);
      --soft:rgba(255,255,255,.55);
      --line:rgba(255,255,255,.14);
      --danger:#ff496d;
      --blue:#72c2ff;
    }

    button,input,textarea{font-family:inherit}
    button{cursor:pointer}
    button,
    a,
    [role="button"],
    .profile-chip,
    .post,
    .media,
    .track,
    .time{
      -webkit-tap-highlight-color:transparent;
      tap-highlight-color:transparent;
    }
    button,
    .profile-chip,
    .online-user-pill,
    .seen-strip,
    .profile-post-thumb,
    .setting-choice{
      position:relative;
      touch-action:manipulation;
    }
    .touch-ripple{
      position:fixed;
      border-radius:50%;
      pointer-events:none;
      z-index:9999;
      width:10px;
      height:10px;
      left:var(--ripple-x);
      top:var(--ripple-y);
      transform:translate(-50%,-50%) scale(0);
      background:radial-gradient(circle,rgba(255,255,255,.46) 0%,rgba(126,211,255,.26) 44%,rgba(126,211,255,0) 72%);
      animation:touchRipple .28s ease-out forwards;
    }
    .notify-btn{
      overflow:visible;
      isolation:auto;
    }
    @keyframes touchRipple{
      to{
        transform:translate(-50%,-50%) scale(var(--ripple-scale, 12));
        opacity:0;
      }
    }

    *{
      scrollbar-width:thin;
      scrollbar-color:rgba(114,194,255,.72) rgba(8,18,30,.72);
    }
    *::-webkit-scrollbar{
      width:8px;
      height:8px;
    }
    *::-webkit-scrollbar-track{
      background:rgba(8,18,30,.72);
      border-radius:999px;
    }
    *::-webkit-scrollbar-thumb{
      min-height:42px;
      border-radius:999px;
      background:linear-gradient(180deg,rgba(126,211,255,.92),rgba(43,126,214,.82));
      border:2px solid rgba(8,18,30,.72);
    }
    *::-webkit-scrollbar-thumb:hover{
      background:linear-gradient(180deg,rgba(178,234,255,.98),rgba(67,154,239,.92));
    }
    *::-webkit-scrollbar-corner{
      background:transparent;
    }
    html{
      scrollbar-width:none;
    }
    html::-webkit-scrollbar,
    body::-webkit-scrollbar{
      display:none;
    }
    .seen-list,
    .audio-storage-form,
    .composer,
    .profile-board{
      scrollbar-width:thin;
      scrollbar-color:rgba(114,194,255,.72) rgba(8,18,30,.72);
    }

    .app{
      width:min(100%, calc(var(--card-width) + 20px));
      margin:0 auto;
      padding:10px 10px 74px;
    }

    .topbar{
      position:sticky;
      top:0;
      z-index:30;
      margin:0 -10px 10px;
      padding:10px 10px 8px;
      background:transparent;
      transition:transform .24s ease, opacity .24s ease;
    }
    .topbar.hidden{
      transform:translateY(-78px);
      opacity:0;
      pointer-events:none;
    }

    .topbar-inner{
      width:min(100%, var(--card-width));
      margin:0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }

    .profile-chip{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
      flex:1 1 auto;
      border:0;
      background:transparent;
      color:#fff;
      padding:0;
      text-align:left;
    }

    .profile-avatar{
      width:38px;
      height:38px;
      border-radius:50%;
      border:1px solid rgba(255,255,255,.28);
      background:rgba(255,255,255,.10);
      display:grid;
      place-items:center;
      flex:0 0 auto;
      overflow:hidden;
      box-shadow:0 12px 28px rgba(0,0,0,.22);
    }

    .profile-avatar img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    .profile-avatar svg{
      width:20px;
      height:20px;
      stroke-width:2;
    }

    .profile-name{
      font-size:15px;
      font-weight:800;
      line-height:1.15;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .profile-email{
      margin-top:3px;
      font-size:11px;
      color:var(--soft);
      line-height:1.2;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .online-dot{
      display:block;
      width:6px;
      height:6px;
      border-radius:50%;
      background:#35e96f;
    }
    .online-dot-wrap{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:13px;
      height:13px;
      margin-left:2px;
      border-radius:50%;
      vertical-align:-1px;
      overflow:visible;
    }

    .profile-board{
      position:fixed;
      inset:0;
      z-index:90;
      display:none;
      align-items:flex-start;
      justify-content:center;
      padding:84px 10px 88px;
      background:rgba(3,10,18,.56);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      overflow:auto;
    }
    .profile-board.open{display:flex}
    .profile-sheet{
      width:min(100%, var(--card-width));
      border:1px solid rgba(255,255,255,.16);
      border-radius:24px;
      background:rgba(12,29,45,.94);
      box-shadow:0 24px 70px rgba(0,0,0,.42);
      overflow:hidden;
    }
    .profile-board-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:14px;
      background:rgba(255,255,255,.06);
      border-bottom:1px solid rgba(255,255,255,.12);
    }
    .profile-board-user{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }
    .profile-board-avatar{
      width:54px;
      height:54px;
      border-radius:16px;
      overflow:hidden;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.18);
      flex:0 0 auto;
      display:grid;
      place-items:center;
    }
    .profile-board-avatar img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }
    .profile-board-avatar svg{width:25px;height:25px}
    .profile-board-name{
      font-size:18px;
      font-weight:900;
      line-height:1.1;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .profile-board-name-text{
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .profile-board-actions{
      margin-left:auto;
      display:flex;
      align-items:center;
      gap:10px;
    }
    .profile-pro-crown-slot{
      min-width:34px;
      height:34px;
      display:grid;
      place-items:center;
    }
    .profile-pro-crown-slot:empty{
      display:none;
    }
    .profile-pro-crown{
      flex:0 0 auto;
      color:#ffd86b;
      font-size:18px;
      line-height:1;
      filter:drop-shadow(0 2px 5px rgba(255,216,107,.25));
    }
    .profile-board-email{
      margin-top:5px;
      color:var(--muted);
      font-size:12px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .profile-board-role{
      margin-top:8px;
      display:inline-flex;
      max-width:100%;
      border-radius:999px;
      padding:5px 8px;
      background:rgba(114,194,255,.18);
      color:#d7efff;
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.04em;
    }
    .profile-close-btn{
      width:38px;
      height:38px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.16);
      background:rgba(255,255,255,.08);
      color:#fff;
      display:grid;
      place-items:center;
      padding:0;
      flex:0 0 auto;
    }
    .profile-logout-icon-btn{
      color:#ffd8e0;
      background:rgba(255,73,109,.14);
      border-color:rgba(255,125,153,.28);
    }
    .profile-close-btn svg{width:19px;height:19px;stroke-width:2.2}
    .profile-board-body{
      padding:14px;
      display:flex;
      flex-direction:column;
      gap:14px;
    }
    .profile-tabs{
      display:flex;
      gap:8px;
      padding:10px 14px 0;
      overflow-x:auto;
      scrollbar-width:none;
    }
    .profile-tabs::-webkit-scrollbar{display:none}
    .profile-tab-btn{
      min-height:34px;
      border:0;
      border-bottom:2px solid transparent;
      background:transparent;
      color:rgba(255,255,255,.58);
      font-size:12px;
      font-weight:900;
      padding:0 4px;
      white-space:nowrap;
      cursor:pointer;
    }
    .profile-tab-btn.active{
      color:#fff;
      border-bottom-color:#fff;
    }
    .profile-tab-panel{display:none}
    .profile-tab-panel.active{display:block}
    .profile-actions{
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .profile-action-btn{
      min-height:42px;
      border:1px solid rgba(255,255,255,.14);
      border-radius:16px;
      background:rgba(255,255,255,.08);
      color:#fff;
      font-size:12px;
      font-weight:900;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      padding:0 12px;
      flex:1;
    }
    .profile-action-btn.danger{
      background:rgba(255,73,109,.16);
      color:#ffd5dd;
    }
    .profile-action-btn.warning{
      background:rgba(94,183,255,.14);
      color:#d8efff;
      border-color:rgba(126,199,255,.24);
    }
    .profile-action-btn svg{width:18px;height:18px;stroke-width:2.2}
    .policy-link-row{
      display:flex;
      flex-wrap:nowrap;
      justify-content:center;
      gap:8px;
      margin-top:14px;
      width:min(100%, 720px);
    }
    .policy-link-btn{
      min-height:38px;
      width:auto;
      flex:1 1 0;
      min-width:0;
      border:1px solid rgba(255,255,255,.20);
      border-radius:13px;
      background:linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.055));
      color:#f4fbff;
      font-size:10.5px;
      font-weight:500;
      cursor:pointer;
      padding:0 14px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.16), 0 10px 24px rgba(0,0,0,.20);
      backdrop-filter:blur(14px);
      -webkit-backdrop-filter:blur(14px);
      text-shadow:0 1px 8px rgba(0,0,0,.52);
    }
    .policy-link-btn:active{transform:translateY(1px)}
    .policy-login-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:7px;
    }
    .policy-login-btn svg{
      width:18px;
      height:18px;
      flex:0 0 auto;
    }
    .policy-actions{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:10px;
    }
    .policy-actions .profile-action-btn{font-weight:500}
    #policyBoard .seen-sheet{
      width:min(94vw, 560px);
      max-height:min(82vh, 720px);
      border:1px solid rgba(159,213,255,.24);
      border-radius:24px;
      background:
        radial-gradient(circle at 12% -8%, rgba(105,154,238,.24), transparent 34%),
        linear-gradient(180deg, rgba(20,38,58,.98), rgba(7,22,36,.98));
      box-shadow:0 28px 80px rgba(0,0,0,.46), inset 0 1px 0 rgba(255,255,255,.10);
      overflow:hidden;
    }
    #policyBoard .seen-head{
      min-height:66px;
      padding:14px 16px;
      border-bottom:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.035);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
    }
    #policyBoard .seen-title{
      font-size:17px;
      font-weight:900;
      letter-spacing:0;
    }
    #policyBoard .profile-close-btn{
      width:42px;
      height:42px;
      border-radius:15px;
    }
    .policy-board-body{
      padding:18px;
      max-height:calc(min(82vh, 720px) - 66px);
      overflow:auto;
      display:flex;
      flex-direction:column;
      gap:12px;
      color:rgba(238,247,255,.86);
      font-size:13.5px;
      line-height:1.7;
      scrollbar-color:rgba(126,199,255,.55) rgba(255,255,255,.06);
    }
    .policy-panel{display:none}
    .policy-panel.active{display:block}
    .policy-panel h3{
      margin:8px 0 10px;
      color:#fff;
      font-size:22px;
      font-weight:900;
      line-height:1.15;
    }
    .policy-panel h4{
      margin:16px 0 8px;
      color:#f7fbff;
      font-size:14px;
      font-weight:900;
      letter-spacing:.01em;
    }
    .policy-panel p{
      margin:0 0 10px;
      color:rgba(238,247,255,.82);
    }
    .policy-panel ul{
      margin:0 0 10px;
      padding:0;
      list-style:none;
      display:flex;
      flex-direction:column;
      gap:8px;
    }
    .policy-panel li{
      position:relative;
      padding-left:18px;
      color:rgba(238,247,255,.82);
    }
    .policy-panel li::before{
      content:"";
      position:absolute;
      left:0;
      top:.75em;
      width:6px;
      height:6px;
      border-radius:50%;
      background:linear-gradient(135deg,#8fe2ff,#71ff9b);
      box-shadow:0 0 12px rgba(113,255,155,.24);
    }
    .policy-updated{
      width:max-content;
      max-width:100%;
      padding:6px 10px;
      border:1px solid rgba(143,226,255,.18);
      border-radius:999px;
      background:rgba(143,226,255,.08);
      color:rgba(216,239,255,.78);
      font-size:10px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.05em;
    }
    .policy-panel h4,
    .policy-panel p,
    .policy-panel ul{
      padding:0 2px;
    }
    .policy-panel h4:not(:first-of-type){
      border-top:1px solid rgba(255,255,255,.08);
      padding-top:14px;
    }
    .policy-panel h3 + p{
      max-width:48ch;
      color:rgba(238,247,255,.76);
    }
    .profile-section{
      border-top:1px solid rgba(255,255,255,.12);
      padding-top:14px;
    }
    .profile-tab-panel .profile-section{
      border-top:0;
      padding-top:0;
    }
    .profile-section:first-child{border-top:0;padding-top:0}
    .section-title{
      font-size:13px;
      font-weight:900;
      margin-bottom:8px;
    }
    .section-copy{
      color:var(--muted);
      font-size:12px;
      line-height:1.5;
    }
    .online-list{
      display:flex;
      flex-wrap:nowrap;
      gap:8px;
      margin-top:12px;
      overflow-x:auto;
      overflow-y:hidden;
      scrollbar-width:none;
      -webkit-overflow-scrolling:touch;
    }
    .online-list::-webkit-scrollbar{display:none}
    .online-user-pill{
      min-width:0;
      display:inline-flex;
      align-items:center;
      gap:7px;
      max-width:100%;
      border:1px solid rgba(53,233,111,.22);
      border-radius:999px;
      padding:5px 9px 5px 5px;
      background:rgba(53,233,111,.08);
      color:#fff;
      font-size:12px;
      font-weight:800;
      cursor:pointer;
      flex:0 0 auto;
    }
    .online-user-pill.more{
      min-width:38px;
      justify-content:center;
      padding:5px 10px;
      border-color:rgba(255,255,255,.18);
      background:rgba(255,255,255,.08);
