        .filter(item => item.cloudName && item.uploadPreset)
        .map(item => ({
          cloudName:item.cloudName,
          uploadPreset:item.uploadPreset,
          folder:item.folder || "grace-media"
        }));
      try{
        setCloudinarySettingsStatus("Saving...");
        await fb.update(fb.dbRef(db, `sermonUsers/${currentUser.uid}`), {
          cloudinary:null,
          cloudinaryStorages:payload.length ? payload : null,
          updatedAt:Date.now()
        });
