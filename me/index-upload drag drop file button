    function renderAudienceUserList(selected=[]){
      const list = document.getElementById('audienceUserList');
      if(!list) return;
      const selectedSet = new Set((Array.isArray(selected) ? selected : parseAudienceUsers(selected)).map(String));
      const users = audienceSelectableUsers().sort((a,b) => {
        const aSelected = selectedSet.has(a.uid) ? 0 : 1;
        const bSelected = selectedSet.has(b.uid) ? 0 : 1;
        if(aSelected !== bSelected) return aSelected - bSelected;
        return String(a.name || "").localeCompare(String(b.name || ""));
      });
      list.innerHTML = users.length ? users.map(user => `
        <label class="audience-user-option ${selectedSet.has(user.uid) ? "checked" : ""}">
          ${safeImageTag(user.photo) || `<span class="audience-user-avatar">${avatarFallback()}</span>`}
          <span class="audience-user-name">${escapeHTML(user.name || "Church Member")}</span>
          <input type="checkbox" value="${escapeHTML(user.uid)}" ${selectedSet.has(user.uid) ? "checked" : ""}>
          <span class="audience-check-circle" aria-hidden="true"></span>
        </label>
      `).join("") : `<div class="audience-empty">No followers or following users yet.</div>`;
    }

