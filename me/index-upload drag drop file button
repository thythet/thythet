        return "";
      }
      if(/^https?:\/\//i.test(fileName)){
        detectedAudioUrl = fileName;
        document.getElementById('audioUrlInput').value = detectedAudioUrl;
        updateAudioSelectedText();
        if(showStatus) setAudioPickerStatus("Direct audio URL selected.", "success");
        return detectedAudioUrl;
      }
      if(!audioStorageBases.length){
        if(showStatus) setAudioPickerStatus("Add at least one storage link first.", "error");
        return "";
      }
      for(const base of audioStorageBases){
        const url = audioUrlFromBase(base, fileName);
        if(showStatus) setAudioPickerStatus("Checking " + audioFileLabel(url) + "...");
        if(await probeAudioUrl(url)){
          detectedAudioUrl = url;
          document.getElementById('audioUrlInput').value = detectedAudioUrl;
          updateAudioSelectedText();
          if(showStatus) setAudioPickerStatus("Audio found and selected.", "success");
          return detectedAudioUrl;
        }
      }
      if(showStatus) setAudioPickerStatus("No matching audio file found in saved storage links.", "error");
      return "";
    }

