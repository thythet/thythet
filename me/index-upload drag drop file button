    function uploadCloudinaryWithProgress(url, formData, onProgress){
      return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        xhr.open("POST", url);
        xhr.upload.onprogress = event => {
          if(!event.lengthComputable) return;
          onProgress?.((event.loaded / event.total) * 100);
        };
        xhr.onload = () => {
          let result = {};
          try{
            result = JSON.parse(xhr.responseText || "{}");
          }catch(error){
            result = {};
          }
          if(xhr.status < 200 || xhr.status >= 300 || !result.secure_url){
            reject(new Error(result.error?.message || "Cloudinary upload failed."));
            return;
          }
          resolve(result);
        };
        xhr.onerror = () => reject(new Error("Network upload failed."));
        xhr.onabort = () => reject(new Error("Upload cancelled."));
        xhr.send(formData);
      });
    }

    async function uploadImageToCloudinary(file, index, button){
      if(!file) return;
      if(!isUploadableImageFile(file)){
        setComposerStatusMessage("Please choose an image file.", "error");
        return;
      }
      const settings = activeCloudinarySettings();
      if(!settings.cloudName || !settings.uploadPreset){
        setComposerStatusMessage("Set up your private Cloudinary storage in Profile > Storage first.", "error");
        alert("Please set up your private Cloudinary storage first.\n\nGo to Profile > Storage > Private Cloudinary Storage.");
        return;
      }
      try{
        button?.classList.add("uploading");
        if(button) button.disabled = true;
        const rowHdButton = button?.closest('.image-link-row')?.querySelector('.image-row-hd');
        const useHd = rowHdButton ? rowHdButton.classList.contains('published') : !!imageHdValues[index];
        setComposerStatusMessage(useHd ? "Preparing HD image..." : "Preparing image...");
        const uploadFile = await convertImageToWebp(file, {hd:useHd});
        const uploadLabel = uploadFile === file ? "Uploading original image..." : (useHd ? "Uploading HD WebP image..." : "Uploading WebP image...");
        setComposerStatusMessage(uploadLabel);
        const formData = new FormData();
        formData.append("file", uploadFile);
        formData.append("upload_preset", settings.uploadPreset);
        if(settings.folder) formData.append("folder", settings.folder);
        setUploadProgress(1);
        const result = await uploadCloudinaryWithProgress(
          `https://api.cloudinary.com/v1_1/${encodeURIComponent(settings.cloudName)}/image/upload`,
          formData,
          setUploadProgress
        );
        setUploadProgress(100);
        syncImageLinkValues();
        imageLinkValues[index] = cloudinaryDisplayImageUrl(result.secure_url);
        imageHdValues[index] = useHd;
        renderImageLinkFields(imageLinkValues);
        sanitizeImageLinkInputs({showStatus:true});
        saveComposerDraft();
        setComposerStatusMessage("Image uploaded.", "success");
        hideUploadProgress(650);
      }catch(error){
        console.error("Cloudinary upload failed:", error);
        hideUploadProgress(1200);
        setComposerStatusMessage(`Image upload failed. ${error.message || ""}`.trim(), "error");
        alert("Image upload failed.\n\n" + (error.message || "Please check Cloudinary upload preset."));
      }finally{
        button?.classList.remove("uploading");
        if(button) button.disabled = false;
      }
    }

