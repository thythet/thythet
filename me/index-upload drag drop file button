    }

    function clientActionAllowed(key, limit=8, windowMs=60000){
      const now = Date.now();
      const storageKey = `sermonActionLimit:${key}`;
      const record = safeJSONParse(sessionStorage.getItem(storageKey) || "[]", []);
      const recent = Array.isArray(record) ? record.filter(time => now - Number(time || 0) < windowMs) : [];
      if(recent.length >= limit) return false;
      recent.push(now);
      sessionStorage.setItem(storageKey, JSON.stringify(recent));
      return true;
    }

