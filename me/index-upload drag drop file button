    function audienceSelectableUsers(){
      const ids = new Set([
        ...Object.keys(currentFollowing || {}),
        ...Object.keys(currentFollowers || {})
      ].filter(uid => uid && uid !== currentUser?.uid));
      return [...ids]
        .map(uid => userSummary(uid))
        .filter(Boolean)
        .sort((a,b) => String(a.name || "").localeCompare(String(b.name || "")));
