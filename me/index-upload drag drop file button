    function openSeenBoard(postId){
      const users = seenUsersForPost(postId);
      const post = firebasePosts.find(item => item.id === postId);
      seenBoard.dataset.postId = postId || "";
      seenTitle.textContent = `Seen by ${users.length}`;
      if(seenTotalViews) seenTotalViews.querySelector('span').textContent = `Total Views ${compactNumber(post?.views || 0)}`;
      seenList.innerHTML = users.length ? users.map(user => `
        <div class="seen-row" data-seen-user-uid="${escapeHTML(user.uid || "")}">
          <div class="seen-row-avatar">
            ${safeImageTag(user.photo) || avatarFallback()}
          </div>
          <div class="seen-row-meta">
            <div class="seen-row-name">${escapeHTML(user.name || "Church Member")}</div>
            <div class="seen-row-email">${followerStatusHTML(user.uid)}</div>
          </div>
          ${currentUser && user.uid && user.uid !== currentUser.uid ? `
            <button class="follow-btn ${isFollowing(user.uid) ? "following" : ""}" type="button" data-follow-uid="${escapeHTML(user.uid)}">
              ${isFollowing(user.uid) ? "Following" : "Follow"}
            </button>
          ` : ""}
        </div>
      `).join("") : `<div class="empty">No seen users yet.</div>`;
      seenBoard.classList.add('open');
      seenBoard.setAttribute('aria-hidden', 'false');
    }

    function closeSeenBoard(){
      seenBoard.classList.remove('open');
      seenBoard.setAttribute('aria-hidden', 'true');
    }

    function refreshSeenBoardIfOpen(){
      if(seenBoard.classList.contains('open')){
        openSeenBoard(seenBoard.dataset.postId || "");
      }
    }

    function hideMediaControls(media){
      if(!media) return;
      const timer = mediaControlTimers.get(media);
      if(timer) clearTimeout(timer);
      mediaControlTimers.delete(media);
      media.querySelector('.owner-tools.open')?.classList.remove('open');
      media.querySelector('.owner-menu-toggle.open')?.classList.remove('open');
      media.classList.remove('controls-visible');
    }

    function showMediaControls(media){
      if(!media) return;
      media.classList.add('controls-visible');
      const oldTimer = mediaControlTimers.get(media);
      if(oldTimer) clearTimeout(oldTimer);
      const timer = setTimeout(() => hideMediaControls(media), 5000);
      mediaControlTimers.set(media, timer);
    }

    function notificationText(item){
      const actor = item.actorName || "Someone";
      if(item.type === "admin_request") return `${actor} requested upload access.`;
      if(item.type === "admin_pending_post") return `${actor} has a pending post.`;
      if(item.type === "admin_restore_post") return `${actor} requested post restore.`;
      if(item.type === "follow") return `${actor} followed you.`;
      if(item.type === "like") return `${actor} liked your post.`;
      if(item.type === "share") return `${actor} shared your post.`;
      if(item.type === "new_post") return `${actor} posted something new.`;
      return item.message || "New notification.";
    }

    function notificationHTML(item){
      const actor = item.actorName || "Someone";
      const action = (() => {
        if(item.type === "admin_request") return "requested upload access.";
        if(item.type === "admin_pending_post") return "has a pending post.";
        if(item.type === "admin_restore_post") return "requested post restore.";
        if(item.type === "follow") return "followed you.";
        if(item.type === "like") return "liked your post.";
        if(item.type === "share") return "shared your post.";
        if(item.type === "new_post") return "posted something new.";
        return item.message || "New notification.";
      })();
      if(!item.type || !["admin_request","admin_pending_post","admin_restore_post","follow","like","share","new_post"].includes(item.type)){
        return `<span class="notification-info">${escapeHTML(action)}</span>`;
      }
      return `<strong class="notification-name">${escapeHTML(actor)}</strong> <span class="notification-info">${escapeHTML(action)}</span>`;
    }

