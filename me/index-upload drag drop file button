    function searchableUsers(){
      const usersByUid = {};
      const fallbackName = "Church Member";
      const isGenericEmptyUser = user => {
        const name = String(user?.name || "").trim().toLowerCase();
        return !user?.photo && (!name || name === fallbackName.toLowerCase());
      };
      const addUser = (user={}, options={}) => {
        const uid = user.uid;
        if(!uid || user.blocked === true) return;
        if(options.skipEmpty !== false && isGenericEmptyUser(user)) return;
        usersByUid[uid] = {
          uid,
          name:user.name || fallbackName,
          email:user.email || "",
          photo:user.photo || "",
          role:user.role || "viewer",
          hasPosts:!!options.hasPosts || !!usersByUid[uid]?.hasPosts
        };
      };
      if(currentUser){
        addUser({
          uid:currentUser.uid,
          name:currentUser.displayName || currentProfile?.name || fallbackName,
          email:currentUser.email || currentProfile?.email || "",
          photo:currentUser.photoURL || currentProfile?.photo || "",
          role:currentProfile?.role || "viewer"
        }, {skipEmpty:false});
      }
      Object.values(userDirectory || {}).forEach(user => {
        addUser(user);
      });
      firebasePosts.forEach(post => {
        if(!post?.authorUid || !isValidPost(post)) return;
        addUser({
          uid:post.authorUid,
          name:post.authorName || fallbackName,
          email:post.authorEmail || "",
          photo:post.authorPhoto || ""
        }, {hasPosts:true, skipEmpty:false});
      });
      Object.values(postSeenUsers || {}).forEach(group => {
        Object.values(group || {}).forEach(user => addUser(user));
      });
      Object.values(onlineUsers || {}).forEach(user => addUser(user));
      Object.values(userNotifications || {}).forEach(item => {
        if(!item?.actorUid) return;
        addUser({
          uid:item.actorUid,
          name:item.actorName || fallbackName,
          photo:item.actorPhoto || ""
        });
      });
      return Object.values(usersByUid)
        .sort((a,b)=>String(a.name || "").localeCompare(String(b.name || "")));
    }

    function userSearchText(user){
      return [user.name, user.role].map(value => String(value || "").toLowerCase()).join(" ");
    }

    function highlightSearchText(value, query=""){
      const text = String(value || "");
      const needle = String(query || "").trim();
      if(!needle) return escapeHTML(text);
      if(/[\u1780-\u17FF]/.test(text) || /[\u1780-\u17FF]/.test(needle)) return escapeHTML(text);
      const lower = text.toLowerCase();
      const cleanNeedle = needle.toLowerCase();
      let index = 0;
      let html = "";
      let matchIndex = lower.indexOf(cleanNeedle);
      while(matchIndex !== -1){
        html += escapeHTML(text.slice(index, matchIndex));
        html += `<mark class="feed-search-highlight">${escapeHTML(text.slice(matchIndex, matchIndex + needle.length))}</mark>`;
        index = matchIndex + needle.length;
        matchIndex = lower.indexOf(cleanNeedle, index);
      }
      html += escapeHTML(text.slice(index));
      return html;
    }

