    async function toggleFollow(targetUid){
      if(!currentUser || !targetUid || targetUid === currentUser.uid) return;
      const wasFollowing = isFollowing(targetUid);
      currentFollowing[targetUid] = !wasFollowing;
      if(wasFollowing) delete currentFollowing[targetUid];
      if(wasFollowing && favoriteUserIds.has(targetUid)){
        favoriteUserIds.delete(targetUid);
        localStorage.setItem("sermonFavoriteUsers", JSON.stringify([...favoriteUserIds]));
        if(USE_FIREBASE) fb.set(fb.dbRef(db, `sermonUsers/${currentUser.uid}/favoriteUsers/${targetUid}`), null).catch(()=>{});
      }
      followerCounts[targetUid] = Math.max(0, followerCount(targetUid) + (wasFollowing ? -1 : 1));
      refreshFollowUI(targetUid);
      const followRef = fb.dbRef(db, `sermonFollows/${targetUid}/${currentUser.uid}`);
      const followNotificationRef = fb.dbRef(db, `sermonNotifications/${targetUid}/follow_${currentUser.uid}`);
      try{
        if(wasFollowing){
          await fb.remove(followRef);
        }else{
          await fb.set(followRef, currentActor());
          await fb.set(followNotificationRef, {
            type:"follow",
            ...actorPayload(),
            createdAt:Date.now(),
            read:false
          }).catch(error => {
            console.warn("Could not send follow notification:", error);
          });
        }
      }catch(error){
        if(wasFollowing) currentFollowing[targetUid] = true;
        else delete currentFollowing[targetUid];
        followerCounts[targetUid] = Math.max(0, followerCount(targetUid) + (wasFollowing ? 1 : -1));
        refreshFollowUI(targetUid);
        alert("Could not update follow. Please check Firebase rules.");
      }
    }

    async function notifyFollowersOfPost(postId, post){
      if(!USE_FIREBASE || !postId || !post?.authorUid || !currentUser) return;
      if(!["public","followers"].includes(normalizeAudience(post.audience || "public"))) return;
      try{
        const snap = await fb.get(fb.dbRef(db, `sermonFollows/${post.authorUid}`));
        const followers = Object.keys(snap.val() || {}).filter(uid => uid !== post.authorUid);
        await Promise.all(followers.map(uid => sendNotification(uid, {
          type:"new_post",
          postId,
          postCaption:postTextPreview(post).slice(0, 80)
        }, {
          uid:post.authorUid,
          name:post.authorName,
          email:post.authorEmail,
          photo:post.authorPhoto
        })));
      }catch(error){
        console.warn("Could not notify followers:", error);
      }
    }

