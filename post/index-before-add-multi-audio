    function startUserPresence(user){
      if(!USE_FIREBASE || !user || !fb.onValue || !fb.onDisconnect || !fb.set) return;
      const presenceRef = fb.dbRef(db, `sermonPresence/${user.uid}`);
      activePresenceRef = presenceRef;
      onlineUsers[user.uid] = {
        online:true,
        uid:user.uid,
        name:user.displayName || currentProfile?.name || "Church Member",
        photo:user.photoURL || currentProfile?.photo || "",
        lastChanged:Date.now()
      };
      refreshOnlineUI(user.uid);
      if(presenceConnectionUnsubscribe){
        try{
          presenceConnectionUnsubscribe();
        }catch(error){
          console.warn("Could not reset presence watcher:", error);
        }
      }
      presenceConnectionUnsubscribe = fb.onValue(fb.dbRef(db, '.info/connected'), snap => {
        if(snap.val() !== true) return;
        const timestamp = Date.now();
        const onlinePayload = {
          online:true,
          uid:user.uid,
          name:user.displayName || currentProfile?.name || "Church Member",
          photo:user.photoURL || currentProfile?.photo || "",
          lastChanged:timestamp
        };
        const offlinePayload = {
          online:false,
          uid:user.uid,
          name:user.displayName || currentProfile?.name || "Church Member",
          photo:user.photoURL || currentProfile?.photo || "",
          lastChanged:timestamp
        };
        fb.onDisconnect(presenceRef).set(offlinePayload)
          .then(() => fb.set(presenceRef, onlinePayload))
          .catch(error => console.warn("Could not update online presence:", error));
      }, error => console.warn("Could not watch connection status:", error));
    }

