    function currentIndexBaseUrl(){
      const url = new URL(location.href);
      url.search = "";
      url.hash = "";
      url.pathname = url.pathname.replace(/(?:index\.html?)?$/i, "");
      if(!url.pathname.endsWith("/")) url.pathname += "/";
      return url;
    }

    function createShareUrl(postId){
      const post = firebasePosts.find(item => item.id === postId);
      const url = currentIndexBaseUrl();
      const token = postShareToken(post);
      if(token) url.searchParams.set("Post", token);
      return url.toString();
