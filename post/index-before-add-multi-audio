    function renderCloudinaryStorageMenu(){
      const picker = document.getElementById('cloudinaryStoragePicker');
      const select = document.getElementById('cloudinaryStorageSelect');
      const choice = document.getElementById('cloudinaryStorageChoice');
      const choiceText = document.getElementById('cloudinaryStorageChoiceText');
      const menu = document.getElementById('cloudinaryStorageMenu');
      if(!picker || !select || !choice || !choiceText || !menu) return;
      const options = Array.from(select.options);
      const selectedOption = options.find(option => option.value === select.value) || options[0];
      const disabled = !options.length || select.disabled || selectedOption?.value === "";
      picker.classList.toggle('disabled', disabled);
      choice.disabled = disabled;
      choiceText.textContent = selectedOption?.textContent || "No Cloudinary storage set";
      menu.innerHTML = options.map(option => `
        <button class="cloudinary-storage-option ${option.value === select.value ? "active" : ""}" type="button" role="option" aria-selected="${option.value === select.value ? "true" : "false"}" data-storage-value="${escapeHTML(option.value)}">
          <span>${escapeHTML(option.textContent || "")}</span>
        </button>
      `).join("");
    }

