    function updateSharePreviewMeta(post){
      if(!post) return;
      const title = postShareTitle(post);
      const image = postShareImage(post);
      document.title = title ? `JESUS LOVEME - ${title}` : "JESUS LOVEME";
      setMetaContent('meta[name="description"]', "JESUS LOVEME");
      setMetaContent('meta[property="og:title"]', title || "JESUS LOVEME");
      setMetaContent('meta[property="og:description"]', "JESUS LOVEME");
      setMetaContent('meta[property="og:image"]', image);
      setMetaContent('meta[property="og:url"]', createShareUrl(post.id));
      setMetaContent('meta[name="twitter:title"]', title || "JESUS LOVEME");
      setMetaContent('meta[name="twitter:description"]', "JESUS LOVEME");
      setMetaContent('meta[name="twitter:image"]', image);
      setMetaContent('meta[name="twitter:card"]', "summary_large_image");
