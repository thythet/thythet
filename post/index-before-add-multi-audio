    function canViewPostAudience(post){
      const audience = normalizeAudience(post?.audience || "public");
      if(isAdmin() || post?.authorUid === currentUser?.uid) return true;
      if(audience === "public") return true;
      if(!currentUser) return false;
      const viewerUid = currentUser.uid;
      const authorUid = post?.authorUid || "";
      if(audience === "only_me") return false;
      if(audience === "followers") return !!allFollows?.[authorUid]?.[viewerUid];
      if(audience === "following") return !!allFollows?.[viewerUid]?.[authorUid];
      if(audience === "selected"){
        const allowed = (Array.isArray(post.audienceUsers) ? post.audienceUsers : []).map(item => String(item || "").toLowerCase());
        const email = String(currentUser.email || "").toLowerCase();
        return allowed.includes(viewerUid.toLowerCase()) || (!!email && allowed.includes(email));
      }
      return true;
    }

