    function isActiveNotification(item){
      if(!item) return false;
      if(item.type === "follow"){
        if(!item.actorUid) return true;
        return !!currentFollowers[item.actorUid];
      }
      if(item.type === "like"){
        if(!item.actorUid || !item.postId || !postLikeUsers) return true;
        return !!postLikeUsers[item.postId]?.[item.actorUid];
      }
      return true;
    }

    function visibleUserNotificationEntries(){
      const seenLikes = new Set();
      return Object.entries(userNotifications || {}).filter(([, item]) => {
        if(!isActiveNotification(item)) return false;
        if(item?.type !== "like" || !item.actorUid || !item.postId) return true;
        const key = `${item.actorUid}_${item.postId}`;
        if(seenLikes.has(key)) return false;
        seenLikes.add(key);
        return true;
      });
    }

    async function pruneStaleFollowNotifications(){
      if(!USE_FIREBASE || !currentUser) return;
      const stale = Object.entries(userNotifications || {}).filter(([, item]) => (
        item?.type === "follow" && item.actorUid && !currentFollowers[item.actorUid]
      ));
      if(!stale.length) return;
      const updates = {};
      stale.forEach(([id]) => {
        updates[`sermonNotifications/${currentUser.uid}/${id}`] = null;
        delete userNotifications[id];
      });
      renderNotificationList();
      refreshNotificationBadge();
      try{
        await fb.update(fb.dbRef(db), updates);
      }catch(error){
        console.warn("Could not prune stale follow notifications:", error);
      }
    }

    async function pruneStaleLikeNotifications(){
      if(!USE_FIREBASE || !currentUser || !postLikeUsers) return;
      const stale = Object.entries(userNotifications || {}).filter(([, item]) => (
        item?.type === "like" && item.actorUid && item.postId && !postLikeUsers[item.postId]?.[item.actorUid]
      ));
      if(!stale.length) return;
      const updates = {};
      stale.forEach(([id]) => {
        updates[`sermonNotifications/${currentUser.uid}/${id}`] = null;
        delete userNotifications[id];
      });
      renderNotificationList();
      refreshNotificationBadge();
      try{
        await fb.update(fb.dbRef(db), updates);
