    async function convertImageToWebp(file, options={}){
      if(!file || file.type === "image/webp" || file.type === "image/gif") return file;
      const bitmap = await createImageBitmap(file);
      const canvas = document.createElement("canvas");
      canvas.width = bitmap.width;
      canvas.height = bitmap.height;
      const ctx = canvas.getContext("2d");
      ctx.drawImage(bitmap, 0, 0);
      bitmap.close?.();
      const qualitySteps = options.hd ? [.92, .88, .84, .80, .76, .72] : [.82];
      let blob = null;
      for(const quality of qualitySteps){
        const nextBlob = await new Promise(resolve => canvas.toBlob(resolve, "image/webp", quality));
        if(!nextBlob) continue;
        blob = nextBlob;
        if(!options.hd || !file.size || nextBlob.size <= file.size) break;
      }
      if(!blob) return file;
      const baseName = String(file.name || "image").replace(/\.[^.]+$/, "");
      return new File([blob], `${baseName}.webp`, {
        type:"image/webp",
        lastModified:Date.now()
      });
    }

    async function uploadImageToCloudinary(file, index, button){
      if(!file) return;
      if(!file.type?.startsWith("image/")){
        setComposerStatusMessage("Please choose an image file.", "error");
        return;
      }
      const settings = activeCloudinarySettings();
      if(!settings.cloudName || !settings.uploadPreset){
        setComposerStatusMessage("Set up your private Cloudinary storage in Profile > Storage first.", "error");
        alert("Please set up your private Cloudinary storage first.\n\nGo to Profile > Storage > Private Cloudinary Storage.");
        return;
      }
      try{
        button?.classList.add("uploading");
        if(button) button.disabled = true;
        const rowHdButton = button?.closest('.image-link-row')?.querySelector('.image-row-hd');
        const useHd = rowHdButton ? rowHdButton.classList.contains('published') : !!imageHdValues[index];
        setComposerStatusMessage(useHd ? "Converting HD WebP image..." : "Converting image to WebP...");
        const uploadFile = await convertImageToWebp(file, {hd:useHd});
        setComposerStatusMessage(useHd ? "Uploading HD WebP image..." : "Uploading WebP image...");
        const formData = new FormData();
        formData.append("file", uploadFile);
        formData.append("upload_preset", settings.uploadPreset);
        if(settings.folder) formData.append("folder", settings.folder);
        const response = await fetch(`https://api.cloudinary.com/v1_1/${encodeURIComponent(settings.cloudName)}/image/upload`, {
          method:"POST",
          body:formData
        });
        const result = await response.json().catch(() => ({}));
        if(!response.ok || !result.secure_url){
          throw new Error(result.error?.message || "Cloudinary upload failed.");
        }
        syncImageLinkValues();
        imageLinkValues[index] = result.secure_url;
        imageHdValues[index] = useHd;
        renderImageLinkFields(imageLinkValues);
        sanitizeImageLinkInputs({showStatus:true});
        saveComposerDraft();
        setComposerStatusMessage("Image uploaded.", "success");
      }catch(error){
        console.error("Cloudinary upload failed:", error);
        setComposerStatusMessage(`Image upload failed. ${error.message || ""}`.trim(), "error");
        alert("Image upload failed.\n\n" + (error.message || "Please check Cloudinary upload preset."));
      }finally{
        button?.classList.remove("uploading");
        if(button) button.disabled = false;
      }
    }

    async function uploadAudioToCloudinary(file, button){
      if(!file) return;
      const audioExtOk = /\.(mp3|m4a|aac|wav|ogg|oga|webm)$/i.test(file.name || "");
      if(!file.type?.startsWith("audio/") && !audioExtOk){
        setComposerStatusMessage("Please choose an audio file.", "error");
        return;
      }
      const maxAudioBytes = 55 * 1024 * 1024;
      if(file.size > maxAudioBytes){
        setComposerStatusMessage("Audio file must be below 55MB.", "error");
        alert("Audio file is too large.\n\nPlease choose an audio file below 55MB.");
        return;
      }
      const settings = activeCloudinarySettings();
      if(!settings.cloudName || !settings.uploadPreset){
        setComposerStatusMessage("Set up your private Cloudinary storage in Profile > Storage first.", "error");
        alert("Please set up your private Cloudinary storage first.\n\nGo to Profile > Storage > Private Cloudinary Storage.");
        return;
      }
      try{
        button?.classList.add("uploading");
        if(button) button.disabled = true;
        setComposerStatusMessage("Uploading audio...");
        const formData = new FormData();
        formData.append("file", file);
        formData.append("upload_preset", settings.uploadPreset);
        if(settings.folder) formData.append("folder", `${settings.folder}/audio`);
        const response = await fetch(`https://api.cloudinary.com/v1_1/${encodeURIComponent(settings.cloudName)}/auto/upload`, {
          method:"POST",
          body:formData
        });
        const result = await response.json().catch(() => ({}));
        if(!response.ok || !result.secure_url){
          throw new Error(result.error?.message || "Cloudinary audio upload failed.");
        }
        detectedAudioUrl = result.secure_url;
        document.getElementById('audioUrlInput').value = detectedAudioUrl;
        if(audioFileNameInput) audioFileNameInput.value = result.original_filename || audioFileLabel(detectedAudioUrl);
        updateAudioSelectedText();
        saveComposerDraft();
        setComposerStatusMessage("Audio uploaded.", "success");
      }catch(error){
        console.error("Cloudinary audio upload failed:", error);
        setComposerStatusMessage(`Audio upload failed. ${error.message || ""}`.trim(), "error");
        alert("Audio upload failed.\n\n" + (error.message || "Please check Cloudinary upload preset."));
      }finally{
        button?.classList.remove("uploading");
        if(button) button.disabled = false;
      }
    }

