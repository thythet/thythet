    function renderPosts(posts){
      if(!posts.length){
        feed.innerHTML = `<div class="empty">${canUpload() ? "No posts yet. Tap + to create the first sermon post." : "No sermon posts yet."}</div>`;
        return;
      }
      feed.innerHTML = posts.map((post,index)=>postHTML(post,index)).join("");
      setupLazyImages();
      setupSliders();
      setupCaptions();
      setupAudio();
      setupPostViews();
      refreshSavedFavoriteUI();
    }

    function captureActiveAudioState(){
      const audio = [...document.querySelectorAll('[data-audio-ui] audio')]
        .find(player => !player.paused && !player.ended);
      if(!audio) return null;
      const postEl = audio.closest('.post');
      return {
        postId: postEl?.dataset.postId || "",
        src: audio.currentSrc || audio.src || "",
        time: Number.isFinite(audio.currentTime) ? audio.currentTime : 0,
        volume: audio.volume,
        muted: audio.muted
      };
    }

    function restoreActiveAudioState(state){
      if(!state?.postId) return;
      const postEl = [...document.querySelectorAll('.post')]
        .find(el => el.dataset.postId === state.postId);
      const audio = postEl?.querySelector('[data-audio-ui] audio');
      if(!audio) return;
      const currentSrc = audio.currentSrc || audio.src || "";
      if(state.src && currentSrc && currentSrc !== state.src) return;
      const syncPlayback = () => {
        try{
          audio.volume = state.volume;
          audio.muted = state.muted;
          if(Number.isFinite(state.time)) audio.currentTime = Math.min(state.time, audio.duration || state.time);
          audio.play().catch(() => {});
        }catch(error){
          console.warn("Could not restore audio playback:", error);
        }
      };
      if(audio.readyState >= 1) syncPlayback();
      else audio.addEventListener('loadedmetadata', syncPlayback, {once:true});
    }

    function renderPostsPreservingAudio(posts){
      const activeAudio = captureActiveAudioState();
      renderPosts(posts);
      if(activeAudio) setTimeout(() => restoreActiveAudioState(activeAudio), 0);
    }

    async function recordPostSeen(postId, postEl){
      if(!postId || !currentUser) return;
      if(postSeenUsers[postId]?.[currentUser.uid]) return;
      const seenUser = currentSeenUser();
      postSeenUsers[postId] = {
        ...(postSeenUsers[postId] || {}),
        [currentUser.uid]:seenUser
      };
      updateSeenStack(postId, postEl);
      if(!USE_FIREBASE) return;
      try{
        await fb.set(fb.dbRef(db, `sermonPostSeen/${postId}/${currentUser.uid}`), seenUser);
      }catch(error){
        delete postSeenUsers[postId]?.[currentUser.uid];
        updateSeenStack(postId, postEl);
        console.warn("Could not update seen user:", error);
      }
    }

    async function registerPostView(postId, postEl){
      if(!postId) return;
      await recordPostSeen(postId, postEl);
      const sessionKey = `sermonPostViewed:${postId}`;
      if(sessionStorage.getItem(sessionKey)) return;
      sessionStorage.setItem(sessionKey, "1");

      const post = firebasePosts.find(entry => entry.id === postId);
      if(post) post.views = Number(post.views || 0) + 1;

      if(!USE_FIREBASE) return;
      try{
        const countRef = fb.dbRef(db, `sermonPosts/${postId}/views`);
        await fb.runTransaction(countRef, count => Number(count || 0) + 1);
      }catch(error){
        sessionStorage.removeItem(sessionKey);
        if(viewBtn) viewBtn.textContent = currentCount;
        if(post) post.views = Math.max(0, Number(post.views || 0) - 1);
        console.warn("Could not update view count:", error);
      }
    }

    function setupPostViews(){
      if(activeViewObserver) activeViewObserver.disconnect();
      const posts = [...document.querySelectorAll('.post[data-post-id]')];
      if(!posts.length) return;

      if(!('IntersectionObserver' in window)){
        posts.forEach(postEl => registerPostView(postEl.dataset.postId, postEl));
        return;
      }

      activeViewObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if(!entry.isIntersecting || entry.intersectionRatio < 0.55) return;
          const postEl = entry.target;
          activeViewObserver.unobserve(postEl);
          registerPostView(postEl.dataset.postId, postEl);
        });
      }, {threshold:[0.55]});

      posts.forEach(postEl => activeViewObserver.observe(postEl));
    }

    function setupLazyImages(){
      const imgs = document.querySelectorAll('img[data-src]');
      if(!imgs.length) return;
      const io = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if(!entry.isIntersecting) return;
          const img = entry.target;
          img.src = img.dataset.src;
          img.onload = () => img.classList.add('loaded');
          io.unobserve(img);
        });
      }, {rootMargin:"260px"});
      imgs.forEach(img => io.observe(img));
    }

    function setupSliders(){
      document.querySelectorAll('.media').forEach(media => {
        const slides = media.querySelector('.slides');
        const dots = [...media.querySelectorAll('.dot')];
        const count = media.querySelector('.media-count');
        if(!slides) return;

        slides.addEventListener('scroll', () => {
          const active = Math.round(slides.scrollLeft / slides.clientWidth);
          dots.forEach((dot,i)=>dot.classList.toggle('active', i === active));
          if(count) count.textContent = `${active + 1}/${Math.max(dots.length,1)}`;
        }, {passive:true});
      });
    }

    function setupCaptions(){
      const lessIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" /></svg>`;
      document.querySelectorAll('.post-content').forEach(content => {
        const line = content.querySelector('.caption-line');
        const text = content.querySelector('.caption-text');
        const btn = content.querySelector('.more-link');
        if(!text || !btn) return;

        requestAnimationFrame(() => {
          const needsMore = text.scrollWidth > text.clientWidth + 2;
          line.classList.toggle('needs-more', needsMore);
          if(!needsMore){
            btn.innerHTML = lessIcon;
            btn.setAttribute("aria-label", "Show post date");
          }else{
            btn.innerHTML = "more";
            btn.setAttribute("aria-label", "Show full caption");
          }
          content?.classList.toggle('caption-below', line.classList.contains('expanded'));
          content?.classList.toggle('caption-expanded', line.classList.contains('expanded'));
        });

        btn.addEventListener('click', () => {
          const expanded = line.classList.toggle('expanded');
          const needsMore = line.classList.contains('needs-more');
          btn.innerHTML = expanded && needsMore ? "less" : (needsMore ? "more" : lessIcon);
          btn.setAttribute("aria-label", expanded ? "Hide post date" : (needsMore ? "Show full caption" : "Show post date"));
          content?.classList.toggle('caption-below', expanded);
          content?.classList.toggle('caption-expanded', expanded);
        });
      });
    }

    function setupAudio(){
      document.querySelectorAll('[data-audio-ui]').forEach(ui => {
        const btn = ui.querySelector('.speaker');
        const audio = ui.querySelector('audio');
        const current = ui.querySelector('.current');
        const duration = ui.querySelector('.duration');
        const progress = ui.querySelector('.progress');
        const track = ui.querySelector('.track');
        const postEl = ui.closest('.post');
        const tools = postEl?.querySelector('[data-audio-tools]');

        if(!audio){
          btn.addEventListener('click',()=>alert('No audio added yet.'));
          return;
        }

        const syncSpeakerIcon = () => {
          btn.innerHTML = audio.paused ? icons.speakerStopped : icons.speakerPlaying;
          btn.setAttribute("aria-label", audio.paused ? "Play" : "Pause");
        };
        const syncToolStates = () => {
          const toggle = tools?.querySelector('[data-audio-action="toggleplay"]');
          if(toggle) toggle.innerHTML = audio.paused ? icons.play : icons.pause;
          tools?.querySelector('[data-audio-action="mute"]')?.classList.toggle('active', audio.muted);
          tools?.querySelector('[data-audio-action="loop"]')?.classList.toggle('active', audio.loop);
        };
        syncSpeakerIcon();
        syncToolStates();

        const requireAudioLogin = () => {
          if(currentUser) return false;
          alert("Please log in to listen audio.");
          signInOrOut();
          return true;
        };

        audio.addEventListener('loadedmetadata',()=>{
          duration.textContent = formatTime(audio.duration);
        });
        audio.addEventListener('play', syncSpeakerIcon);
        audio.addEventListener('pause', syncSpeakerIcon);
        audio.addEventListener('ended', syncSpeakerIcon);
        audio.addEventListener('play', syncToolStates);
        audio.addEventListener('pause', syncToolStates);
        audio.addEventListener('ended', syncToolStates);
        audio.addEventListener('volumechange', syncToolStates);

        audio.addEventListener('timeupdate',()=>{
          current.textContent = formatTime(audio.currentTime);
          const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
          progress.style.width = pct + "%";
        });

        btn.addEventListener('click', async ()=>{
          if(requireAudioLogin()) return;
          document.querySelectorAll('audio').forEach(a => { if(a !== audio) a.pause(); });
          if(audio.paused) await audio.play();
          else audio.pause();
        });

        track.addEventListener('click', e => {
          if(requireAudioLogin()) return;
          const rect = track.getBoundingClientRect();
          const pct = (e.clientX - rect.left) / rect.width;
          audio.currentTime = pct * audio.duration;
        });

        const openTools = () => {
          document.querySelectorAll('.post.audio-tools-open').forEach(post => {
            if(post !== postEl) post.classList.remove('audio-tools-open');
          });
          postEl?.classList.add('audio-tools-open');
          syncToolStates();
        };
        const toggleTools = e => {
          e.preventDefault();
          e.stopPropagation();
          if(postEl?.classList.contains('audio-tools-open')) postEl.classList.remove('audio-tools-open');
          else openTools();
        };
        [current, duration].forEach(label => {
          label.addEventListener('click', toggleTools);
        });
        track.addEventListener('mouseenter', openTools);
        track.addEventListener('touchstart', openTools, {passive:true});

        tools?.addEventListener('click', e => {
          const tool = e.target.closest('[data-audio-action]');
          if(!tool) return;
          e.stopPropagation();
          if(requireAudioLogin()) return;
          const action = tool.dataset.audioAction;
          if(action === "toggleplay"){
            if(audio.paused){
              document.querySelectorAll('audio').forEach(a => { if(a !== audio) a.pause(); });
              audio.play().catch(()=>{});
            }else{
              audio.pause();
            }
          }
          if(action === "stop"){
            audio.pause();
            audio.currentTime = 0;
            progress.style.width = "0%";
            current.textContent = "00:00";
          }
          if(action === "mute") audio.muted = !audio.muted;
          if(action === "loop") audio.loop = !audio.loop;
          if(action === "back10") audio.currentTime = Math.max(0, audio.currentTime - 10);
          if(action === "forward10") audio.currentTime = Math.min(audio.duration || audio.currentTime + 10, audio.currentTime + 10);
          syncToolStates();
        });
      });
    }

    function closeAudioToolboxes(exceptPost=null){
      document.querySelectorAll('.post.audio-tools-open').forEach(post => {
        if(post !== exceptPost) post.classList.remove('audio-tools-open');
      });
    }

