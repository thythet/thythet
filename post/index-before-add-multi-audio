    async function updatePostLike(postId, postEl, forceLike=false){
      if(!currentUser) return renderAuthGate();
      const like = postEl?.querySelector('.like-btn');
      const span = like?.querySelector('span');
      const post = firebasePosts.find(entry => entry.id === postId);
      const wasLiked = userLikedPostIds.has(postId);
      const shouldLike = forceLike ? true : !wasLiked;
      if(shouldLike === wasLiked) return;

      like?.classList.toggle('liked', shouldLike);
      if(span) span.textContent = Math.max(0, Number(span.textContent) + (shouldLike ? 1 : -1));
      const likeRef = fb.dbRef(db, `sermonPostLikes/${postId}/${currentUser.uid}`);
      const countRef = fb.dbRef(db, `sermonPosts/${postId}/likes`);
      try{
        if(shouldLike){
          await fb.set(likeRef, {
            email:currentUser.email || "",
            name:currentUser.displayName || "",
            at:Date.now()
          });
          await fb.runTransaction(countRef, count => Number(count || 0) + 1);
          if(post?.authorUid && post.authorUid !== currentUser.uid){
            await removeLikeNotifications(post.authorUid, currentUser.uid, postId);
            await fb.set(fb.dbRef(db, `sermonNotifications/${post.authorUid}/${likeNotificationId(postId, currentUser.uid)}`), {
              type:"like",
              postId,
              postCaption:postTextPreview(post).slice(0, 80),
              ...actorPayload(),
              createdAt:Date.now(),
              read:false
            }).catch(error => {
              console.warn("Could not send like notification:", error);
            });
          }
          userLikedPostIds.add(postId);
        }else{
          await fb.remove(likeRef);
          await fb.runTransaction(countRef, count => Math.max(0, Number(count || 0) - 1));
          if(post?.authorUid && post.authorUid !== currentUser.uid){
            await removeLikeNotifications(post.authorUid, currentUser.uid, postId);
          }
          userLikedPostIds.delete(postId);
        }
      }catch(error){
        like?.classList.toggle('liked', wasLiked);
        if(span) span.textContent = Math.max(0, Number(span.textContent) + (shouldLike ? -1 : 1));
        alert("Could not update like. Please try again.");
      }
    }

    function formatTime(sec){
      if(!isFinite(sec)) return "00:00";
      const m = Math.floor(sec / 60);
      const s = Math.floor(sec % 60);
      return String(m).padStart(2,'0') + ":" + String(s).padStart(2,'0');
    }

    async function loadFirebasePosts(){
      if(!USE_FIREBASE) return renderPosts(demoPosts);
      const sharedLink = hasSharedPostLink();
      const sharedPreview = !currentUser && sharedLink;
      if(!currentUser && !sharedLink) return renderAuthGate();
      const snap = await fb.get(fb.dbRef(db, 'sermonPosts'));
      const val = snap.val() || {};
      const posts = Object.entries(val).map(([id,p]) => ({id,...p})).sort((a,b)=>(b.createdAt||0)-(a.createdAt||0));
      firebasePosts = posts;
      cleanupInvalidPostsForAdmin(posts);
      const linkedPost = linkedPostFromPosts(posts);
      const visiblePosts = sharedLink
        ? (linkedPost && isValidPost(linkedPost) && linkedPost.blockedByAdmin !== true && canViewPostAudience(linkedPost) && linkedPost.status !== "pending" ? [linkedPost] : [])
        : visiblePostsFrom(posts);
      if(currentUser){
        const likeSnap = await fb.get(fb.dbRef(db, 'sermonPostLikes'));
        const likeVal = likeSnap.val() || {};
        postLikeUsers = likeVal;
        userLikedPostIds = new Set(Object.entries(likeVal)
          .filter(([, users]) => users && users[currentUser.uid])
          .map(([postId]) => postId));
      }else{
        postLikeUsers = null;
        userLikedPostIds = new Set();
      }
      try{
        const seenSnap = await fb.get(fb.dbRef(db, 'sermonPostSeen'));
        postSeenUsers = seenSnap.val() || {};
      }catch(error){
        postSeenUsers = {};
        console.warn("Could not load seen users:", error);
      }
      renderPostsPreservingAudio(visiblePosts);
      renderRoleUI();
      if(linkedPost) updateSharePreviewMeta(linkedPost);
      setSharedPreviewMode(sharedPreview && !!linkedPost);
      setSharedMoreButton(!!(currentUser && sharedLink && linkedPost));
      if(sharedLink && !linkedPost && !currentUser) renderAuthGate();
      if(currentUser) recordSharedLinkClick();
      if(isAdmin()) await loadAdminRequests();
    }

    function syncImageLinkValues(){
      const previousLinks = imageLinkValues;
      const previousHd = imageHdValues;
      const inputs = [...document.querySelectorAll('.image-link-input')];
      imageLinkValues = inputs.map(input => input.value);
      imageHdValues = inputs.map(input => {
        const oldIndex = Number(input.dataset.linkIndex || 0);
        return input.value ? (input.value === previousLinks[oldIndex] ? !!previousHd[oldIndex] : false) : !!previousHd[oldIndex];
      });
      if(!imageLinkValues.length) imageLinkValues = [""];
      if(!imageHdValues.length) imageHdValues = [false];
    }

    function normalizeImageLink(link=""){
      const clean = String(link || "").trim();
      if(!clean) return "";
      try{
        const url = new URL(clean);
        url.hash = "";
        const path = url.pathname.replace(/\/+$/, "");
        return `${url.protocol.toLowerCase()}//${url.host.toLowerCase()}${path}${url.search}`;
      }catch(error){
        return clean.replace(/\/+$/, "");
      }
    }

    function existingImageKeys(excludePostId=""){
      const keys = new Set();
      firebasePosts.forEach(post => {
        if(excludePostId && post.id === excludePostId) return;
        (post.images || []).forEach(src => {
          const key = normalizeImageLink(src);
          if(key) keys.add(key);
        });
      });
      return keys;
    }

    function sanitizeImageLinkInputs({excludePostId=editingPostId, showStatus=false}={}){
      const inputs = [...document.querySelectorAll('.image-link-input')];
      const usedInForm = new Set();
      const usedOnPlatform = existingImageKeys(excludePostId);
      let removedPlatform = false;
      let removedDuplicate = false;

      inputs.forEach(input => {
        input.classList.remove('image-link-alert');
        const raw = input.value.trim();
        const key = normalizeImageLink(raw);
        if(!key) return;
        if(usedOnPlatform.has(key)){
          input.value = "";
          input.placeholder = "Image already posted";
          input.classList.add('image-link-alert');
          removedPlatform = true;
          return;
        }
        if(usedInForm.has(key)){
          input.value = "";
          input.placeholder = "Duplicate image";
          input.classList.add('image-link-alert');
          removedDuplicate = true;
          return;
        }
        usedInForm.add(key);
      });

      syncImageLinkValues();
      if(showStatus && (removedPlatform || removedDuplicate)){
        const statusEl = document.getElementById('composerStatus');
        if(statusEl){
          statusEl.textContent = removedPlatform ? "Image already posted." : "Duplicate image removed.";
          statusEl.className = "composer-status error";
        }
      }
      return {removedPlatform, removedDuplicate, ok:!removedPlatform && !removedDuplicate};
    }

    function renderImageLinkFields(values=imageLinkValues){
      const container = document.getElementById('imageLinkRows');
      const limit = imageLimit();
      const normalized = Number.isFinite(limit)
        ? (values.length ? values : [""]).slice(0, limit)
        : (values.length ? values : [""]);
      imageLinkValues = normalized;
      imageHdValues = normalized.map((_, index) => !!imageHdValues[index]);
      container.innerHTML = normalized.map((value, index) => `
        <div class="image-link-row ${value ? "has-image" : ""}">
          <input class="field image-link-input" type="url" inputmode="url" value="${escapeHTML(value || "")}" placeholder="IMAGE URL${index + 1}" data-link-index="${index}">
          <input class="cloudinary-upload-input" type="file" accept="image/*" data-upload-index="${index}">
