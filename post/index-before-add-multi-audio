        }
        presenceConnectionUnsubscribe = null;
      }
      if(!activePresenceRef || !fb.set) return;
      const uid = currentUser?.uid || "";
      const offlinePayload = {
        online:false,
        uid,
        name:currentUser?.displayName || currentProfile?.name || "Church Member",
        photo:currentUser?.photoURL || currentProfile?.photo || "",
        lastChanged:Date.now()
      };
      try{
        await fb.set(activePresenceRef, offlinePayload);
      }catch(error){
        console.warn("Could not mark user offline:", error);
      }finally{
        if(uid){
          onlineUsers[uid] = offlinePayload;
          refreshOnlineUI(uid);
        }
        activePresenceRef = null;
