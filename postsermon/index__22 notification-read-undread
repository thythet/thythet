    async function ensureUserProfile(user){
      if(!USE_FIREBASE || !user) return;
      const userRef = fb.dbRef(db, `sermonUsers/${user.uid}`);
      const snap = await fb.get(userRef);
      const existing = snap.val() || {};
      const admin = user.email === ADMIN_EMAIL;
      const profile = {
        uid:user.uid,
        email:user.email || "",
        name:user.displayName || "Church Member",
        photo:user.photoURL || "",
        role:admin ? "admin" : (existing.role || "viewer"),
        status:admin ? "approved" : (existing.status || "viewer"),
        requestedRole:existing.requestedRole || "",
        updatedAt:Date.now(),
        createdAt:existing.createdAt || Date.now()
      };
      await fb.update(userRef, profile);
      currentProfile = profile;
      renderAuthGate();
      updateAuthUI();
      renderRoleUI();
    }

    async function requestCreatorAccess(){
      if(!currentUser) return renderAuthGate();
      const userRef = fb.dbRef(db, `sermonUsers/${currentUser.uid}`);
      await fb.update(userRef, {
        uid:currentUser.uid,
        email:currentUser.email || "",
        name:currentUser.displayName || "Church Member",
        photo:currentUser.photoURL || "",
        role:currentProfile?.role || "viewer",
        status:"requested",
        requestedRole:"content_creator",
        requestedAt:Date.now(),
        updatedAt:Date.now()
      });
      currentProfile = {...(currentProfile || {}), status:"requested", requestedRole:"content_creator"};
