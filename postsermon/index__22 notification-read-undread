    function renderNotificationList(){
      const items = Object.entries(userNotifications || {})
        .map(([id, item]) => ({id, ...item}))
        .sort((a,b)=>(b.createdAt || 0) - (a.createdAt || 0));
      if(clearNotificationsBtn) clearNotificationsBtn.disabled = !items.length;
      notificationList.innerHTML = items.length ? items.map(item => `
        <div class="seen-row notification-row ${item.read === true ? "read" : "unread"}" data-notification-id="${escapeHTML(item.id)}">
          <div class="seen-row-avatar" data-profile-uid="${escapeHTML(item.actorUid || "")}">
            ${item.actorPhoto ? `<img src="${escapeHTML(item.actorPhoto)}" alt="">` : avatarFallback()}
          </div>
          <div class="seen-row-meta">
            <div class="notification-copy" data-profile-uid="${escapeHTML(item.actorUid || "")}">${escapeHTML(notificationText(item))}</div>
            <div class="notification-time">${timeAgo(item.createdAt)}</div>
          </div>
          <div class="notification-actions">
            ${item.type === "follow" && item.actorUid && item.actorUid !== currentUser?.uid ? `
              <button class="follow-btn ${isFollowing(item.actorUid) ? "following" : ""}" type="button" data-follow-uid="${escapeHTML(item.actorUid)}">
                ${isFollowing(item.actorUid) ? "Following" : "Follow Back"}
