      composer.setAttribute('aria-hidden', 'false');
    }

    document.getElementById('composerBtn').addEventListener('click', handleCreateClick);
    document.getElementById('navCreateBtn').addEventListener('click', handleCreateClick);
    document.getElementById('profileChip').addEventListener('click', openProfileBoard);
    document.getElementById('profileCloseBtn').addEventListener('click', closeProfileBoard);
    document.getElementById('profileLogoutBtn').addEventListener('click', signInOrOut);
    document.getElementById('seenCloseBtn').addEventListener('click', closeSeenBoard);
    document.getElementById('notificationCloseBtn').addEventListener('click', closeNotificationBoard);
    clearNotificationsBtn.addEventListener('click', clearNotifications);
    document.getElementById('userProfileCloseBtn').addEventListener('click', closeUserProfile);
    document.getElementById('audioStorageCloseBtn').addEventListener('click', closeAudioStorageBoard);
    document.getElementById('composerCloseBtn').addEventListener('click', closeComposer);
    notifyBtn.addEventListener('click', () => {
      openNotificationBoard();
    });
    profileBoard.addEventListener('click', e => {
      if(e.target === profileBoard) closeProfileBoard();
    });
    seenBoard.addEventListener('click', e => {
      if(e.target === seenBoard) closeSeenBoard();
      const followBtn = e.target.closest('.follow-btn');
      if(followBtn){
        toggleFollow(followBtn.dataset.followUid);
        return;
      }
      const profileTarget = e.target.closest('[data-seen-user-uid]');
      if(profileTarget && !e.target.closest('button')){
        openUserProfile(profileTarget.dataset.seenUserUid);
      }
    });
    notificationBoard.addEventListener('click', e => {
      if(e.target === notificationBoard) closeNotificationBoard();
      const goBtn = e.target.closest('.go-post-btn');
      if(goBtn){
        goToPost(goBtn.dataset.goPostId);
        return;
      }
      const followBtn = e.target.closest('.follow-btn');
      if(followBtn){
        toggleFollow(followBtn.dataset.followUid);
        return;
      }
      const notificationRow = e.target.closest('.notification-row');
      if(notificationRow && !e.target.closest('button')){
        toggleNotificationRead(notificationRow.dataset.notificationId);
        return;
      }
      const profileTarget = e.target.closest('[data-profile-uid]');
      if(profileTarget){
        openUserProfile(profileTarget.dataset.profileUid);
        return;
      }
    });
    userProfileBoard.addEventListener('click', e => {
      if(e.target === userProfileBoard) closeUserProfile();
      const followBtn = e.target.closest('.follow-btn');
      if(followBtn){
        toggleFollow(followBtn.dataset.followUid);
        openUserProfile(followBtn.dataset.followUid);
        return;
      }
      const goBtn = e.target.closest('[data-go-post-id]');
      if(goBtn){
        goToPost(goBtn.dataset.goPostId);
      }
    });
    audioStorageBoard.addEventListener('click', e => {
      if(e.target === audioStorageBoard) closeAudioStorageBoard();
      const add = e.target.closest('.add-storage-link-btn');
      const remove = e.target.closest('.remove-storage-link-btn');
      if(!add && !remove) return;
      const values = currentAudioStorageRowValues();
      if(add) values.push("");
      if(remove){
        const row = e.target.closest('.audio-storage-link-row');
        const index = Number(row?.querySelector('.audio-storage-link-input')?.dataset.storageLinkIndex || 0);
        values.splice(index, 1);
      }
      renderAudioStorageRows(values.length ? values : [""]);
    });
    audioStorageBoard.addEventListener('input', e => {
      if(e.target.closest('.audio-storage-link-input')) syncAudioStorageSource();
    });
    composer.addEventListener('click', e => {
      if(e.target === composer) closeComposer();
    });
    let lastScrollY = window.scrollY;
    window.addEventListener('scroll', () => {
      const currentY = window.scrollY;
      const shouldHide = currentY > lastScrollY && currentY > 80 && !profileBoard.classList.contains('open');
      bottomNav.classList.toggle('hidden', shouldHide);
      topbar.classList.toggle('hidden', shouldHide);
      lastScrollY = Math.max(0, currentY);
    }, {passive:true});
    document.getElementById('clearFormBtn').addEventListener('click', resetComposer);
    document.getElementById('composerForm').addEventListener('submit', publishPost);
    document.getElementById('audioPickerIconBtn').addEventListener('click', openAudioStorageBoard);
    document.getElementById('saveAudioStorageBtn').addEventListener('click', saveAudioStorageBases);
    audioStorageList.addEventListener('click', e => {
      const editBtn = e.target.closest('.edit-audio-base-btn');
      if(editBtn){
        editAudioStorageBase(Number(editBtn.dataset.audioBaseIndex));
        return;
      }
      const deleteBtn = e.target.closest('.delete-audio-base-btn');
      if(deleteBtn){
        deleteAudioStorageBase(Number(deleteBtn.dataset.audioBaseIndex));
      }
    });
    document.getElementById('imageLinkRows').addEventListener('input', syncImageLinkValues);
    document.getElementById('imageLinkRows').addEventListener('click', e => {
      const add = e.target.closest('.add-image-link-btn');
      const remove = e.target.closest('.remove-image-link-btn');
      if(!add && !remove) return;

      syncImageLinkValues();
      if(add && imageLinkValues.length < imageLimit()){
        imageLinkValues.push("");
      }
      if(remove){
        const row = e.target.closest('.image-link-row');
        const input = row?.querySelector('.image-link-input');
        const index = Number(input?.dataset.linkIndex || 0);
        imageLinkValues.splice(index, 1);
        if(!imageLinkValues.length) imageLinkValues = [""];
      }
      renderImageLinkFields(imageLinkValues);
    });
    document.getElementById('requestCreatorBtn').addEventListener('click', requestCreatorAccess);

    async function signInOrOut(){
      if(!USE_FIREBASE){
        alert("Demo mode. Set USE_FIREBASE = true and paste Firebase config.");
        return;
      }
      if(auth.currentUser || currentUser){
        const confirmed = window.confirm("Do you want to log out?");
        if(!confirmed) return;
        currentUser = null;
        currentProfile = null;
        closeProfileBoard();
        updateAuthUI();
        return fb.signOut(auth);
      }
      try{
        setLoginBusy(true);
        const provider = new fb.GoogleAuthProvider();
        const result = await fb.signInWithPopup(auth, provider);
        currentUser = result.user || auth.currentUser;
        updateAuthUI();
        await ensureUserProfile(currentUser);
        await loadAudioStorageBases();
        await loadFirebasePosts();
      }catch(error){
        const authCopy = document.getElementById('authCopy');
        if(authCopy) authCopy.textContent = "Google sign-in was cancelled or could not open. Please try again.";
      }finally{
        setLoginBusy(false);
      }
    }

    document.getElementById('loginBtn').addEventListener('click', signInOrOut);
    document.getElementById('gateLoginBtn').addEventListener('click', signInOrOut);
    document.getElementById('welcomeImageBtn').addEventListener('click', signInOrOut);
    document.getElementById('welcomeImage').addEventListener('load', () => {
      if(authGate.classList.contains('checking')) return;
      document.getElementById('welcomeImageBtn').classList.remove('loading');
    });
    document.getElementById('welcomeImage').addEventListener('error', () => {
      const btn = document.getElementById('welcomeImageBtn');
      btn.classList.remove('loading');
      btn.classList.add('failed');
    });
    if(document.getElementById('welcomeImage').complete && !authGate.classList.contains('checking')){
      document.getElementById('welcomeImageBtn').classList.remove('loading');
    }

    profileBoard.addEventListener('click', async e => {
      if(!isAdmin()) return;
      const userRow = e.target.closest('[data-request-uid]');
      const manageUserRow = e.target.closest('[data-user-uid]');
      const postRow = e.target.closest('[data-pending-post-id]');

      if(userRow){
        const uid = userRow.dataset.requestUid;
        const approve = e.target.closest('.approve-user-btn');
        const reject = e.target.closest('.reject-user-btn');
        if(!approve && !reject) return;

        await fb.update(fb.dbRef(db, `sermonUsers/${uid}`), approve ? {
          role:"content_creator",
          status:"approved",
          approvedAt:Date.now(),
          approvedBy:currentUser.email,
          updatedAt:Date.now()
        } : {
          role:"viewer",
          status:"rejected",
          rejectedAt:Date.now(),
          rejectedBy:currentUser.email,
          updatedAt:Date.now()
        });
        await loadAdminRequests();
        return;
      }

      if(manageUserRow){
        const uid = manageUserRow.dataset.userUid;
        if(uid === currentUser.uid) return;
        const deleteData = e.target.closest('.delete-user-data-btn');
        if(deleteData){
          deleteData.disabled = true;
          try{
            await permanentlyDeleteUserData(uid);
          }catch(error){
            console.error("Permanent user delete failed:", error);
            deleteData.disabled = false;
            alert("Could not permanently delete this user data. Please check Firebase rules and try again.");
          }
          return;
        }
        const grant = e.target.closest('.grant-user-btn');
        const pending = e.target.closest('.pending-user-btn');
        const remove = e.target.closest('.remove-user-btn');
        if(!grant && !pending && !remove) return;

        const update = grant ? {
          role:"content_creator",
          status:"approved",
          approvedAt:Date.now(),
          approvedBy:currentUser.email,
          updatedAt:Date.now()
        } : pending ? {
          role:"viewer",
          status:"requested",
          requestedRole:"content_creator",
          requestedAt:Date.now(),
          updatedAt:Date.now()
        } : {
          role:"viewer",
          status:"rejected",
          rejectedAt:Date.now(),
          rejectedBy:currentUser.email,
          updatedAt:Date.now()
        };
        await fb.update(fb.dbRef(db, `sermonUsers/${uid}`), update);
        await loadAdminRequests();
        return;
      }

      if(postRow){
        const postId = postRow.dataset.pendingPostId;
        const approve = e.target.closest('.approve-post-btn');
        const reject = e.target.closest('.reject-post-btn');
        if(!approve && !reject) return;

        if(approve){
          await fb.update(fb.dbRef(db, `sermonPosts/${postId}`), {
            status:"published",
            approvedAt:Date.now(),
            approvedBy:currentUser.email,
            updatedAt:Date.now()
          });
          const approvedPost = firebasePosts.find(post => post.id === postId);
          if(approvedPost) await notifyFollowersOfPost(postId, {...approvedPost, status:"published"});
        }else{
          const confirmed = window.confirm("Reject and delete this pending post?");
          if(!confirmed) return;
          await fb.remove(fb.dbRef(db, `sermonPosts/${postId}`));
        }
        await loadFirebasePosts();
      }
    });

    feed.addEventListener('click', async e => {
      const postEl = e.target.closest('.post');
      if(!postEl) return;
      const id = postEl.dataset.postId;
      const post = firebasePosts.find(entry => entry.id === id);
      const mediaTap = e.target.closest('.media');
      if(mediaTap && !e.target.closest('button')){
        showMediaControls(mediaTap);
        return;
      }

      const followIcon = e.target.closest('.profile-follow-icon');
      if(followIcon){
        await toggleFollow(followIcon.dataset.followUid);
        return;
      }

      const profileTarget = e.target.closest('[data-profile-uid]');
      if(profileTarget && !e.target.closest('button')){
        openUserProfile(profileTarget.dataset.profileUid);
        return;
      }

      const seenBtn = e.target.closest('.seen-strip');
      if(seenBtn){
        openSeenBoard(seenBtn.dataset.seenPostId || id);
        return;
      }

      const exitFullscreenBtn = e.target.closest('.exit-fullscreen-btn');
      if(exitFullscreenBtn){
        if(document.fullscreenElement && document.exitFullscreen) await document.exitFullscreen().catch(()=>{});
        else if(document.webkitFullscreenElement && document.webkitExitFullscreen) document.webkitExitFullscreen();
        return;
      }

      const fullscreenBtn = e.target.closest('.fullscreen-post-btn');
      if(fullscreenBtn){
        const media = postEl.querySelector('.media');
        showMediaControls(media);
        if(media?.requestFullscreen) await media.requestFullscreen().catch(()=>{});
        else if(media?.webkitRequestFullscreen) media.webkitRequestFullscreen();
        return;
      }

      const menuToggle = e.target.closest('.owner-menu-toggle');
      if(menuToggle){
        const tools = menuToggle.parentElement?.querySelector('.owner-tools');
        const open = !tools?.classList.contains('open');
        document.querySelectorAll('.owner-tools.open').forEach(el => el.classList.remove('open'));
        document.querySelectorAll('.owner-menu-toggle.open').forEach(el => el.classList.remove('open'));
        if(tools && open){
          tools.classList.add('open');
          menuToggle.classList.add('open');
          showMediaControls(menuToggle.closest('.media'));
        }else{
          hideMediaControls(menuToggle.closest('.media'));
        }
        return;
      }

      const editBtn = e.target.closest('.edit-post-btn');
      if(editBtn){
        if(!post) return alert("Could not find this post. Please refresh and try again.");
        if(!currentUser || (currentUser.uid !== post.authorUid && !isAdmin())){
          return alert("You can only edit your own posts.");
        }
        editBtn.closest('.owner-tools')?.classList.remove('open');
        editBtn.closest('.media-tools')?.querySelector('.owner-menu-toggle')?.classList.remove('open');
        setComposerMode(post);
        return;
      }

      const deleteBtn = e.target.closest('.delete-post-btn');
      if(deleteBtn){
        if(!post) return alert("Could not find this post. Please refresh and try again.");
        if(!currentUser || (currentUser.uid !== post.authorUid && !isAdmin())){
          return alert("You can only delete your own posts.");
        }
        const confirmed = window.confirm("Delete this sermon post? This cannot be undone.");
        if(!confirmed) return;

        deleteBtn.disabled = true;
        try{
          await fb.remove(fb.dbRef(db, `sermonPosts/${id}`));
          await loadFirebasePosts();
        }catch(error){
          deleteBtn.disabled = false;
          alert("Could not delete this post. Please check Firebase rules and try again.");
        }
        return;
      }

      const like = e.target.closest('.like-btn');
      if(like){
        if(!currentUser) return renderAuthGate();
        const span = like.querySelector('span');
        const wasLiked = userLikedPostIds.has(id);
        like.classList.toggle('liked', !wasLiked);
        span.textContent = Math.max(0, Number(span.textContent) + (wasLiked ? -1 : 1));
        const likeRef = fb.dbRef(db, `sermonPostLikes/${id}/${currentUser.uid}`);
        const countRef = fb.dbRef(db, `sermonPosts/${id}/likes`);
        try{
          if(wasLiked){
            await fb.remove(likeRef);
            await fb.runTransaction(countRef, count => Math.max(0, Number(count || 0) - 1));
            userLikedPostIds.delete(id);
          }else{
            await fb.set(likeRef, {
              email:currentUser.email || "",
              name:currentUser.displayName || "",
              at:Date.now()
            });
            await fb.runTransaction(countRef, count => Number(count || 0) + 1);
            if(post?.authorUid && post.authorUid !== currentUser.uid){
              await sendNotification(post.authorUid, {
                type:"like",
                postId:id,
                postCaption:(post.caption || "").slice(0, 80)
              });
            }
            userLikedPostIds.add(id);
          }
        }catch(error){
          like.classList.toggle('liked', wasLiked);
          span.textContent = Math.max(0, Number(span.textContent) + (wasLiked ? 1 : -1));
          alert("Could not update like. Please try again.");
        }
      }

      const share = e.target.closest('.share-btn');
      if(share){
        const text = location.href.split('#')[0] + '#post-' + id;
        if(navigator.share) await navigator.share({title:"Sermon Post", url:text}).catch(()=>{});
        else await navigator.clipboard.writeText(text);
      }
    });

    renderImageLinkFields();
    renderAuthGate("checking");
  </script>
</body>
</html>
