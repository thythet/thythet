    function renderAuthGate(state="ready"){
      const copy = document.getElementById('authCopy');
      const checking = state === "checking";

      if(currentUser){
        document.body.classList.remove('auth-locked');
        authGate.classList.add('hidden');
        authGate.classList.remove('checking');
        copy.textContent = "";
        return;
      }

      document.body.classList.add('auth-locked');
      authGate.classList.remove('hidden');
      authGate.classList.toggle('checking', checking);
      if(checking){
        document.getElementById('welcomeImageBtn').classList.add('loading');
      }else if(document.getElementById('welcomeImage').complete){
        document.getElementById('welcomeImageBtn').classList.remove('loading');
      }
      copy.textContent = checking
        ? "Checking your secure Google session..."
        : "Please sign in before viewing, liking, or requesting upload access.";
    }

    function setLoginBusy(isBusy){
      const buttons = [document.getElementById('gateLoginBtn'), document.getElementById('welcomeImageBtn')];
      buttons.forEach(btn => {
        if(btn) btn.disabled = isBusy;
