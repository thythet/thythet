    async function permanentlyDeleteUserData(uid){
      if(!isAdmin() || !uid || uid === currentUser.uid) return;
      const targetUser = (await fb.get(fb.dbRef(db, `sermonUsers/${uid}`))).val() || {};
      const label = targetUser.name || targetUser.email || uid;
      const firstConfirm = window.confirm(`Permanently delete all data for ${label}? This removes profile, posts, likes, views, follows, notifications, and audio storage links.`);
      if(!firstConfirm) return;
      const secondConfirm = window.confirm("This cannot be undone. Delete this user's platform data now?");
      if(!secondConfirm) return;

      const [postsSnap, likesSnap, seenSnap, followsSnap, notificationsSnap, savesSnap] = await Promise.all([
        fb.get(fb.dbRef(db, 'sermonPosts')),
        fb.get(fb.dbRef(db, 'sermonPostLikes')),
        fb.get(fb.dbRef(db, 'sermonPostSeen')),
        fb.get(fb.dbRef(db, 'sermonFollows')),
        fb.get(fb.dbRef(db, 'sermonNotifications')),
        fb.get(fb.dbRef(db, 'sermonPostSaves')).catch(() => ({val:()=>({})}))
      ]);

      const posts = postsSnap.val() || {};
      const likes = likesSnap.val() || {};
      const seen = seenSnap.val() || {};
      const follows = followsSnap.val() || {};
      const notifications = notificationsSnap.val() || {};
      const saves = savesSnap.val() || {};
      const updates = {
        [`sermonUsers/${uid}`]: null,
        [`sermonAudioStorageBases/${uid}`]: null,
        [`sermonNotifications/${uid}`]: null
      };
      const deletedPostIds = new Set();

      Object.entries(posts).forEach(([postId, post]) => {
        if(post?.authorUid === uid){
          deletedPostIds.add(postId);
          updates[`sermonPosts/${postId}`] = null;
          updates[`sermonPostLikes/${postId}`] = null;
          updates[`sermonPostSeen/${postId}`] = null;
          updates[`sermonPostSaves/${postId}`] = null;
          updates[`sermonPostSaves/${uid}/${postId}`] = null;
        }
      });

      Object.entries(likes).forEach(([postId, users]) => {
        if(deletedPostIds.has(postId)) return;
        if(users && users[uid]){
          updates[`sermonPostLikes/${postId}/${uid}`] = null;
          updates[`sermonPosts/${postId}/likes`] = Math.max(0, Number(posts[postId]?.likes || 0) - 1);
        }
      });

      Object.entries(seen).forEach(([postId, users]) => {
        if(deletedPostIds.has(postId)) return;
        if(users && users[uid]){
          updates[`sermonPostSeen/${postId}/${uid}`] = null;
          updates[`sermonPosts/${postId}/views`] = Math.max(0, Number(posts[postId]?.views || 0) - 1);
        }
      });

      Object.entries(follows).forEach(([targetUid, followers]) => {
        if(targetUid === uid){
          updates[`sermonFollows/${targetUid}`] = null;
          return;
        }
        if(followers && followers[uid]){
          updates[`sermonFollows/${targetUid}/${uid}`] = null;
        }
      });

      Object.entries(notifications).forEach(([ownerUid, items]) => {
        if(ownerUid === uid || !items) return;
        Object.entries(items).forEach(([notificationId, item]) => {
          if(item?.actorUid === uid || deletedPostIds.has(item?.postId)){
            updates[`sermonNotifications/${ownerUid}/${notificationId}`] = null;
          }
        });
      });

      Object.entries(saves).forEach(([firstKey, value]) => {
        if(firstKey === uid){
          updates[`sermonPostSaves/${firstKey}`] = null;
          return;
        }
        if(value && typeof value === "object" && value[uid]){
          updates[`sermonPostSaves/${firstKey}/${uid}`] = null;
        }
      });

      await fb.update(fb.dbRef(db), updates);
      await loadSocialData();
      await loadFirebasePosts();
      await loadAdminRequests();
    }

    async function loadAdminRequests(){
      if(!isAdmin()) return;
      const snap = await fb.get(fb.dbRef(db, 'sermonUsers'));
      const allUsers = Object.values(snap.val() || {})
        .filter(Boolean)
        .sort((a,b)=>String(a.name || a.email || "").localeCompare(String(b.name || b.email || "")));
      const users = allUsers
        .filter(user => user && user.status === "requested")
        .sort((a,b)=>(b.requestedAt || 0) - (a.requestedAt || 0));
      const pendingPosts = firebasePosts.filter(post => post.status === "pending");
      updateNotificationBadge(users.length + pendingPosts.length);

      const userHtml = users.length ? users.map(user => `
        <div class="request-row" data-request-uid="${escapeHTML(user.uid)}">
          <img class="request-avatar" src="${escapeHTML(user.photo || "https://thythet.com/assets/audio/mic-fill.svg?v=2")}" alt="">
          <div class="request-meta">
            <strong>${escapeHTML(user.name || "Church Member")}</strong>
            <span class="request-subline">${escapeHTML(followerLabel(user.uid))}</span>
            <span class="request-role requested">${escapeHTML(user.requestedRole || "content_creator")}</span>
          </div>
          <div class="admin-actions">
            <button class="mini-btn primary approve-user-btn" type="button">Approve</button>
            <button class="mini-btn danger reject-user-btn" type="button">Reject</button>
          </div>
        </div>
      `).join("") : `<div class="admin-empty">No pending creator requests.</div>`;

      const postHtml = pendingPosts.length ? pendingPosts.map(post => `
        <div class="request-row pending-post-row" data-pending-post-id="${escapeHTML(post.id)}">
          <img class="pending-thumb" src="${escapeHTML((post.images || [])[0] || "")}" alt="">
          <div class="request-meta">
            <strong>${escapeHTML(post.authorName || "Church Member")}</strong>
            <span class="request-subline">${escapeHTML(followerLabel(post.authorUid))}</span>
            <span class="request-caption">${escapeHTML(post.caption || "No caption")}</span>
