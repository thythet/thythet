    function normalizeAudioBase(link=""){
      const clean = String(link || "").trim();
      if(!clean) return "";
      return clean.endsWith("/") ? clean : clean + "/";
    }

    function normalizeAudioFileName(name=""){
      const clean = String(name || "").trim();
      if(!clean) return "";
      if(/^https?:\/\//i.test(clean)) return clean;
      const safeName = clean.replace(/^\/+/, "");
      return /\.[a-z0-9]{2,5}$/i.test(safeName) ? safeName : safeName + ".mp3";
    }

    function audioUrlFromBase(base, fileName){
      const normalizedBase = normalizeAudioBase(base);
      const normalizedFile = normalizeAudioFileName(fileName);
      if(!normalizedBase || !normalizedFile) return "";
      if(/^https?:\/\//i.test(normalizedFile)) return normalizedFile;
      return normalizedBase + normalizedFile.split("/").map(part => encodeURIComponent(part)).join("/");
    }

    function audioFileLabel(url=""){
