            <div class="notification-copy" data-profile-uid="${escapeHTML(item.actorUid || "")}">${notificationHTML(item)}</div>
            <div class="notification-time">${timeAgo(item.createdAt)}</div>
          </div>
          <div class="notification-actions">
            ${item.type === "follow" && item.actorUid && item.actorUid !== currentUser?.uid ? `
              <button class="follow-btn ${isFollowing(item.actorUid) ? "following" : ""}" type="button" data-follow-uid="${escapeHTML(item.actorUid)}">
                ${isFollowing(item.actorUid) ? "Following" : "Follow Back"}
              </button>
            ` : ""}
            ${item.adminNotice ? `<button class="review-admin-btn" type="button" data-admin-review="request">Review</button>` : ""}
            ${item.postId ? `<button class="go-post-btn" type="button" data-go-post-id="${escapeHTML(item.postId)}">Go to</button>` : ""}
          </div>
        </div>
      `).join("") : `<div class="empty">No notifications yet.</div>`;
    }

    function userSummary(uid){
      if(!uid) return null;
      if(currentUser && uid === currentUser.uid){
        return {
          uid,
          name:currentUser.displayName || currentProfile?.name || "Church Member",
          photo:currentUser.photoURL || currentProfile?.photo || ""
        };
      }
      const seenUser = Object.values(postSeenUsers || {})
        .flatMap(group => Object.values(group || {}))
        .find(user => user && user.uid === uid);
      if(seenUser) return {uid, name:seenUser.name || "Church Member", photo:seenUser.photo || ""};
      const post = firebasePosts.find(item => item.authorUid === uid);
      if(post) return {uid, name:post.authorName || "Church Member", photo:post.authorPhoto || ""};
      const notice = Object.values(userNotifications || {}).find(item => item && item.actorUid === uid);
      if(notice) return {uid, name:notice.actorName || "Church Member", photo:notice.actorPhoto || ""};
      return {uid, name:"Church Member", photo:""};
    }

    function postsByUser(uid){
      return firebasePosts.filter(post => isValidPost(post) && post.authorUid === uid && (post.status !== "pending" || isAdmin() || post.authorUid === currentUser?.uid));
    }

    function profilePostGridHTML(posts){
      return posts.length ? `
        <div class="profile-post-grid">
          ${posts.map(post => `
            <button class="profile-post-thumb" type="button" data-go-post-id="${escapeHTML(post.id)}">
              <img src="${escapeHTML((post.images || [])[0] || "")}" alt="">
              <span class="profile-thumb-views">${icons.eye}<span>${compactNumber(post.views || 0)}</span></span>
            </button>
          `).join("")}
        </div>
      ` : `<div class="profile-post-empty">No posts yet.</div>`;
    }

    function openUserProfile(uid){
      if(!uid) return;
      const user = userSummary(uid);
      const posts = postsByUser(uid);
      userProfileContent.innerHTML = `
        <div class="user-profile-head">
          <div class="user-profile-avatar">
            ${user.photo ? `<img src="${escapeHTML(user.photo)}" alt="">` : avatarFallback()}
          </div>
          <div class="user-profile-meta">
            <div class="user-profile-name">${escapeHTML(user.name || "Church Member")}</div>
            <div class="user-profile-count">${escapeHTML(followerLabel(uid))} · ${posts.length} ${posts.length === 1 ? "post" : "posts"}</div>
          </div>
          ${currentUser && uid !== currentUser.uid && isFollowing(uid) ? `
            <button class="profile-favorite-btn ${isFavoriteUser(uid) ? "favorited" : ""}" type="button" data-favorite-uid="${escapeHTML(uid)}" aria-label="${isFavoriteUser(uid) ? "Remove favorite" : "Add favorite"}">
              ${icons.star}
            </button>
          ` : ""}
          ${currentUser && uid !== currentUser.uid ? `
            <button class="follow-btn ${isFollowing(uid) ? "following" : ""}" type="button" data-follow-uid="${escapeHTML(uid)}">
              ${isFollowing(uid) ? "Following" : "Follow"}
            </button>
          ` : ""}
        </div>
        ${profilePostGridHTML(posts)}
      `;
      userProfileBoard.classList.add('open');
      userProfileBoard.setAttribute('aria-hidden', 'false');
    }

    function closeUserProfile(){
      userProfileBoard.classList.remove('open');
      userProfileBoard.setAttribute('aria-hidden', 'true');
    }

    function goToPost(postId){
      if(!postId) return;
      closeProfileBoard();
      closeNotificationBoard();
      closeUserProfile();
      closeSeenBoard();
      const safePostId = window.CSS?.escape ? CSS.escape(postId) : String(postId).replace(/"/g, '\\"');
      const postEl = document.querySelector(`.post[data-post-id="${safePostId}"]`);
      if(postEl){
        postEl.scrollIntoView({behavior:"smooth", block:"center"});
        postEl.classList.add('controls-visible');
        setTimeout(() => postEl.classList.remove('controls-visible'), 1400);
      }
    }

    function createShareUrl(postId){
      const url = new URL(location.href);
      url.hash = "";
      url.searchParams.set("post", postId);
      url.searchParams.set("share", `${Date.now()}_${Math.random().toString(36).slice(2, 9)}`);
      url.searchParams.set("by", currentUser?.displayName || currentProfile?.name || "Church Member");
      url.searchParams.set("byUid", currentUser?.uid || "");
      return url.toString();
    }

    function setMetaContent(selector, content){
      const el = document.head.querySelector(selector);
      if(el) el.setAttribute("content", content || "");
    }

    function updateSharePreviewMeta(post){
      if(!post) return;
      const caption = String(post.caption || "Sermon Post").replace(/\s+/g, " ").trim();
      const oneLine = caption.length > 92 ? caption.slice(0, 92).trim() + "... read more" : caption;
      const image = (post.images || [])[0] || "https://thythet.com/assets/audio/mic-fill.svg?v=2";
      document.title = caption ? `Sermon Post - ${oneLine}` : "Sermon Post";
      setMetaContent('meta[name="description"]', oneLine || "Church sermon image and audio post platform.");
      setMetaContent('meta[property="og:title"]', "Sermon Post");
      setMetaContent('meta[property="og:description"]', oneLine || "Church sermon image and audio post platform.");
      setMetaContent('meta[property="og:image"]', image);
      setMetaContent('meta[name="twitter:card"]', "summary_large_image");
    }

    async function recordSharedLinkClick(){
      if(!USE_FIREBASE || !currentUser) return;
      const params = new URLSearchParams(location.search);
      const postId = params.get("post");
      const shareId = params.get("share");
      const sharedBy = params.get("by") || "";
      const sharedByUid = params.get("byUid") || "";
      if(!postId || !shareId) return;

      const localKey = `sermonShareClicked:${postId}:${shareId}`;
      if(localStorage.getItem(localKey)){
        goToPost(postId);
        return;
      }
      localStorage.setItem(localKey, "1");

      try{
        await fb.runTransaction(fb.dbRef(db, `shareCounts/${shareCountKey(postId)}`), count => Number(count || 0) + 1);
        const postSnap = await fb.get(fb.dbRef(db, `sermonPosts/${postId}`)).catch(() => null);
        const post = postSnap?.val?.() || firebasePosts.find(item => item.id === postId);
        updateSharePreviewMeta(post);
        if(post?.authorUid && post.authorUid !== sharedByUid){
          await sendNotification(post.authorUid, {
            type:"share",
            postId,
            postCaption:(post.caption || "").slice(0, 80)
          }, {
            uid:currentUser.uid,
            name:sharedBy || currentUser.displayName || "Church Member",
            email:currentUser.email || "",
            photo:currentUser.photoURL || ""
          });
        }
      }catch(error){
        localStorage.removeItem(localKey);
        console.warn("Could not count shared link click:", error);
      }
      goToPost(postId);
    }

    async function openNotificationBoard(){
      if(!currentUser) return renderAuthGate();
      if(isAdmin()) await loadAdminRequests();
      renderNotificationList();
      notificationBoard.classList.add('open');
      notificationBoard.setAttribute('aria-hidden', 'false');
    }

    function closeNotificationBoard(){
      notificationBoard.classList.remove('open');
      notificationBoard.setAttribute('aria-hidden', 'true');
    }

    async function clearNotifications(){
      if(!currentUser) return renderAuthGate();
      const count = Object.keys(userNotifications || {}).length;
      if(!count) return;
      const confirmed = window.confirm("Clear all notifications?");
      if(!confirmed) return;
      if(clearNotificationsBtn) clearNotificationsBtn.disabled = true;
      const previous = userNotifications;
      userNotifications = {};
      renderNotificationList();
      refreshNotificationBadge();
      if(!USE_FIREBASE) return;
      try{
        await fb.remove(fb.dbRef(db, `sermonNotifications/${currentUser.uid}`));
      }catch(error){
        userNotifications = previous;
        renderNotificationList();
        refreshNotificationBadge();
        alert("Could not clear notifications. Please try again.");
      }
    }

    function isActiveNotification(item){
      if(!item) return false;
      if(item.type !== "follow") return true;
      if(!item.actorUid) return true;
      return !!currentFollowers[item.actorUid];
    }

    function visibleUserNotificationEntries(){
      return Object.entries(userNotifications || {}).filter(([, item]) => isActiveNotification(item));
    }

    async function pruneStaleFollowNotifications(){
      if(!USE_FIREBASE || !currentUser) return;
      const stale = Object.entries(userNotifications || {}).filter(([, item]) => (
        item?.type === "follow" && item.actorUid && !currentFollowers[item.actorUid]
      ));
      if(!stale.length) return;
      const updates = {};
      stale.forEach(([id]) => {
        updates[`sermonNotifications/${currentUser.uid}/${id}`] = null;
        delete userNotifications[id];
      });
      renderNotificationList();
      refreshNotificationBadge();
      try{
        await fb.update(fb.dbRef(db), updates);
      }catch(error){
        console.warn("Could not prune stale follow notifications:", error);
      }
    }

    function unreadNotificationCount(){
      return visibleUserNotificationEntries().filter(([, item]) => item && item.read !== true).length;
    }

    function refreshNotificationBadge(){
      const count = unreadNotificationCount() + (isAdmin() ? adminNoticeCount : 0);
      notifyBtn.style.display = currentUser ? "" : "none";
      notifyBtn.classList.toggle('has-count', count > 0);
      notifyBadge.textContent = count > 99 ? "99+" : String(count);
    }

    async function markNotificationsRead(){
      if(!USE_FIREBASE || !currentUser) return;
      const unread = visibleUserNotificationEntries().filter(([, item]) => item && item.read !== true);
      if(!unread.length) return;
      const updates = {};
      unread.forEach(([id]) => {
        updates[`sermonNotifications/${currentUser.uid}/${id}/read`] = true;
        userNotifications[id].read = true;
      });
      renderNotificationList();
      refreshNotificationBadge();
      try{
        await fb.update(fb.dbRef(db), updates);
      }catch(error){
        console.warn("Could not mark notifications read:", error);
      }
    }

    async function toggleNotificationRead(notificationId){
      if(!notificationId || !currentUser || !userNotifications[notificationId]) return;
      const nextRead = userNotifications[notificationId].read !== true;
      userNotifications[notificationId].read = nextRead;
      renderNotificationList();
      refreshNotificationBadge();
      if(!USE_FIREBASE) return;
      try{
        await fb.update(fb.dbRef(db, `sermonNotifications/${currentUser.uid}/${notificationId}`), {read:nextRead});
      }catch(error){
        userNotifications[notificationId].read = !nextRead;
        renderNotificationList();
        refreshNotificationBadge();
        console.warn("Could not toggle notification read:", error);
      }
    }

    async function toggleSavePost(postId){
      if(!currentUser || !postId) return renderAuthGate();
      const wasSaved = isSavedPost(postId);
      if(wasSaved) savedPostIds.delete(postId);
      else savedPostIds.add(postId);
      localStorage.setItem("sermonSavedPosts", JSON.stringify([...savedPostIds]));
      refreshSavedFavoriteUI();
      if(activeFeedFilter === "saved") renderPostsPreservingAudio(visiblePosts());
      if(!USE_FIREBASE) return;
      try{
        await fb.set(fb.dbRef(db, `sermonUsers/${currentUser.uid}/savedPosts/${postId}`), wasSaved ? null : true);
      }catch(error){
        if(wasSaved) savedPostIds.add(postId);
        else savedPostIds.delete(postId);
        refreshSavedFavoriteUI();
        if(activeFeedFilter === "saved") renderPostsPreservingAudio(visiblePosts());
        alert("Could not update saved post. Please try again.");
      }
    }

    async function toggleFavoriteUser(uid){
      if(!currentUser || !uid || uid === currentUser.uid || !isFollowing(uid)) return;
      const wasFavorite = isFavoriteUser(uid);
      if(wasFavorite) favoriteUserIds.delete(uid);
      else favoriteUserIds.add(uid);
      localStorage.setItem("sermonFavoriteUsers", JSON.stringify([...favoriteUserIds]));
      refreshSavedFavoriteUI();
      if(userProfileBoard.classList.contains('open') && userProfileBoard.dataset.profileUid === uid) openUserProfile(uid);
      if(activeFeedFilter === "favorite") renderPostsPreservingAudio(visiblePosts());
      if(!USE_FIREBASE) return;
      try{
        await fb.set(fb.dbRef(db, `sermonUsers/${currentUser.uid}/favoriteUsers/${uid}`), wasFavorite ? null : true);
      }catch(error){
        if(wasFavorite) favoriteUserIds.add(uid);
        else favoriteUserIds.delete(uid);
        refreshSavedFavoriteUI();
        alert("Could not update favorite. Please try again.");
      }
    }

    function actorPayload(actor={}){
      return {
        actorUid:actor.uid || currentUser?.uid || "",
        actorName:actor.name || currentUser?.displayName || currentProfile?.name || "Church Member",
        actorEmail:actor.email || currentUser?.email || "",
        actorPhoto:actor.photo || currentUser?.photoURL || currentProfile?.photo || ""
      };
    }

    async function sendNotification(toUid, data, actor=null){
      if(!USE_FIREBASE || !toUid || !currentUser || toUid === currentUser.uid) return;
      try{
        const ref = fb.push(fb.dbRef(db, `sermonNotifications/${toUid}`));
        await fb.set(ref, {
          ...data,
          ...actorPayload(actor || {}),
          createdAt:Date.now(),
          read:false
        });
      }catch(error){
        console.warn("Could not send notification:", error);
      }
    }

    async function removeFollowNotifications(toUid, actorUid){
      if(!USE_FIREBASE || !toUid || !actorUid) return;
      try{
        const notificationsRef = fb.dbRef(db, `sermonNotifications/${toUid}`);
        const snap = await fb.get(notificationsRef);
        const notifications = snap.val() || {};
        const updates = {};
        Object.entries(notifications).forEach(([id, item]) => {
          if(item?.type === "follow" && item?.actorUid === actorUid){
            updates[id] = null;
          }
        });
        updates[`follow_${actorUid}`] = null;
        if(Object.keys(updates).length) await fb.update(notificationsRef, updates);
      }catch(error){
        console.warn("Could not remove follow notifications:", error);
      }
    }

    async function loadSocialData(){
      if(!USE_FIREBASE || !currentUser) return;
      try{
        const followsSnap = await fb.get(fb.dbRef(db, 'sermonFollows'));
        const follows = followsSnap.val() || {};
        followerCounts = Object.fromEntries(Object.entries(follows)
          .map(([targetUid, followers]) => [targetUid, Object.keys(followers || {}).length]));
        currentFollowing = Object.fromEntries(Object.entries(follows)
          .filter(([, followers]) => followers && followers[currentUser.uid])
          .map(([targetUid]) => [targetUid, true]));
        currentFollowers = follows[currentUser.uid] || {};
        pruneStaleFollowNotifications();
      }catch(error){
        currentFollowing = {};
        currentFollowers = {};
        followerCounts = {};
        console.warn("Could not load follows:", error);
      }
      try{
        const notificationsSnap = await fb.get(fb.dbRef(db, `sermonNotifications/${currentUser.uid}`));
        userNotifications = notificationsSnap.val() || {};
      }catch(error){
        userNotifications = {};
        console.warn("Could not load notifications:", error);
      }
      try{
        const prefSnap = await fb.get(fb.dbRef(db, `sermonUsers/${currentUser.uid}`));
        const prefs = prefSnap.val() || {};
        savedPostIds = new Set(Object.keys(prefs.savedPosts || {}));
        favoriteUserIds = new Set(Object.keys(prefs.favoriteUsers || {}));
      }catch(error){
        savedPostIds = new Set(JSON.parse(localStorage.getItem("sermonSavedPosts") || "[]"));
        favoriteUserIds = new Set(JSON.parse(localStorage.getItem("sermonFavoriteUsers") || "[]"));
        console.warn("Could not load profile preferences:", error);
      }
      updateAuthUI();
      renderProfileBoard();
      refreshNotificationBadge();
    }

    function watchNotifications(){
      if(!USE_FIREBASE || !currentUser || !fb.onValue) return;
      const ref = fb.dbRef(db, `sermonNotifications/${currentUser.uid}`);
      notificationUnsubscribe = fb.onValue(ref, snap => {
        userNotifications = snap.val() || {};
        pruneStaleFollowNotifications();
        refreshNotificationBadge();
        if(notificationBoard.classList.contains('open')) renderNotificationList();
      }, error => {
        console.warn("Could not watch notifications:", error);
      });
    }

    function stopRealtimeWatchers(){
      [postsUnsubscribe, followsUnsubscribe, likesUnsubscribe, seenUnsubscribe, shareCountsUnsubscribe, adminUsersUnsubscribe].forEach(unsubscribe => {
        try{
          if(typeof unsubscribe === "function") unsubscribe();
        }catch(error){
          console.warn("Could not stop realtime watcher:", error);
        }
      });
      postsUnsubscribe = null;
      followsUnsubscribe = null;
      likesUnsubscribe = null;
      seenUnsubscribe = null;
      shareCountsUnsubscribe = null;
      adminUsersUnsubscribe = null;
      if(adminRefreshTimer){
        clearTimeout(adminRefreshTimer);
        adminRefreshTimer = null;
      }
    }

    function applyFollowsSnapshot(follows){
      const nextFollowerCounts = {};
      const nextFollowing = {};
      Object.entries(follows || {}).forEach(([targetUid, followers]) => {
        const followerMap = followers || {};
        nextFollowerCounts[targetUid] = Object.keys(followerMap).length;
        if(currentUser && followerMap[currentUser.uid]) nextFollowing[targetUid] = true;
      });
      currentFollowers = currentUser ? (follows?.[currentUser.uid] || {}) : {};
      const changedUids = new Set([
        ...Object.keys(followerCounts),
        ...Object.keys(nextFollowerCounts),
        ...Object.keys(currentFollowing),
        ...Object.keys(nextFollowing)
      ]);
      followerCounts = nextFollowerCounts;
      currentFollowing = nextFollowing;
      changedUids.forEach(refreshFollowUI);
      updateAuthUI();
      if(profileBoard.classList.contains('open')) renderProfileBoard();
      if(notificationBoard.classList.contains('open')) renderNotificationList();
      refreshNotificationBadge();
      pruneStaleFollowNotifications();
    }

    function updatePostMetaUI(){
      document.querySelectorAll('.post').forEach(postEl => {
        const postId = postEl.dataset.postId;
        if(!postId) return;
        const likeBtn = postEl.querySelector('.like');
        if(likeBtn) likeBtn.classList.toggle('liked', userLikedPostIds.has(postId));
        updateSeenStack(postId, postEl);
      });
      refreshSeenBoardIfOpen();
    }

    function cssEscape(value){
      return window.CSS?.escape ? CSS.escape(String(value || "")) : String(value || "").replace(/"/g, '\\"');
    }

    function postRenderSignature(post){
      if(!post) return "";
      const {likes, shares, views, ...renderFields} = post;
      return JSON.stringify(renderFields);
    }

    function postsCanPatchCountersOnly(previousPosts, nextPosts){
      if(previousPosts.length !== nextPosts.length) return false;
      return nextPosts.every((post, index) => {
        const previous = previousPosts[index];
        return previous?.id === post.id && postRenderSignature(previous) === postRenderSignature(post);
      });
    }

    function updatePostCounterUI(posts){
      posts.forEach(post => {
        const postEl = document.querySelector(`.post[data-post-id="${cssEscape(post.id)}"]`);
        if(!postEl) return;
        const likeCount = postEl.querySelector('.like-btn span');
        const shareCount = postEl.querySelector('.share-btn span');
        const viewCount = postEl.querySelector('.view-btn span');
        if(likeCount) likeCount.textContent = Number(post.likes || 0);
        if(shareCount) shareCount.textContent = shareCountForPost(post);
        if(viewCount) viewCount.textContent = Number(post.views || 0);
      });
      if(profileBoard.classList.contains('open')) renderProfileBoard();
    }

    function applyPostsSnapshot(value){
      const previousVisiblePosts = visiblePosts();
      const nextPosts = Object.entries(value || {})
        .map(([id,p]) => ({id,...p}))
        .sort((a,b)=>(b.createdAt||0)-(a.createdAt||0));
      cleanupInvalidPostsForAdmin(nextPosts);
      const nextVisiblePosts = visiblePostsFrom(nextPosts);
      const canPatchCounters = postsCanPatchCountersOnly(previousVisiblePosts, nextVisiblePosts)
        && document.querySelectorAll('.post[data-post-id]').length > 0;

      firebasePosts = nextPosts;
      if(canPatchCounters){
        updatePostCounterUI(nextVisiblePosts);
        updatePostMetaUI();
        return;
      }

      renderPostsPreservingAudio(nextVisiblePosts);
    }

    async function cleanupInvalidPostsForAdmin(posts=[]){
      if(!USE_FIREBASE || !isAdmin()) return;
      const invalidPosts = posts.filter(post => !isValidPost(post));
      if(!invalidPosts.length) return;
      const updates = {};
      invalidPosts.forEach(post => {
        if(!post.id) return;
        updates[`sermonPosts/${post.id}`] = null;
        updates[`sermonPostLikes/${post.id}`] = null;
        updates[`sermonPostSeen/${post.id}`] = null;
        updates[`sermonPostSaves/${post.id}`] = null;
      });
      if(!Object.keys(updates).length) return;
      try{
        await fb.update(fb.dbRef(db), updates);
      }catch(error){
        console.warn("Could not clean invalid posts:", error);
      }
    }

    function scheduleAdminRealtimeRefresh(){
      if(!isAdmin()) return;
      clearTimeout(adminRefreshTimer);
      adminRefreshTimer = setTimeout(() => {
        loadAdminRequests().catch(error => console.warn("Could not refresh admin data:", error));
      }, 120);
    }

    function watchRealtimeData(){
      if(!USE_FIREBASE || !currentUser || !fb.onValue) return;
      postsUnsubscribe = fb.onValue(fb.dbRef(db, 'sermonPosts'), snap => {
        applyPostsSnapshot(snap.val() || {});
        renderRoleUI();
        scheduleAdminRealtimeRefresh();
      }, error => console.warn("Could not watch posts:", error));

      followsUnsubscribe = fb.onValue(fb.dbRef(db, 'sermonFollows'), snap => {
        applyFollowsSnapshot(snap.val() || {});
      }, error => console.warn("Could not watch follows:", error));

      likesUnsubscribe = fb.onValue(fb.dbRef(db, 'sermonPostLikes'), snap => {
        const likeVal = snap.val() || {};
        userLikedPostIds = new Set(Object.entries(likeVal)
          .filter(([, users]) => users && users[currentUser.uid])
          .map(([postId]) => postId));
        updatePostMetaUI();
      }, error => console.warn("Could not watch likes:", error));

      seenUnsubscribe = fb.onValue(fb.dbRef(db, 'sermonPostSeen'), snap => {
        postSeenUsers = snap.val() || {};
        updatePostMetaUI();
      }, error => console.warn("Could not watch seen users:", error));

      shareCountsUnsubscribe = fb.onValue(fb.dbRef(db, 'shareCounts'), snap => {
        postShareCounts = snap.val() || {};
        updatePostCounterUI(visiblePosts());
      }, error => console.warn("Could not watch share counts:", error));

      if(isAdmin()){
        adminUsersUnsubscribe = fb.onValue(fb.dbRef(db, 'sermonUsers'), () => {
          scheduleAdminRealtimeRefresh();
        }, error => console.warn("Could not watch users:", error));
      }
    }

    async function toggleFollow(targetUid){
      if(!currentUser || !targetUid || targetUid === currentUser.uid) return;
      const wasFollowing = isFollowing(targetUid);
      currentFollowing[targetUid] = !wasFollowing;
      if(wasFollowing) delete currentFollowing[targetUid];
      if(wasFollowing && favoriteUserIds.has(targetUid)){
        favoriteUserIds.delete(targetUid);
        localStorage.setItem("sermonFavoriteUsers", JSON.stringify([...favoriteUserIds]));
        if(USE_FIREBASE) fb.set(fb.dbRef(db, `sermonUsers/${currentUser.uid}/favoriteUsers/${targetUid}`), null).catch(()=>{});
      }
      followerCounts[targetUid] = Math.max(0, followerCount(targetUid) + (wasFollowing ? -1 : 1));
      refreshFollowUI(targetUid);
      const followRef = fb.dbRef(db, `sermonFollows/${targetUid}/${currentUser.uid}`);
      const followNotificationRef = fb.dbRef(db, `sermonNotifications/${targetUid}/follow_${currentUser.uid}`);
      try{
        if(wasFollowing){
          await fb.remove(followRef);
        }else{
          await fb.set(followRef, currentActor());
          await fb.set(followNotificationRef, {
            type:"follow",
            ...actorPayload(),
            createdAt:Date.now(),
            read:false
          }).catch(error => {
            console.warn("Could not send follow notification:", error);
          });
        }
      }catch(error){
        if(wasFollowing) currentFollowing[targetUid] = true;
        else delete currentFollowing[targetUid];
        followerCounts[targetUid] = Math.max(0, followerCount(targetUid) + (wasFollowing ? 1 : -1));
        refreshFollowUI(targetUid);
        alert("Could not update follow. Please check Firebase rules.");
      }
