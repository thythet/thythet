<!DOCTYPE html>
<html lang="km">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Sermon Post</title>
  <meta name="description" content="Church sermon image and audio post platform." />
  <meta name="theme-color" content="#081522" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Kantumruy+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    @font-face{
      font-family:'Krasar';
      src:url('https://thythet.com/assets/fonts/Krasar.woff') format('woff');
      font-weight:400;
      font-display:swap;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      min-height:100vh;
      background:
        radial-gradient(circle at 15% -10%, rgba(57,121,255,.20), transparent 34%),
        radial-gradient(circle at 100% 8%, rgba(0,211,184,.13), transparent 30%),
        #081522;
      font-family:'Kantumruy Pro', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      color:#fff;
      overflow-x:hidden;
    }
    body.auth-locked .app,
    body.auth-locked .bottom-nav{display:none}

    :root{
      /* EDIT ONLY THESE TWO VALUES TO TUNE UI */
      --avatar-radius:6px;
      --card-width:390px;

      /* AUTO CALCULATED */
      --gap:calc(var(--avatar-radius) * 2);
      --media-radius:calc(var(--avatar-radius) + var(--gap));
      --audio-radius:var(--media-radius);
      --card-radius:calc(var(--media-radius) + var(--gap));

      --avatar-size:38px;
      --text:#fff;
      --muted:rgba(255,255,255,.82);
      --soft:rgba(255,255,255,.55);
      --line:rgba(255,255,255,.14);
      --danger:#ff496d;
      --blue:#72c2ff;
    }

    button,input,textarea{font-family:inherit}
    button{cursor:pointer}

    .app{
      width:min(100%, calc(var(--card-width) + 20px));
      margin:0 auto;
      padding:10px 10px 74px;
    }

    .topbar{
      position:sticky;
      top:0;
      z-index:30;
      margin:0 -10px 10px;
      padding:10px 10px 8px;
      background:linear-gradient(180deg, rgba(8,21,34,.72), rgba(8,21,34,.28), transparent);
      backdrop-filter:blur(16px);
      -webkit-backdrop-filter:blur(16px);
    }

    .topbar-inner{
      width:min(100%, var(--card-width));
      margin:0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }

    .profile-chip{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
      flex:1 1 auto;
      border:0;
      background:transparent;
      color:#fff;
      padding:0;
      text-align:left;
    }

    .profile-avatar{
      width:38px;
      height:38px;
      border-radius:50%;
      border:1px solid rgba(255,255,255,.28);
      background:rgba(255,255,255,.10);
      display:grid;
      place-items:center;
      flex:0 0 auto;
      overflow:hidden;
      box-shadow:0 12px 28px rgba(0,0,0,.22);
    }

    .profile-avatar img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    .profile-avatar svg{
      width:20px;
      height:20px;
      stroke-width:2;
    }

    .profile-name{
      font-size:15px;
      font-weight:800;
      line-height:1.15;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .profile-email{
      margin-top:3px;
      font-size:11px;
      color:var(--soft);
      line-height:1.2;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .profile-board{
      position:fixed;
      inset:0;
      z-index:90;
      display:none;
      align-items:flex-start;
      justify-content:center;
      padding:84px 10px 88px;
      background:rgba(3,10,18,.56);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      overflow:auto;
    }
    .profile-board.open{display:flex}
    .profile-sheet{
      width:min(100%, var(--card-width));
      border:1px solid rgba(255,255,255,.16);
      border-radius:24px;
      background:rgba(12,29,45,.94);
      box-shadow:0 24px 70px rgba(0,0,0,.42);
      overflow:hidden;
    }
    .profile-board-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:14px;
      background:rgba(255,255,255,.06);
      border-bottom:1px solid rgba(255,255,255,.12);
    }
    .profile-board-user{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }
    .profile-board-avatar{
      width:54px;
      height:54px;
      border-radius:16px;
      overflow:hidden;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.18);
      flex:0 0 auto;
      display:grid;
      place-items:center;
    }
    .profile-board-avatar img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }
    .profile-board-avatar svg{width:25px;height:25px}
    .profile-board-name{
      font-size:18px;
      font-weight:900;
      line-height:1.1;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .profile-board-email{
      margin-top:5px;
      color:var(--muted);
      font-size:12px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .profile-board-role{
      margin-top:8px;
      display:inline-flex;
      max-width:100%;
      border-radius:999px;
      padding:5px 8px;
      background:rgba(114,194,255,.18);
      color:#d7efff;
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.04em;
    }
    .profile-close-btn{
      width:38px;
      height:38px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.16);
      background:rgba(255,255,255,.08);
      color:#fff;
      display:grid;
      place-items:center;
      padding:0;
      flex:0 0 auto;
    }
    .profile-close-btn svg{width:19px;height:19px;stroke-width:2.2}
    .profile-board-body{
      padding:14px;
      display:flex;
      flex-direction:column;
      gap:14px;
    }
    .profile-actions{
      display:flex;
      gap:10px;
    }
    .profile-action-btn{
      min-height:42px;
      border:1px solid rgba(255,255,255,.14);
      border-radius:16px;
      background:rgba(255,255,255,.08);
      color:#fff;
      font-size:12px;
      font-weight:900;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      padding:0 12px;
      flex:1;
    }
    .profile-action-btn.danger{
      background:rgba(255,73,109,.16);
      color:#ffd5dd;
    }
    .profile-action-btn svg{width:18px;height:18px;stroke-width:2.2}
    .profile-section{
      border-top:1px solid rgba(255,255,255,.12);
      padding-top:14px;
    }
    .profile-section:first-child{border-top:0;padding-top:0}
    .section-title{
      font-size:13px;
      font-weight:900;
      margin-bottom:8px;
    }
    .section-copy{
      color:var(--muted);
      font-size:12px;
      line-height:1.5;
    }

    .top-actions{
      display:flex;
      align-items:center;
      gap:8px;
      flex:0 0 auto;
    }

    .circle-btn{
      width:38px;
      height:38px;
      border-radius:14px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.08);
      color:#fff;
      display:grid;
      place-items:center;
      padding:0;
    }

    .circle-btn svg{width:20px;height:20px;stroke-width:2}

    .circle-btn img{
      width:24px;
      height:24px;
      border-radius:50%;
      object-fit:cover;
      display:block;
    }

    .auth-chip{
      max-width:116px;
      height:38px;
      border-radius:14px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.08);
      color:#fff;
      padding:0 10px;
      display:flex;
      align-items:center;
      gap:7px;
      font-size:12px;
      font-weight:800;
      overflow:hidden;
    }

    .auth-chip img{
      width:22px;
      height:22px;
      border-radius:50%;
      object-fit:cover;
      flex:0 0 auto;
    }

    .auth-chip span{
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .notice{
      display:none;
      width:100%;
      border-radius:18px;
      padding:12px 14px;
      margin-bottom:10px;
      background:rgba(255,255,255,.08);
      border:1px solid var(--line);
      color:var(--muted);
      font-size:12px;
      line-height:1.55;
    }
    .notice.show{display:block}

    .auth-gate{
      position:fixed;
      inset:0;
      z-index:100;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:28px;
      background:
        radial-gradient(circle at 18% 0%, rgba(57,121,255,.22), transparent 32%),
        radial-gradient(circle at 95% 10%, rgba(0,211,184,.16), transparent 28%),
        rgba(8,21,34,.98);
    }
    .auth-gate.hidden{display:none}
    .auth-gate.checking .auth-card{
      width:min(100%, calc(var(--card-width) + 20px));
      gap:14px;
    }
    .auth-card{
      width:min(100%, 760px);
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:30px;
    }
    .welcome-art-btn{
      width:min(100%, 680px);
      border:16px solid #fff;
      border-radius:34px;
      background:#d9edff;
      padding:0;
      display:block;
      overflow:hidden;
      box-shadow:0 28px 70px rgba(0,0,0,.28);
      position:relative;
      min-height:180px;
    }
    .auth-gate.checking .welcome-art-btn{
      width:100%;
      min-height:620px;
      border:1px solid rgba(255,255,255,.16);
      border-radius:26px;
      background:rgba(255,255,255,.06);
      pointer-events:none;
      box-shadow:0 24px 70px rgba(0,0,0,.26);
    }
    .welcome-art-btn.loading::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(90deg, transparent, rgba(255,255,255,.48), transparent),
        linear-gradient(145deg, #d8ecff, #acd6f6);
      background-size:220% 100%, 100% 100%;
      animation:welcomeShimmer 1.2s linear infinite;
      z-index:1;
    }
    .auth-gate.checking .welcome-art-btn.loading::before{
      inset:16px;
      border-radius:20px;
      background:
        linear-gradient(90deg, transparent, rgba(255,255,255,.20), transparent),
        radial-gradient(circle at 34px 34px, rgba(255,255,255,.30) 0 18px, transparent 19px),
        linear-gradient(rgba(255,255,255,.32), rgba(255,255,255,.32)) 68px 20px/150px 16px no-repeat,
        linear-gradient(rgba(255,255,255,.18), rgba(255,255,255,.18)) 68px 46px/104px 12px no-repeat,
        linear-gradient(rgba(255,255,255,.18), rgba(255,255,255,.18)) 0 94px/100% 260px no-repeat,
        linear-gradient(rgba(255,255,255,.24), rgba(255,255,255,.24)) 0 382px/86px 14px no-repeat,
        linear-gradient(rgba(255,255,255,.16), rgba(255,255,255,.16)) 0 414px/100% 12px no-repeat,
        linear-gradient(rgba(255,255,255,.16), rgba(255,255,255,.16)) 0 452px/72% 12px no-repeat,
        linear-gradient(rgba(255,255,255,.16), rgba(255,255,255,.16)) 0 490px/58% 12px no-repeat,
        rgba(255,255,255,.08);
      background-size:220% 100%, auto, 150px 16px, 104px 12px, 100% 260px, 86px 14px, 100% 12px, 72% 12px, 58% 12px, auto;
      animation:welcomeShimmer 1.15s linear infinite;
    }
    .welcome-art-btn.loading::after{
      content:"Loading welcome...";
      position:absolute;
      inset:0;
      z-index:2;
      display:grid;
      place-items:center;
      color:#41637d;
      font-size:13px;
      font-weight:800;
      letter-spacing:.2px;
    }
    .auth-gate.checking .welcome-art-btn.loading::after{
      content:"";
    }
    .welcome-art-btn.failed::after{
      content:"Welcome to Sermon Post";
      position:absolute;
      inset:0;
      display:grid;
      place-items:center;
      color:#34536c;
      font-size:20px;
      font-weight:800;
    }
    .welcome-art-btn img{
      width:100%;
      height:auto;
      display:block;
      border-radius:18px;
      opacity:1;
      transition:opacity .22s ease;
    }
    .welcome-art-btn.loading img{opacity:0}
    .google-signin-btn{
      min-height:64px;
      border-radius:999px;
      border:2px solid rgba(255,255,255,.62);
      background:#1f1f1f;
      color:#f5f5f5;
      padding:0 26px 0 20px;
      display:flex;
      align-items:center;
      gap:16px;
      font-size:26px;
      font-weight:700;
      line-height:1;
      box-shadow:0 18px 40px rgba(0,0,0,.28);
    }
    .google-signin-btn:disabled{
      cursor:wait;
      opacity:.72;
    }
    .auth-gate.checking .google-signin-btn{display:none}
    .google-signin-btn svg{
      width:40px;
      height:40px;
      flex:0 0 auto;
    }
    .auth-loading-text{
      color:rgba(255,255,255,.78);
      font-size:13px;
      min-height:18px;
      text-align:center;
    }
    .auth-card-skeleton{display:none}
    .auth-gate.checking .welcome-art-btn{display:none}
    .auth-gate.checking .auth-card-skeleton{display:block}
    .auth-card-skeleton .media,
    .auth-card-skeleton .audio,
    .auth-card-skeleton .action,
    .auth-card-skeleton .post-author,
    .auth-card-skeleton .post-time,
    .auth-card-skeleton .caption-text,
    .auth-card-skeleton .avatar,
    .auth-card-skeleton .name,
    .auth-card-skeleton .email,
    .auth-card-skeleton .media-count{
      color:transparent;
      position:relative;
      overflow:hidden;
    }
    .auth-card-skeleton .media,
    .auth-card-skeleton .avatar,
    .auth-card-skeleton .name,
    .auth-card-skeleton .email,
    .auth-card-skeleton .audio,
    .auth-card-skeleton .post-author,
    .auth-card-skeleton .post-time,
    .auth-card-skeleton .caption-text{
      background:rgba(255,255,255,.12);
    }
    .auth-card-skeleton .media::before,
    .auth-card-skeleton .avatar::before,
    .auth-card-skeleton .name::before,
    .auth-card-skeleton .email::before,
    .auth-card-skeleton .audio::before,
    .auth-card-skeleton .post-author::before,
    .auth-card-skeleton .post-time::before,
    .auth-card-skeleton .caption-text::before{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(90deg, transparent, rgba(255,255,255,.22), transparent);
      background-size:220% 100%;
      animation:skeleton 1.2s ease-in-out infinite;
    }
    .auth-card-skeleton .media::after{background:none}
    .auth-card-skeleton .name{
      width:118px;
      height:16px;
      border-radius:999px;
    }
    .auth-card-skeleton .email{
      width:92px;
      height:12px;
      border-radius:999px;
    }
    .auth-card-skeleton .media-count{
      width:28px;
      height:14px;
      border-radius:999px;
      background:rgba(255,255,255,.18);
    }
    .auth-card-skeleton .speaker,
    .auth-card-skeleton .track,
    .auth-card-skeleton .time,
    .auth-card-skeleton .action svg,
    .auth-card-skeleton .action span{
      opacity:.34;
    }
    .auth-card-skeleton .caption-text{
      height:18px;
      border-radius:999px;
      display:block;
    }
    @keyframes welcomeShimmer{
      to{background-position:-220% 0, 0 0}
    }
    @media(max-width:640px){
      .auth-card{gap:20px}
      .welcome-art-btn{
        border-width:10px;
        border-radius:24px;
      }
      .welcome-art-btn img{border-radius:13px}
      .google-signin-btn{
        min-height:52px;
        font-size:18px;
        padding:0 20px 0 16px;
      }
      .google-signin-btn svg{width:31px;height:31px}
    }
    .role-card,
    .admin-panel{
      display:none;
      margin-bottom:10px;
      border-radius:var(--card-radius);
      background:rgba(255,255,255,.08);
      border:1px solid var(--line);
      padding:14px;
    }
    .role-card.show,
    .admin-panel.show{display:block}
    .panel-title{
      font-size:13px;
      font-weight:800;
      margin-bottom:6px;
    }
    .panel-copy{
      color:var(--muted);
      font-size:12px;
      line-height:1.55;
      margin-bottom:10px;
    }
    .request-row{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      border-top:1px solid var(--line);
      padding-top:10px;
      margin-top:10px;
    }
    .request-row.pending-post-row,
    .request-row.user-row{align-items:flex-start}
    .pending-thumb{
      width:46px;
      height:46px;
      border-radius:12px;
      object-fit:cover;
      background:rgba(255,255,255,.12);
      flex:0 0 auto;
    }
    .request-meta{
      min-width:0;
      flex:1;
      font-size:12px;
      color:var(--muted);
      line-height:1.45;
    }
    .request-role{
      display:inline-flex;
      margin-top:4px;
      border-radius:999px;
      padding:3px 7px;
      background:rgba(255,255,255,.10);
      color:rgba(255,255,255,.78);
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
    }
    .request-avatar{
      width:42px;
      height:42px;
      border-radius:13px;
      object-fit:cover;
      background:rgba(255,255,255,.12);
      flex:0 0 auto;
    }
    .request-meta strong{
      color:#fff;
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .mini-btn.primary{background:rgba(114,194,255,.24)}
    .mini-btn.danger{background:rgba(255,73,109,.18)}
    .mini-btn.warning{background:rgba(255,181,62,.18)}
    .mini-btn:disabled{
      opacity:.42;
      cursor:not-allowed;
    }

    .composer{
      display:none;
      margin-bottom:10px;
      border-radius:var(--card-radius);
      background:linear-gradient(145deg,#28114f,#103d69 56%,#087064);
      padding:var(--gap);
      overflow:hidden;
    }
    .composer.open{display:block}

    .composer-form{
      display:flex;
      flex-direction:column;
      gap:var(--gap);
    }

    .field{
      width:100%;
      border:0;
      outline:0;
      border-radius:var(--media-radius);
      background:rgba(255,255,255,.14);
      color:#fff;
      padding:12px 13px;
      font-size:13px;
      font-weight:600;
    }

    textarea.field{
      min-height:88px;
      resize:vertical;
      line-height:1.55;
      font-family:'Krasar','Kantumruy Pro',sans-serif;
    }

    .field::placeholder{color:rgba(255,255,255,.55)}
    .image-link-builder{
      display:flex;
      flex-direction:column;
      gap:8px;
    }
    .image-link-row{
      display:grid;
      grid-template-columns:1fr 38px;
      gap:8px;
      align-items:center;
    }
    .image-link-row .field{
      min-height:46px;
      padding:10px 12px;
    }
    .link-icon-btn{
      width:38px;
      height:38px;
      border:1px solid var(--line);
      border-radius:14px;
      background:rgba(255,255,255,.12);
      color:#fff;
      display:grid;
      place-items:center;
      padding:0;
    }
    .link-icon-btn svg{
      width:19px;
      height:19px;
      stroke-width:2.2;
    }
    .link-icon-btn:disabled{
      opacity:.45;
      cursor:not-allowed;
    }
    .field-help{
      color:rgba(255,255,255,.62);
      font-size:11px;
      line-height:1.4;
      padding:0 4px;
    }
    .file-row{display:grid;grid-template-columns:1fr;gap:var(--gap)}

    .file-box{
      border-radius:var(--media-radius);
      border:1px dashed rgba(255,255,255,.28);
      background:rgba(255,255,255,.10);
      padding:12px;
      color:var(--muted);
      font-size:12px;
      line-height:1.5;
    }

    .file-box input{width:100%;margin-top:8px;color:#fff}

    .composer-actions{
      display:flex;
      gap:var(--gap);
    }

    .btn{
      min-height:44px;
      border:0;
      border-radius:var(--media-radius);
      color:#fff;
      font-weight:800;
      font-size:13px;
      padding:0 14px;
      background:rgba(255,255,255,.14);
      flex:1;
    }

    .btn.primary{background:rgba(114,194,255,.28)}
    .btn.danger{background:rgba(255,73,109,.20)}
    .composer-status{
      min-height:20px;
      margin:2px 4px 0;
      color:rgba(255,255,255,.82);
      font-size:12px;
      line-height:1.45;
    }
    .composer-status.error{color:#ffd0d0}
    .composer-status.success{color:#d5ffe6}

    .feed{
      display:flex;
      flex-direction:column;
      gap:14px;
    }

    .empty{
      padding:26px 14px;
      text-align:center;
      color:var(--soft);
      font-size:13px;
      line-height:1.7;
    }

    .post{
      width:100%;
