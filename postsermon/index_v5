    function setupLazyImages(){
      const imgs = document.querySelectorAll('img[data-src]');
      const io = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if(!entry.isIntersecting) return;
          const img = entry.target;
          img.src = img.dataset.src;
          img.onload = () => img.classList.add('loaded');
          io.unobserve(img);
        });
      }, {rootMargin:"260px"});
      imgs.forEach(img => io.observe(img));
    }

    function setupSliders(){
      document.querySelectorAll('.media').forEach(media => {
        const slides = media.querySelector('.slides');
        const dots = [...media.querySelectorAll('.dot')];
        const count = media.querySelector('.media-count');
        if(!slides) return;

        slides.addEventListener('scroll', () => {
          const active = Math.round(slides.scrollLeft / slides.clientWidth);
          dots.forEach((dot,i)=>dot.classList.toggle('active', i === active));
          if(count) count.textContent = `${active + 1}/${Math.max(dots.length,1)}`;
        }, {passive:true});
      });
    }

    function setupCaptions(){
      document.querySelectorAll('.caption-line').forEach(line => {
        const text = line.querySelector('.caption-text');
        const btn = line.querySelector('.more-link');
        if(!text || !btn) return;

        requestAnimationFrame(() => {
          const needsMore = text.scrollWidth > text.clientWidth + 2;
          line.classList.toggle('needs-more', needsMore);
        });

        btn.addEventListener('click', () => {
          const expanded = line.classList.toggle('expanded');
          btn.textContent = expanded ? "less" : "more";
        });
      });
    }

    function setupAudio(){
      document.querySelectorAll('[data-audio-ui]').forEach(ui => {
        const btn = ui.querySelector('.speaker');
        const audio = ui.querySelector('audio');
        const current = ui.querySelector('.current');
        const duration = ui.querySelector('.duration');
        const progress = ui.querySelector('.progress');
        const track = ui.querySelector('.track');

        if(!audio){
          btn.addEventListener('click',()=>alert('No audio added yet.'));
          return;
        }

        audio.addEventListener('loadedmetadata',()=>{
          duration.textContent = formatTime(audio.duration);
        });

        audio.addEventListener('timeupdate',()=>{
          current.textContent = formatTime(audio.currentTime);
          const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
          progress.style.width = pct + "%";
        });

        btn.addEventListener('click', async ()=>{
          document.querySelectorAll('audio').forEach(a => { if(a !== audio) a.pause(); });
          if(audio.paused) await audio.play();
          else audio.pause();
        });

        track.addEventListener('click', e => {
          const rect = track.getBoundingClientRect();
          const pct = (e.clientX - rect.left) / rect.width;
          audio.currentTime = pct * audio.duration;
        });
      });
    }

    function formatTime(sec){
      if(!isFinite(sec)) return "00:00";
      const m = Math.floor(sec / 60);
      const s = Math.floor(sec % 60);
      return String(m).padStart(2,'0') + ":" + String(s).padStart(2,'0');
    }

    async function loadFirebasePosts(){
      if(!USE_FIREBASE) return renderPosts(demoPosts);
      if(!currentUser) return renderAuthGate();
      const snap = await fb.get(fb.dbRef(db, 'sermonPosts'));
      const val = snap.val() || {};
      const posts = Object.entries(val).map(([id,p]) => ({id,...p})).sort((a,b)=>(b.createdAt||0)-(a.createdAt||0));
      firebasePosts = posts;
      const visiblePosts = posts.filter(post => post.status !== "pending" || isAdmin() || post.authorUid === currentUser.uid);
      const likeSnap = await fb.get(fb.dbRef(db, 'sermonPostLikes'));
      const likeVal = likeSnap.val() || {};
      userLikedPostIds = new Set(Object.entries(likeVal)
        .filter(([, users]) => users && users[currentUser.uid])
        .map(([postId]) => postId));
      renderPosts(visiblePosts);
      renderRoleUI();
      if(isAdmin()) await loadAdminRequests();
    }

    async function uploadFile(file, folder){
      if(!USE_FIREBASE) return "";
      const clean = file.name.replace(/[^\w.\-]+/g,'_');
      const path = `${folder}/${Date.now()}_${clean}`;
      const fileRef = fb.storageRef(storage, path);
      await fb.uploadBytes(fileRef, file);
      return await fb.getDownloadURL(fileRef);
    }

