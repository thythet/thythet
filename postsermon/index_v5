    function escapeHTML(str=""){
      return String(str).replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[s]));
    }

    function emailHandle(email=""){
      const local = String(email || "").split("@")[0].trim();
      return local ? "@" + local : "@member";
    }

    function timeAgo(ms){
      const diff = Math.max(1, Date.now() - Number(ms || Date.now()));
      const m = Math.floor(diff/60000);
      const h = Math.floor(m/60);
      const d = Math.floor(h/24);
      if(d) return d + (d === 1 ? " day ago" : " days ago");
      if(h) return h + (h === 1 ? " hour ago" : " hours ago");
      if(m) return m + (m === 1 ? " min ago" : " mins ago");
      return "just now";
    }

