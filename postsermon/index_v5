    async function publishPost(e){
      e.preventDefault();
      const statusEl = document.getElementById('composerStatus');
      const publishBtn = e.target.querySelector('button[type="submit"]');
      const setComposerStatus = (message, type="") => {
        if(!statusEl) return;
        statusEl.textContent = message;
        statusEl.className = "composer-status" + (type ? " " + type : "");
      };

      const caption = document.getElementById('captionInput').value.trim();
      const audioUrlInput = document.getElementById('audioUrlInput').value.trim();
      const imageFiles = [...document.getElementById('imageFilesInput').files].slice(0,5);
      const audioFile = document.getElementById('audioFileInput').files[0];

      let images = getImageLinks();
      let audioUrl = audioUrlInput;

      if(USE_FIREBASE){
        try{
        setComposerStatus("Publishing...");
        if(publishBtn) publishBtn.disabled = true;
        const signedInUser = auth && auth.currentUser ? auth.currentUser : currentUser;
        currentUser = signedInUser;
        updateAuthUI();

        if(!signedInUser){
          alert("Please login first.");
          setComposerStatus("Please login first.", "error");
          return;
        }

        if(!canUpload()){
          setComposerStatus("Request upload access before publishing.", "error");
          alert("Please request upload access first. An admin must approve your account before you can publish.");
          renderRoleUI();
          return;
        }

        const wasEditing = !!editingPostId;
        const editingPost = editingPostId ? firebasePosts.find(post => post.id === editingPostId) : null;
        if(editingPostId && !editingPost){
          setComposerStatus("Could not find the post to edit. Refresh and try again.", "error");
          return;
        }
        if(editingPost && signedInUser.uid !== editingPost.authorUid && !isAdmin()){
          setComposerStatus("You can only edit your own posts.", "error");
          alert("You can only edit your own posts.");
          return;
        }

        if(!isAdmin() && !wasEditing){
          const ownedCount = firebasePosts.filter(post => post.authorUid === signedInUser.uid).length;
          if(ownedCount >= 100){
            setComposerStatus("You reached the 100 post limit. Pro upgrade will be available later.", "error");
            alert("You reached the 100 post limit. Pro upgrade will be available later.");
            return;
          }
        }

        for(const file of imageFiles){
          if(images.length >= 5) break;
          images.push(await uploadFile(file, 'sermon-posts/images'));
        }

        if(audioFile) audioUrl = await uploadFile(audioFile, 'sermon-posts/audio');

        if(!images.length){
          alert("Please add at least one image.");
          setComposerStatus("Please add at least one image.", "error");
          return;
        }

        const postRef = editingPostId
          ? fb.dbRef(db, `sermonPosts/${editingPostId}`)
          : fb.push(fb.dbRef(db, 'sermonPosts'));
        const payload = {
          authorUid:signedInUser.uid,
          authorName:signedInUser.displayName || "Church Member",
          authorEmail:signedInUser.email || "",
          authorPhoto:signedInUser.photoURL || "",
          images,
          audioUrl,
          caption,
          likes:Number(editingPost?.likes || 0),
          shares:Number(editingPost?.shares || 0),
          views:Number(editingPost?.views || 0),
          createdAt:editingPost?.createdAt || Date.now(),
          updatedAt:Date.now(),
          status:isAdmin() ? "published" : "pending"
        };
        if(editingPost && signedInUser.uid !== editingPost.authorUid && isAdmin()){
          payload.authorUid = editingPost.authorUid;
          payload.authorName = editingPost.authorName || "Church Member";
          payload.authorEmail = editingPost.authorEmail || "";
          payload.authorPhoto = editingPost.authorPhoto || "";
        }
        await fb.set(postRef, payload);

        e.target.reset();
        setComposerMode(null);
        composer.classList.remove('open');
        setComposerStatus(
          isAdmin()
            ? (wasEditing ? "Updated successfully." : "Published successfully.")
            : "Submitted for admin approval.",
          "success"
        );
        loadFirebasePosts();
        }catch(error){
          console.error("Publish failed:", error);
          const message = error && (error.code || error.message)
            ? `${error.code || "Error"}: ${error.message || ""}`.trim()
            : "Unknown Firebase error.";
          setComposerStatus("Publish failed. " + message, "error");
          alert("Publish failed.\n\n" + message + "\n\nIf this says permission_denied, update Realtime Database rules.");
        }finally{
          if(publishBtn) publishBtn.disabled = false;
        }
      }else{
        const post = {
          id:"local_" + Date.now(),
          authorName:"Thy Thet",
          authorEmail:"thythet@gmail.com",
          authorPhoto:"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=200&q=80",
          images: images.length ? images : demoPosts[0].images,
          audioUrl,
          caption: caption || "New sermon post caption...",
          likes:0, shares:0, views:0,
          createdAt:Date.now()
        };
        demoPosts.unshift(post);
        e.target.reset();
        composer.classList.remove('open');
        renderPosts(demoPosts);
      }
    }

    function updateAuthUI(){
      const loginBtn = document.getElementById('loginBtn');
      const profileAvatar = document.getElementById('profileAvatar');
      const profileName = document.getElementById('profileName');
      const profileEmail = document.getElementById('profileEmail');
      if(currentUser){
        const displayName = currentUser.displayName || "Church Member";
        const email = currentUser.email || "";
        profileAvatar.innerHTML = currentUser.photoURL
          ? `<img src="${escapeHTML(currentUser.photoURL)}" alt="${escapeHTML(displayName)}">`
          : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>`;
        profileName.textContent = displayName;
        profileEmail.textContent = emailHandle(email);
        loginBtn.innerHTML = icons.logout;
        loginBtn.title = "Logout";
        loginBtn.setAttribute("aria-label", "Logout");
        loginBtn.style.display = "none";
        renderProfileBoard();
      }else{
        profileAvatar.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>`;
        profileName.textContent = "Guest";
        profileEmail.textContent = "Please sign in";
        loginBtn.innerHTML = icons.login;
        loginBtn.title = "Login";
        loginBtn.setAttribute("aria-label", "Login");
        loginBtn.style.display = "";
        renderProfileBoard();
      }
    }

    function handleCreateClick(){
      if(!currentUser) return renderAuthGate();
      if(!canUpload()){
        renderRoleUI();
        roleCard.scrollIntoView({behavior:"smooth", block:"center"});
        return;
      }
      if(!composer.classList.contains('open')) resetComposer();
      composer.classList.toggle('open');
    }

    document.getElementById('composerBtn').addEventListener('click', handleCreateClick);
    document.getElementById('navCreateBtn').addEventListener('click', handleCreateClick);
    document.getElementById('profileChip').addEventListener('click', openProfileBoard);
    document.getElementById('profileCloseBtn').addEventListener('click', closeProfileBoard);
    document.getElementById('profileLogoutBtn').addEventListener('click', signInOrOut);
    profileBoard.addEventListener('click', e => {
      if(e.target === profileBoard) closeProfileBoard();
    });
    let lastScrollY = window.scrollY;
    window.addEventListener('scroll', () => {
      const currentY = window.scrollY;
      const shouldHide = currentY > lastScrollY && currentY > 80 && !profileBoard.classList.contains('open');
      bottomNav.classList.toggle('hidden', shouldHide);
      lastScrollY = Math.max(0, currentY);
    }, {passive:true});
    document.getElementById('clearFormBtn').addEventListener('click', resetComposer);
    document.getElementById('composerForm').addEventListener('submit', publishPost);
    document.getElementById('imageLinkRows').addEventListener('input', syncImageLinkValues);
    document.getElementById('imageLinkRows').addEventListener('click', e => {
      const add = e.target.closest('.add-image-link-btn');
      const remove = e.target.closest('.remove-image-link-btn');
      if(!add && !remove) return;

      syncImageLinkValues();
      if(add && imageLinkValues.length < 5){
        imageLinkValues.push("");
      }
      if(remove){
        const row = e.target.closest('.image-link-row');
        const input = row?.querySelector('.image-link-input');
        const index = Number(input?.dataset.linkIndex || 0);
        imageLinkValues.splice(index, 1);
        if(!imageLinkValues.length) imageLinkValues = [""];
      }
      renderImageLinkFields(imageLinkValues);
    });
    document.getElementById('requestCreatorBtn').addEventListener('click', requestCreatorAccess);

    async function signInOrOut(){
      if(!USE_FIREBASE){
        alert("Demo mode. Set USE_FIREBASE = true and paste Firebase config.");
        return;
      }
      if(auth.currentUser || currentUser){
        const confirmed = window.confirm("Do you want to log out?");
        if(!confirmed) return;
        currentUser = null;
        currentProfile = null;
        closeProfileBoard();
        updateAuthUI();
        return fb.signOut(auth);
      }
      try{
        setLoginBusy(true);
        const provider = new fb.GoogleAuthProvider();
        const result = await fb.signInWithPopup(auth, provider);
        currentUser = result.user || auth.currentUser;
        updateAuthUI();
        await ensureUserProfile(currentUser);
        await loadFirebasePosts();
      }catch(error){
        const authCopy = document.getElementById('authCopy');
        if(authCopy) authCopy.textContent = "Google sign-in was cancelled or could not open. Please try again.";
      }finally{
        setLoginBusy(false);
      }
    }

    document.getElementById('loginBtn').addEventListener('click', signInOrOut);
    document.getElementById('gateLoginBtn').addEventListener('click', signInOrOut);
    document.getElementById('welcomeImageBtn').addEventListener('click', signInOrOut);
    document.getElementById('welcomeImage').addEventListener('load', () => {
      if(authGate.classList.contains('checking')) return;
      document.getElementById('welcomeImageBtn').classList.remove('loading');
    });
    document.getElementById('welcomeImage').addEventListener('error', () => {
      const btn = document.getElementById('welcomeImageBtn');
      btn.classList.remove('loading');
      btn.classList.add('failed');
    });
    if(document.getElementById('welcomeImage').complete && !authGate.classList.contains('checking')){
      document.getElementById('welcomeImageBtn').classList.remove('loading');
    }

    profileBoard.addEventListener('click', async e => {
      if(!isAdmin()) return;
      const userRow = e.target.closest('[data-request-uid]');
      const manageUserRow = e.target.closest('[data-user-uid]');
      const postRow = e.target.closest('[data-pending-post-id]');

      if(userRow){
        const uid = userRow.dataset.requestUid;
        const approve = e.target.closest('.approve-user-btn');
        const reject = e.target.closest('.reject-user-btn');
        if(!approve && !reject) return;

        await fb.update(fb.dbRef(db, `sermonUsers/${uid}`), approve ? {
          role:"content_creator",
          status:"approved",
          approvedAt:Date.now(),
          approvedBy:currentUser.email,
          updatedAt:Date.now()
        } : {
          role:"viewer",
          status:"rejected",
          rejectedAt:Date.now(),
          rejectedBy:currentUser.email,
          updatedAt:Date.now()
        });
        await loadAdminRequests();
        return;
      }

      if(manageUserRow){
        const uid = manageUserRow.dataset.userUid;
        if(uid === currentUser.uid) return;
        const grant = e.target.closest('.grant-user-btn');
        const pending = e.target.closest('.pending-user-btn');
        const remove = e.target.closest('.remove-user-btn');
        if(!grant && !pending && !remove) return;

        const update = grant ? {
          role:"content_creator",
          status:"approved",
          approvedAt:Date.now(),
          approvedBy:currentUser.email,
          updatedAt:Date.now()
        } : pending ? {
          role:"viewer",
          status:"requested",
          requestedRole:"content_creator",
          requestedAt:Date.now(),
          updatedAt:Date.now()
        } : {
          role:"viewer",
          status:"rejected",
          rejectedAt:Date.now(),
          rejectedBy:currentUser.email,
          updatedAt:Date.now()
        };
        await fb.update(fb.dbRef(db, `sermonUsers/${uid}`), update);
        await loadAdminRequests();
        return;
      }

      if(postRow){
        const postId = postRow.dataset.pendingPostId;
        const approve = e.target.closest('.approve-post-btn');
        const reject = e.target.closest('.reject-post-btn');
        if(!approve && !reject) return;

        if(approve){
          await fb.update(fb.dbRef(db, `sermonPosts/${postId}`), {
            status:"published",
            approvedAt:Date.now(),
            approvedBy:currentUser.email,
            updatedAt:Date.now()
          });
        }else{
          const confirmed = window.confirm("Reject and delete this pending post?");
          if(!confirmed) return;
          await fb.remove(fb.dbRef(db, `sermonPosts/${postId}`));
        }
        await loadFirebasePosts();
      }
    });

    feed.addEventListener('click', async e => {
      const postEl = e.target.closest('.post');
      if(!postEl) return;
      const id = postEl.dataset.postId;
      const post = firebasePosts.find(entry => entry.id === id);

      const editBtn = e.target.closest('.edit-post-btn');
      if(editBtn){
        if(!post) return alert("Could not find this post. Please refresh and try again.");
        if(!currentUser || (currentUser.uid !== post.authorUid && !isAdmin())){
          return alert("You can only edit your own posts.");
        }
        setComposerMode(post);
        return;
      }

      const deleteBtn = e.target.closest('.delete-post-btn');
      if(deleteBtn){
        if(!post) return alert("Could not find this post. Please refresh and try again.");
        if(!currentUser || (currentUser.uid !== post.authorUid && !isAdmin())){
          return alert("You can only delete your own posts.");
        }
        const confirmed = window.confirm("Delete this sermon post? This cannot be undone.");
        if(!confirmed) return;

        deleteBtn.disabled = true;
        try{
          await fb.remove(fb.dbRef(db, `sermonPosts/${id}`));
          await loadFirebasePosts();
        }catch(error){
          deleteBtn.disabled = false;
          alert("Could not delete this post. Please check Firebase rules and try again.");
        }
        return;
      }

      const like = e.target.closest('.like-btn');
      if(like){
        if(!currentUser) return renderAuthGate();
        const span = like.querySelector('span');
        const wasLiked = userLikedPostIds.has(id);
        like.classList.toggle('liked', !wasLiked);
        span.textContent = Math.max(0, Number(span.textContent) + (wasLiked ? -1 : 1));
        const likeRef = fb.dbRef(db, `sermonPostLikes/${id}/${currentUser.uid}`);
        const countRef = fb.dbRef(db, `sermonPosts/${id}/likes`);
        try{
          if(wasLiked){
            await fb.remove(likeRef);
            await fb.runTransaction(countRef, count => Math.max(0, Number(count || 0) - 1));
            userLikedPostIds.delete(id);
          }else{
            await fb.set(likeRef, {
              email:currentUser.email || "",
              name:currentUser.displayName || "",
              at:Date.now()
            });
            await fb.runTransaction(countRef, count => Number(count || 0) + 1);
            userLikedPostIds.add(id);
          }
        }catch(error){
          like.classList.toggle('liked', wasLiked);
          span.textContent = Math.max(0, Number(span.textContent) + (wasLiked ? 1 : -1));
          alert("Could not update like. Please try again.");
        }
      }

      const share = e.target.closest('.share-btn');
      if(share){
        const text = location.href.split('#')[0] + '#post-' + id;
        if(navigator.share) await navigator.share({title:"Sermon Post", url:text}).catch(()=>{});
        else await navigator.clipboard.writeText(text);
      }
    });

    renderImageLinkFields();
    renderAuthGate("checking");
  </script>
</body>
</html>
